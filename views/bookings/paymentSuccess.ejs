<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="icon" type="image/png" href="/images/favicon-removebg-preview.png">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Payment Successful - Stayzio</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen flex flex-col">
  <%- include("../includes/navbar.ejs") %>

  <div class="flex-grow flex items-center justify-center py-12 px-4">
    <div class="max-w-md w-full bg-white dark:bg-gray-800 p-8 rounded-3xl shadow-2xl text-center border border-gray-100 dark:border-gray-700 relative overflow-hidden">
      
      <div class="absolute top-0 left-0 w-full h-32 bg-gradient-to-br from-green-400/20 to-green-600/20 rounded-b-[50%] -translate-y-16"></div>

      <div class="relative mx-auto w-24 h-24 bg-green-100 dark:bg-green-900/30 text-green-500 rounded-full flex items-center justify-center mb-6 shadow-inner shadow-green-500/20">
        <i class="fa-solid fa-check text-5xl"></i>
      </div>

      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Payment Successful!</h1>
      <p class="text-gray-500 dark:text-gray-400 mb-8">Your booking for <span class="font-semibold text-gray-800 dark:text-gray-200"><%= booking.listing.title %></span> has been confirmed.</p>
      
      <div class="bg-gray-50 dark:bg-gray-700/50 rounded-2xl p-5 mb-8 text-left border border-gray-100 dark:border-gray-600">
        <div class="flex justify-between items-center mb-3">
          <span class="text-sm text-gray-500 dark:text-gray-400">Amount Paid</span>
          <span class="font-semibold text-gray-900 dark:text-white">₹ <%= booking.finalTotal.toLocaleString("en-IN") %></span>
        </div>
        <div class="flex justify-between items-center mb-3">
          <span class="text-sm text-gray-500 dark:text-gray-400">Transaction ID</span>
          <span class="font-medium text-xs text-gray-600 dark:text-gray-300 font-mono"><%= booking.transactionId %></span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-sm text-gray-500 dark:text-gray-400">Dates</span>
          <span class="font-medium text-sm text-gray-900 dark:text-white">
            <%= new Date(booking.checkIn).toLocaleDateString('en-IN', {day:'numeric', month:'short'}) %> - <%= new Date(booking.checkOut).toLocaleDateString('en-IN', {day:'numeric', month:'short'}) %>
          </span>
        </div>
      </div>

      <div class="space-y-3">
        <a href="/bookings/my" class="block w-full bg-[#fe424d] hover:bg-[#e63946] text-white font-semibold py-3 px-4 rounded-xl transition-all shadow-md">
          View My Bookings
        </a>
        <a href="/listings" class="block w-full bg-white dark:bg-gray-800 border-2 border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:border-gray-300 dark:hover:border-gray-500 font-semibold py-3 px-4 rounded-xl transition-all">
          Explore More Places
        </a>
      </div>
    </div>
  </div>

  <%- include("../includes/footer.ejs") %>
  
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
  <script>
    // Trigger confetti on load
    window.onload = function() {
      var duration = 3 * 1000;
      var end = Date.now() + duration;

      (function frame() {
        confetti({
          particleCount: 5,
          angle: 60,
          spread: 55,
          origin: { x: 0 },
          colors: ['#fe424d', '#22c55e', '#3b82f6']
        });
        confetti({
          particleCount: 5,
          angle: 120,
          spread: 55,
          origin: { x: 1 },
          colors: ['#fe424d', '#22c55e', '#3b82f6']
        });

        if (Date.now() < end) {
          requestAnimationFrame(frame);
        }
      }());
    };
  </script>
</body>
</html>
