<% layout('layouts/infoBoilerplate') -%>

    <style>
        :root {
            --brand-red: #fe424d;
            --brand-dark: #111827;
        }

        body {
            background-color: #f8fafc;
        }

        .clip-reveal {
            clip-path: polygon(0 100%, 100% 100%, 100% 100%, 0% 100%);
            animation: revealUp 1.2s cubic-bezier(0.77, 0, 0.175, 1) forwards;
        }

        @keyframes revealUp {
            0% {
                clip-path: polygon(0 100%, 100% 100%, 100% 100%, 0% 100%);
                transform: translateY(50px);
            }

            100% {
                clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
                transform: translateY(0);
            }
        }

        .blob-shape {
            position: absolute;
            filter: blur(80px);
            z-index: 0;
            opacity: 0.6;
            animation: floatShape 15s ease-in-out infinite alternate;
        }

        @keyframes floatShape {
            0% {
                transform: translate(0, 0) scale(1);
            }

            50% {
                transform: translate(30px, -50px) scale(1.1);
            }

            100% {
                transform: translate(-20px, 30px) scale(0.9);
            }
        }

        .glass-card-3d {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
            transition: all 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
            transform-style: preserve-3d;
            perspective: 1000px;
        }

        .glass-card-3d:hover {
            transform: translateY(-10px) rotateX(5deg) rotateY(-5deg);
            box-shadow: 0 35px 60px -15px rgba(254, 66, 77, 0.15);
            border-color: rgba(254, 66, 77, 0.3);
        }

        .glass-card-3d .icon-wrapper {
            transition: transform 0.5s ease;
        }

        .glass-card-3d:hover .icon-wrapper {
            transform: translateZ(30px) scale(1.1);
            color: var(--brand-red);
        }

        .parallax-mask {
            clip-path: inset(0 0 0 0 round 2rem);
            transition: clip-path 0.5s ease;
        }

        .parallax-mask:hover {
            clip-path: inset(2% 2% 2% 2% round 1rem);
        }

        .text-gradient-animate {
            background: linear-gradient(to right, var(--brand-dark), var(--brand-red), var(--brand-dark));
            background-size: 200% auto;
            color: transparent;
            -webkit-background-clip: text;
            background-clip: text;
            animation: shineText 4s linear infinite;
        }

        @keyframes shineText {
            to {
                background-position: 200% center;
            }
        }

        .team-card {
            position: relative;
            overflow: hidden;
            border-radius: 2rem;
            background: #fff;
        }

        .team-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.8) 100%);
            z-index: 1;
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .team-card:hover::before {
            opacity: 1;
        }

        .team-info {
            position: absolute;
            bottom: -50px;
            left: 0;
            right: 0;
            padding: 2rem;
            z-index: 2;
            color: white;
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .team-card:hover .team-info {
            transform: translateY(-50px);
        }

        .team-img {
            transition: transform 0.7s ease;
        }

        .team-card:hover .team-img {
            transform: scale(1.1);
        }
    </style>

