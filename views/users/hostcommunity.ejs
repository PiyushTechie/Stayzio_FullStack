<% layout('layouts/infoBoilerplate') -%>

    <div class="bg-gradient-to-r from-gray-900 to-gray-800 pt-20 pb-16 relative overflow-hidden">
        <div
            class="absolute top-0 left-0 w-full h-full opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]">
        </div>
        <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10 text-center" data-aos="fade-up">
            <h1 class="text-4xl md:text-5xl font-black text-white mb-4 tracking-tight">
                <i class="fas fa-users text-[#fe424d] mr-3"></i> Host Community
            </h1>
            <p class="text-xl text-gray-300 max-w-2xl mx-auto">Connect, learn, and grow with thousands of other Stayzio
                hosts globally.</p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
        <div class="flex flex-col lg:flex-row gap-12">

            <div class="lg:w-1/4 hidden lg:block">
                <div
                    class="sticky top-28 bg-white border border-gray-100 rounded-3xl p-6 shadow-[0_8px_30px_rgb(0,0,0,0.04)]">
                    <h3 class="font-bold text-gray-900 mb-4 uppercase tracking-wider text-sm flex items-center gap-2">
                        <i class="fas fa-list text-[#fe424d]"></i> Contents
                    </h3>
                    <nav class="sticky-nav flex flex-col space-y-1">
                        <a href="#forums"
                            class="px-4 py-2 text-sm text-gray-500 rounded-lg border-l-2 border-transparent hover:bg-gray-50 transition-colors">Community
                            Forums</a>
                        <a href="#meetups"
                            class="px-4 py-2 text-sm text-gray-500 rounded-lg border-l-2 border-transparent hover:bg-gray-50 transition-colors">Local
                            Meetups</a>
                        <a href="#superhosts"
                            class="px-4 py-2 text-sm text-gray-500 rounded-lg border-l-2 border-transparent hover:bg-gray-50 transition-colors">Superhost
                            Program</a>
                        <a href="#feedback"
                            class="px-4 py-2 text-sm text-gray-500 rounded-lg border-l-2 border-transparent hover:bg-gray-50 transition-colors">Give
                            Feedback</a>
                    </nav>
                </div>
            </div>

            <div
                class="lg:w-3/4 prose-content bg-white p-8 md:p-12 rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100">

                <div id="forums">
                    <h2><i class="fas fa-comments"></i> Community Forums</h2>
                    <p>The Host Community Forum is your go-to place to ask questions, share stories, and get advice from
                        experienced hosts. Whether you're wondering how to handle a difficult guest or looking for
                        cleaning product recommendations, the community is here to help.</p>
                    <div class="highlight-box">
                        <h4><i class="fas fa-lightbulb"></i> Pro Tip</h4>
                        <p>Search the forums before posting a new question—chances are another host has already
                            encountered and solved the exact same issue!</p>
                    </div>
                </div>

                <div id="meetups">
                    <h2><i class="fas fa-map-marker-alt"></i> Local Meetups</h2>
                    <p>Hosting can sometimes feel like a solo job. Local Host Meetups allow you to connect with other
                        Stayzio hosts in your city or region. Share local regulatory updates, exchange contact info for
                        reliable cleaners, or just enjoy a coffee together.</p>
                    <p>Check the Events tab in your Host Dashboard to find upcoming meetups near you.</p>
                </div>

                <div id="superhosts">
                    <h2><i class="fas fa-medal"></i> Superhost Program</h2>
                    <p>Our Superhost program recognizes hosts who consistently provide outstanding hospitality.
                        Superhosts enjoy exclusive benefits, including:</p>
                    <ul>
                        <li>A special badge on your profile and listings.</li>
                        <li>Priority placement in search results.</li>
                        <li>Access to exclusive community events and beta features.</li>
                    </ul>
                </div>

                <div id="feedback">
                    <h2><i class="fas fa-bullhorn"></i> Give Feedback</h2>
                    <p>We are constantly building new tools to make hosting easier. Your feedback drives our roadmap.
                        Participate in surveys, join beta programs, and submit feature requests directly through the
                        Community portal.</p>
                </div>

            </div>
        </div>
    </div>