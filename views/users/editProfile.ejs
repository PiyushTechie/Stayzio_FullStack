<% layout('layouts/boilerplate') -%>

  <div class="min-h-screen bg-gray-50 flex flex-col justify-start pt-28 pb-12 sm:px-6 lg:px-8 font-['Roboto_Slab']">
    <div class="sm:mx-auto sm:w-full sm:max-w-2xl">
      <h2 class="mt-6 text-center text-3xl sm:text-4xl font-black text-gray-900 tracking-tight">
        <i class="fas fa-user-edit text-red-500 mr-2"></i>Edit Profile
      </h2>
      <p class="mt-2 text-center text-sm text-gray-600 font-medium">
        Update your personal details and profile image.
      </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-2xl">
      <div
        class="bg-white py-8 px-4 shadow-xl shadow-red-500/10 sm:rounded-3xl sm:px-10 border border-gray-100 transition-all duration-300 hover:shadow-2xl hover:shadow-red-500/20">

        <form id="editProfileForm" action="/profile/edit" method="POST" enctype="multipart/form-data" class="space-y-6"
          novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div>
            <label class="block text-sm font-bold text-gray-900 mb-2">
              <i class="fas fa-camera text-red-500 mr-1"></i> Profile Photo
            </label>
            <div class="flex items-center gap-6">
              <div class="relative group cursor-pointer w-28 h-28 shrink-0">
                <img id="previewImg"
                  class="w-full h-full rounded-full object-cover border-4 border-white shadow-md transition-transform duration-300 group-hover:scale-105"
                  src="<%= currentUser.profile?.photo?.url || '/images/default-profile.png' %>" alt="Profile Photo"
                  onerror="this.src='/images/default-profile.png'">
                <label for="photoInput"
                  class="absolute inset-0 bg-black/50 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 cursor-pointer">
                  <i class="fas fa-camera text-white text-2xl"></i>
                </label>
              </div>

              <div class="flex flex-col gap-2">
                <label for="photoInput"
                  class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-red-50 text-red-600 border border-red-100 rounded-xl font-bold cursor-pointer transition-colors hover:bg-red-100 hover:text-red-700">
                  <i class="fas fa-upload"></i> Choose Photo
                </label>
                <input type="file" name="photo" id="photoInput" accept="image/*" class="hidden">
                <span id="fileName" class="text-xs font-bold text-gray-500">No file chosen</span>
              </div>
            </div>
          </div>

          <div>
            <label for="nameInput" class="block text-sm font-bold text-gray-900 mb-2">
              <i class="fas fa-user text-red-500 mr-1"></i> Full Name
            </label>
            <input type="text" name="name" id="nameInput" value="<%= currentUser.profile?.name || '' %>"
              placeholder="Enter your full name" required
              class="block w-full rounded-xl border-gray-300 bg-gray-50 px-4 py-3 text-gray-900 focus:border-red-500 focus:bg-white focus:ring-red-500 font-medium transition-colors border outline-none">
            <div id="nameError" class="hidden mt-2 text-sm text-red-600 font-bold flex items-center gap-1">
              <i class="fas fa-exclamation-circle"></i> Name must be between 2 and 100 characters.
            </div>
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-900 mb-2">
              <i class="fas fa-envelope text-red-500 mr-1"></i> Email Address
            </label>
            <div class="relative">
              <input type="email" name="email" value="<%= currentUser.email || '' %>" disabled readonly
                class="block w-full rounded-xl border-gray-200 bg-gray-100 px-4 py-3 text-gray-500 cursor-not-allowed font-medium border outline-none">
              <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
                <i class="fas fa-lock text-gray-400"></i>
              </div>
            </div>
            <p class="mt-1.5 text-xs font-bold text-gray-400 flex items-center gap-1">
              <i class="fas fa-info-circle"></i> Email cannot be changed for security reasons
            </p>
          </div>

          <div>
            <label for="addressInput" class="block text-sm font-bold text-gray-900 mb-2">
              <i class="fas fa-map-marker-alt text-red-500 mr-1"></i> Address
            </label>
            <input type="text" name="address" id="addressInput" value="<%= currentUser.profile?.address || '' %>"
              placeholder="Enter your street address"
              class="block w-full rounded-xl border-gray-300 bg-gray-50 px-4 py-3 text-gray-900 focus:border-red-500 focus:bg-white focus:ring-red-500 font-medium transition-colors border outline-none">
            <div id="addressError" class="hidden mt-2 text-sm text-red-600 font-bold flex items-center gap-1">
              <i class="fas fa-exclamation-circle"></i> Address must be between 5 and 200 characters.
            </div>
          </div>

          <div>
            <label for="countryInput" class="block text-sm font-bold text-gray-900 mb-2">
              <i class="fas fa-globe text-red-500 mr-1"></i> Country
            </label>
            <input type="text" name="country" id="countryInput" value="<%= currentUser.profile?.country || '' %>"
              placeholder="Enter your country" required
              class="block w-full rounded-xl border-gray-300 bg-gray-50 px-4 py-3 text-gray-900 focus:border-red-500 focus:bg-white focus:ring-red-500 font-medium transition-colors border outline-none">
            <div id="countryError" class="hidden mt-2 text-sm text-red-600 font-bold flex items-center gap-1">
              <i class="fas fa-exclamation-circle"></i> Country must contain only letters (2-100 characters).
            </div>
          </div>

          <div>
            <label for="phoneInput" class="block text-sm font-bold text-gray-900 mb-2">
              <i class="fas fa-phone text-red-500 mr-1"></i> Phone Number
            </label>
            <input type="tel" name="phone" id="phoneInput" value="<%= currentUser.profile?.phone || '' %>"
              placeholder="Enter your phone number"
              class="block w-full rounded-xl border-gray-300 bg-gray-50 px-4 py-3 text-gray-900 focus:border-red-500 focus:bg-white focus:ring-red-500 font-medium transition-colors border outline-none">
            <div id="phoneError" class="hidden mt-2 text-sm text-red-600 font-bold flex items-center gap-1">
              <i class="fas fa-exclamation-circle"></i> Phone must be 10-20 digits (can include +, -, spaces,
              parentheses).
            </div>
          </div>

          <div>
            <label for="bioInput" class="block text-sm font-bold text-gray-900 mb-2">
              <i class="fas fa-pen text-red-500 mr-1"></i> Bio
            </label>
            <textarea name="bio" id="bioInput" rows="4" placeholder="Tell us something about yourself..."
              class="block w-full rounded-xl border-gray-300 bg-gray-50 px-4 py-3 text-gray-900 focus:border-red-500 focus:bg-white focus:ring-red-500 font-medium transition-colors border outline-none resize-y"><%= currentUser.profile?.bio || '' %></textarea>
            <div id="bioError" class="hidden mt-2 text-sm text-red-600 font-bold flex items-center gap-1">
              <i class="fas fa-exclamation-circle"></i> Bio must not exceed 500 characters.
            </div>
          </div>

          <div class="pt-4 flex flex-col gap-3">
            <button type="submit"
              class="w-full bg-gradient-to-br from-red-500 to-red-600 text-white p-4 rounded-xl font-black text-lg shadow-lg shadow-red-500/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-red-500/40 flex justify-center items-center gap-2">
              <i class="fas fa-save"></i> Update Profile
            </button>

            <a href="/profile"
              class="no-underline w-full bg-white text-gray-700 p-4 rounded-xl font-bold text-base border border-gray-200 transition-colors duration-300 hover:bg-gray-50 flex justify-center items-center gap-2">
              <i class="fas fa-arrow-left"></i> Cancel & Go Back
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div id="imageModal"
    class="fixed inset-0 z-50 hidden bg-black/90 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 transition-opacity duration-300">
    <div class="relative max-w-4xl max-h-[90vh] scale-95 transition-transform duration-300" id="modalContent">
      <button id="modalClose"
        class="absolute -top-12 right-0 md:-right-12 text-white/70 hover:text-white hover:rotate-90 transition-all duration-300 text-3xl">
        <i class="fas fa-times"></i>
      </button>
      <img id="modalImage" src="" alt="Profile Photo"
        class="max-w-full max-h-[85vh] rounded-2xl shadow-2xl shadow-black/50 object-contain">
    </div>
  </div>

  <script>
    const photoInput = document.getElementById("photoInput");
    const previewImg = document.getElementById("previewImg");
    const fileName = document.getElementById("fileName");

    photoInput.addEventListener("change", (e) => {
      const file = e.target.files[0];
      if (file) {
        if (file.size > 5 * 1024 * 1024) {
          alert("File size must be less than 5MB");
          photoInput.value = "";
          return;
        }

        if (!file.type.startsWith("image/")) {
          alert("Please select a valid image file");
          photoInput.value = "";
          return;
        }

        previewImg.src = URL.createObjectURL(file);
        fileName.textContent = file.name;
        fileName.classList.remove("text-gray-500");
        fileName.classList.add("text-red-600");
      } else {
        fileName.textContent = "No file chosen";
        fileName.classList.add("text-gray-500");
        fileName.classList.remove("text-red-600");
      }
    });

    const imageModal = document.getElementById("imageModal");
    const modalImage = document.getElementById("modalImage");
    const modalClose = document.getElementById("modalClose");
    const modalContent = document.getElementById("modalContent");

    previewImg.addEventListener("click", () => {
      modalImage.src = previewImg.src;
      imageModal.classList.remove("hidden");
      setTimeout(() => {
        imageModal.classList.remove("opacity-0");
        modalContent.classList.remove("scale-95");
      }, 10);
      document.body.style.overflow = "hidden";
    });

    function closeImageModal() {
      imageModal.classList.add("opacity-0");
      modalContent.classList.add("scale-95");
      setTimeout(() => {
        imageModal.classList.add("hidden");
        document.body.style.overflow = "auto";
      }, 300);
    }

    modalClose.addEventListener("click", closeImageModal);

    imageModal.addEventListener("click", (e) => {
      if (e.target === imageModal) {
        closeImageModal();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !imageModal.classList.contains("hidden")) {
        closeImageModal();
      }
    });

    const form = document.getElementById('editProfileForm');

    const fields = {
      name: {
        input: document.getElementById('nameInput'),
        error: document.getElementById('nameError'),
        validate: (val) => val.trim().length >= 2 && val.trim().length <= 100
      },
      address: {
        input: document.getElementById('addressInput'),
        error: document.getElementById('addressError'),
        validate: (val) => !val.trim() || (val.trim().length >= 5 && val.trim().length <= 200)
      },
      country: {
        input: document.getElementById('countryInput'),
        error: document.getElementById('countryError'),
        validate: (val) => {
          const t = val.trim();
          return t.length >= 2 && t.length <= 100 && /^[A-Za-z\s]+$/.test(t);
        }
      },
      phone: {
        input: document.getElementById('phoneInput'),
        error: document.getElementById('phoneError'),
        validate: (val) => {
          const t = val.trim();
          return !t || (t.length >= 10 && t.length <= 20 && /^[\d\+\-\s\(\)]+$/.test(t));
        }
      },
      bio: {
        input: document.getElementById('bioInput'),
        error: document.getElementById('bioError'),
        validate: (val) => !val.trim() || val.trim().length <= 500
      }
    };

    function showError(fieldObj) {
      fieldObj.input.classList.add('border-red-500', 'bg-red-50', 'focus:ring-red-500');
      fieldObj.input.classList.remove('border-gray-300', 'bg-gray-50', 'focus:bg-white');
      fieldObj.error.classList.remove('hidden');
    }

    function hideError(fieldObj) {
      fieldObj.input.classList.remove('border-red-500', 'bg-red-50', 'focus:ring-red-500');
      fieldObj.input.classList.add('border-gray-300', 'bg-gray-50', 'focus:bg-white');
      fieldObj.error.classList.add('hidden');
    }

    Object.values(fields).forEach(field => {
      field.input.addEventListener('blur', () => {
        if (field.input.value.trim() !== '' && !field.validate(field.input.value)) {
          showError(field);
        }
      });

      field.input.addEventListener('input', () => {
        if (!field.error.classList.contains('hidden')) {
          if (field.input.value.trim() === '' || field.validate(field.input.value)) {
            hideError(field);
          }
        }
      });
    });

    form.addEventListener('submit', (e) => {
      let isFormValid = true;
      let firstInvalidInput = null;

      Object.values(fields).forEach(field => {
        const isRequired = field.input.hasAttribute('required');
        const val = field.input.value.trim();

        if ((isRequired && val === '') || (val !== '' && !field.validate(val))) {
          showError(field);
          isFormValid = false;
          if (!firstInvalidInput) {
            firstInvalidInput = field.input;
          }
        } else {
          hideError(field);
        }
      });

      if (!isFormValid) {
        e.preventDefault();
        firstInvalidInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
        firstInvalidInput.focus({ preventScroll: true });
      }
    });
  </script>