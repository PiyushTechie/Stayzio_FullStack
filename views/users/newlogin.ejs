<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="icon" type="image/png" href="/images/favicon-removebg-preview.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Stayzio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@300;400;500;600;700;800;900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="stylesheet" href="/css/output.css">

    <style>
        body {
            font-family: 'Roboto Slab', serif;
        }

        .form-container {
            position: relative;
            overflow: hidden;
            min-height: 500px;
        }

        .form-step {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            opacity: 0;
            transform: translateX(50px);
            pointer-events: none;
        }

        .form-step.active {
            opacity: 1;
            transform: translateX(0);
            pointer-events: auto;
            position: relative;
        }

        .form-step.exit-left {
            opacity: 0;
            transform: translateX(-50px);
            position: absolute;
        }

        .form-step.exit-right {
            opacity: 0;
            transform: translateX(50px);
            position: absolute;
        }

        .input-group input {
            transition: all 0.3s ease;
        }

        .input-group input:focus {
            box-shadow: 0 0 0 4px rgba(254, 66, 77, 0.15);
        }

        .loading-spinner {
            display: none;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .overflow-y-auto::-webkit-scrollbar {
            width: 8px;
        }

        .overflow-y-auto::-webkit-scrollbar-track {
            background: #f8fafc;
            border-radius: 4px;
        }

        .overflow-y-auto::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }

        .overflow-y-auto::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
</head>

<body class="bg-gray-50 antialiased overflow-x-hidden min-h-screen flex items-center justify-center">

    <a href="/"
        class="absolute top-6 left-6 z-50 text-gray-900 bg-white/80 backdrop-blur px-4 py-2 rounded-full font-bold shadow-md hover:bg-white transition-all flex items-center gap-2 hover:-translate-y-1">
        <i class="fa-solid fa-arrow-left"></i> Home
    </a>

    <div
        class="w-full h-screen lg:h-[90vh] lg:max-w-6xl lg:rounded-3xl overflow-hidden flex shadow-2xl relative bg-white flex-row-reverse">

        <div class="hidden lg:block lg:w-1/2 relative bg-black">
            <img src="https://images.unsplash.com/photo-1499793983690-e29da59ef1c2?q=80&w=2070&auto=format&fit=crop"
                alt="Stayzio Login" class="absolute inset-0 w-full h-full object-cover opacity-60">

            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/90 via-gray-900/40 to-transparent"></div>

            <div class="absolute bottom-12 left-12 right-12 text-white">
                <img src="/images/logonobg.png" alt="Stayzio" class="h-16 w-auto mb-6">
                <h2 class="text-4xl font-black mb-4 leading-tight">Welcome back.</h2>
                <p class="text-lg text-gray-300 font-medium">Log in to access your saved lists, upcoming trips, and host
                    dashboard.</p>
            </div>
        </div>

        <div
            class="w-full lg:w-1/2 h-full flex flex-col justify-start sm:justify-center items-center p-8 sm:p-12 lg:p-16 bg-white relative overflow-y-auto max-h-screen lg:max-h-[90vh]">
            <div class="w-full max-w-md form-container my-auto py-8 lg:py-12">

                <div id="step-login" class="form-step active">
                    <div class="text-center mb-8">
                        <img src="/images/logonobg.png" alt="Stayzio" class="h-12 w-auto mx-auto mb-4 lg:hidden">
                        <h1 class="text-3xl font-black text-gray-900 mb-2">Sign in</h1>
                        <p class="text-gray-500 font-medium">Please enter your credentials</p>
                    </div>

                    <form id="loginForm" action="/login" method="POST" class="space-y-5">
                        <input type="hidden" name="_csrf" id="csrfToken" value="<%= csrfToken %>">

                        <div class="input-group">
                            <label class="block text-sm font-bold text-gray-700 mb-1">Email Address</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fa-solid fa-envelope text-gray-400"></i>
                                </div>
                                <input type="email" name="username" id="loginEmail" required
                                    placeholder="john@example.com"
                                    class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#fe424d] focus:bg-white font-medium">
                            </div>
                        </div>

                        <div class="input-group">
                            <div class="flex items-center justify-between mb-1">
                                <label class="block text-sm font-bold text-gray-700">Password</label>
                                <button type="button" id="showForgotBtn"
                                    class="text-sm text-[#fe424d] font-bold hover:underline">Forgot password?</button>
                            </div>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fa-solid fa-lock text-gray-400"></i>
                                </div>
                                <input type="password" name="password" id="loginPassword" required
                                    placeholder="••••••••"
                                    class="w-full pl-11 pr-12 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#fe424d] focus:bg-white font-medium">
                                <button type="button"
                                    class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-gray-600 toggle-password">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </div>
                        </div>

                        <button type="submit"
                            class="w-full py-3.5 px-4 bg-[#fe424d] hover:bg-[#e63946] text-white font-black rounded-xl shadow-lg shadow-red-500/30 transition-all flex items-center justify-center gap-2">
                            <span>Sign In</span>
                        </button>
                    </form>

                    <p class="text-center text-sm text-gray-600 mt-8 font-medium">
                        Don't have an account?
                        <a href="/signup" class="text-[#fe424d] font-bold hover:underline">Sign up</a>
                    </p>
                </div>

                <div id="step-forgot" class="form-step">
                    <button type="button" id="backToLoginBtn"
                        class="text-gray-500 hover:text-gray-900 mb-6 transition-colors font-bold text-sm flex items-center gap-2">
                        <i class="fa-solid fa-arrow-left"></i> Back to login
                    </button>
                    <div class="text-left mb-8">
                        <div
                            class="w-16 h-16 bg-red-100 text-red-500 rounded-full flex items-center justify-center mb-4 text-2xl">
                            <i class="fa-solid fa-key"></i>
                        </div>
                        <h1 class="text-3xl font-black text-gray-900 mb-2">Reset Password</h1>
                        <p class="text-gray-500 font-medium">Enter your email and we'll send you an OTP to reset your
                            password.</p>
                    </div>

                    <form id="forgotForm" class="space-y-5">
                        <div class="input-group">
                            <label class="block text-sm font-bold text-gray-700 mb-1">Email Address</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fa-solid fa-envelope text-gray-400"></i>
                                </div>
                                <input type="email" name="email" id="forgotEmail" required
                                    placeholder="john@example.com"
                                    class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#fe424d] focus:bg-white font-medium">
                            </div>
                        </div>

                        <button type="submit" id="forgotSubmitBtn"
                            class="w-full py-3.5 px-4 bg-gray-900 hover:bg-black text-white font-black rounded-xl shadow-lg transition-all flex items-center justify-center gap-2">
                            <span>Send OTP</span>
                            <div class="loading-spinner" id="forgotSpinner"></div>
                        </button>
                    </form>
                </div>

                <div id="step-reset" class="form-step">
                    <div class="text-left mb-8">
                        <div
                            class="w-16 h-16 bg-green-100 text-green-500 rounded-full flex items-center justify-center mb-4 text-2xl">
                            <i class="fa-solid fa-shield-check"></i>
                        </div>
                        <h1 class="text-3xl font-black text-gray-900 mb-2">Create New Password</h1>
                        <p class="text-gray-500 font-medium">Enter the 6-digit code sent to <span
                                id="displayForgotEmail" class="text-gray-900 font-bold"></span></p>
                    </div>

                    <form id="resetForm" class="space-y-5">
                        <input type="hidden" name="email" id="resetEmailInput">

                        <div class="input-group">
                            <label class="block text-sm font-bold text-gray-700 mb-1">6-Digit Code</label>
                            <input type="text" name="otp" id="resetOtp" required maxlength="6" placeholder="123456"
                                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 tracking-[0.5em] text-center font-black focus:outline-none focus:border-[#fe424d] focus:bg-white transition-colors">
                        </div>

                        <div class="input-group">
                            <label class="block text-sm font-bold text-gray-700 mb-1">New Password</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fa-solid fa-lock text-gray-400"></i>
                                </div>
                                <input type="password" name="password" id="resetPassword" required
                                    placeholder="••••••••"
                                    class="w-full pl-11 pr-12 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#fe424d] focus:bg-white font-medium">
                                <button type="button"
                                    class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-gray-600 toggle-password">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </div>
                        </div>

                        <div class="input-group">
                            <label class="block text-sm font-bold text-gray-700 mb-1">Confirm Password</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fa-solid fa-lock text-gray-400"></i>
                                </div>
                                <input type="password" name="confirmPassword" id="resetConfirmPassword" required
                                    placeholder="••••••••"
                                    class="w-full pl-11 pr-12 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#fe424d] focus:bg-white font-medium">
                                <button type="button"
                                    class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-gray-600 toggle-password">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </div>
                        </div>

                        <button type="submit" id="resetSubmitBtn"
                            class="w-full py-3.5 px-4 bg-[#fe424d] hover:bg-[#e63946] text-white font-black rounded-xl shadow-lg shadow-red-500/30 transition-all flex items-center justify-center gap-2">
                            <span>Update Password</span>
                            <div class="loading-spinner" id="resetSpinner"></div>
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div>

    <script>
        const csrfToken = document.getElementById('csrfToken').value;
        const stepOtp = document.getElementById('step-otp');

        const stepLogin = document.getElementById('step-login');
        const stepForgot = document.getElementById('step-forgot');
        const stepReset = document.getElementById('step-reset');

        function transition(from, to) {
            from.classList.remove('active');
            from.classList.add('exit-left');
            setTimeout(() => {
                from.classList.remove('exit-left');
                to.classList.add('active');
            }, 100);
        }

        function transitionBack(from, to) {
            from.classList.remove('active');
            from.classList.add('exit-right');
            setTimeout(() => {
                from.classList.remove('exit-right');
                to.classList.add('active');
            }, 100);
        }

        document.getElementById('showForgotBtn').addEventListener('click', () => {
            document.getElementById('forgotEmail').value = document.getElementById('loginEmail').value;
            transition(stepLogin, stepForgot);
        });

        document.getElementById('backToLoginBtn').addEventListener('click', () => {
            transitionBack(stepForgot, stepLogin);
        });

        document.querySelectorAll('.toggle-password').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const input = e.currentTarget.previousElementSibling;
                const icon = e.currentTarget.querySelector('i');
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.replace('fa-eye', 'fa-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.replace('fa-eye-slash', 'fa-eye');
                }
            });
        });

        document.getElementById('loginForm').addEventListener('submit', function (e) {
            const email = document.getElementById('loginEmail').value;
            const pass = document.getElementById('loginPassword').value;

            if (!email.includes('@') || email.length < 5) {
                e.preventDefault();
                return showFlash('Please enter a valid email address.', 'error');
            }
            if (pass.length < 6) {
                e.preventDefault();
                return showFlash('Password must be at least 6 characters long.', 'error');
            }
        });

        document.getElementById('forgotForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('forgotSubmitBtn');
            const spinner = document.getElementById('forgotSpinner');
            btn.disabled = true;
            spinner.style.display = 'block';

            const email = document.getElementById('forgotEmail').value;
            const formData = new URLSearchParams();
            formData.append('email', email);
            formData.append('_csrf', csrfToken);

            try {
                const response = await fetch('/forgot-password', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'Accept': 'application/json'
                    },
                    body: formData
                });
                const data = await response.json();

                if (data.success) {
                    document.getElementById('displayForgotEmail').innerText = email;
                    document.getElementById('resetEmailInput').value = email;
                    transition(stepForgot, stepReset);
                    showFlash(data.message, 'success');
                } else {
                    showFlash(data.message, 'error');
                }
            } catch (err) {
                showFlash('Network error occurred.', 'error');
            } finally {
                btn.disabled = false;
                spinner.style.display = 'none';
            }
        });

        document.getElementById('resetForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const pass = document.getElementById('resetPassword').value;
            const conf = document.getElementById('resetConfirmPassword').value;

            if (pass !== conf) {
                return showFlash("Passwords do not match", 'error');
            }

            const btn = document.getElementById('resetSubmitBtn');
            const spinner = document.getElementById('resetSpinner');
            btn.disabled = true;
            spinner.style.display = 'block';

            const formData = new URLSearchParams(new FormData(e.target));
            formData.append('_csrf', csrfToken);

            try {
                const response = await fetch('/reset-password-otp', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'Accept': 'application/json'
                    },
                    body: formData
                });
                const data = await response.json();

                if (data.success) {
                    showFlash(data.message, 'success');
                    document.getElementById('loginEmail').value = document.getElementById('resetEmailInput').value;
                    document.getElementById('loginPassword').value = '';
                    setTimeout(() => {
                        transitionBack(stepReset, stepLogin);
                    }, 1000);
                } else {
                    showFlash(data.message, 'error');
                }
            } catch (err) {
                showFlash('Network error occurred.', 'error');
            } finally {
                btn.disabled = false;
                spinner.style.display = 'none';
            }
        });
    </script>
    <%- include('../includes/flash.ejs') %>
</body>

</html>