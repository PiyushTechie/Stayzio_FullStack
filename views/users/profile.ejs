<% layout('layouts/boilerplate') -%>

  <style>
    .glass-panel {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.5);
    }

    .glass-card {
      background: linear-gradient(135deg, rgba(255, 255, 255, 1) 0%, rgba(249, 250, 251, 0.9) 100%);
      box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.8);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .glass-card:hover {
      transform: translateY(-4px) scale(1.01);
      box-shadow: 0 20px 40px -10px rgba(254, 66, 77, 0.15);
      border-color: rgba(254, 66, 77, 0.2);
    }

    a {
      text-decoration: none !important;
    }

    .avatar-img {
      color: transparent;
    }
  </style>

  <div class="min-h-screen bg-gray-50 pb-20 font-['Roboto_Slab']">

    <div class="w-full px-4 sm:px-8 lg:px-12 pt-28">

      <div class="bg-white w-full rounded-3xl shadow-sm border border-gray-200 p-6 sm:p-10 mb-12">

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">

          <div class="col-span-1 lg:col-span-3 flex justify-center lg:justify-start">
            <div
              class="w-32 h-32 sm:w-40 sm:h-40 shrink-0 rounded-full border-4 border-gray-50 shadow-md bg-gray-100 flex items-center justify-center overflow-hidden relative">
              <% if (user.profile && user.profile.photo && user.profile.photo.url) { %>
                <img id="previewImg" src="<%= user.profile.photo.url %>" alt="Profile Avatar"
                  class="avatar-img w-full h-full object-cover absolute inset-0 z-10"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <i
                  class="fa-solid fa-user text-5xl text-gray-400 absolute inset-0 m-auto flex items-center justify-center z-0"></i>
                <% } else { %>
                  <i class="fa-solid fa-user text-5xl text-gray-400"></i>
                  <% } %>
            </div>
          </div>

          <div class="col-span-1 lg:col-span-5 flex flex-col items-center lg:items-start w-full">
            <h1 class="text-3xl sm:text-4xl font-black text-gray-900 tracking-tight mb-3">
              <%= user.username %>
            </h1>

            <% if (isOwner) { %>
              <div
                class="inline-flex items-center justify-center gap-2 bg-gray-50 px-4 py-2 rounded-full text-gray-600 font-medium mb-6 border border-gray-200">
                <i class="fa-solid fa-envelope text-[#fe424d]"></i>
                <%= user.email %>
              </div>

              <div class="flex flex-row flex-wrap items-center justify-center lg:justify-start gap-3 w-full">
                <% if (user.role==="admin" || user.role==="host" ) { %>
                  <a href="/listings/new"
                    class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-gray-900 text-white rounded-lg font-bold text-sm shadow hover:bg-black transition-colors">
                    <i class="fa-solid fa-plus"></i> Add Listing
                  </a>
                  <a href="/host"
                    class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-[#fe424d] text-white rounded-lg font-bold text-sm shadow hover:bg-[#e63946] transition-colors">
                    <i class="fa-solid fa-chart-pie"></i> Dashboard
                  </a>
                  <form id="revertForm" action="/host/revert" method="POST" class="inline m-0">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="button" onclick="document.getElementById('revertModal').style.display = 'flex'"
                      class="revert-btn inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-white border border-gray-200 text-gray-700 rounded-lg font-bold text-sm shadow-sm hover:bg-gray-50 transition-colors">
                      <i class="fa-solid fa-arrow-rotate-left"></i> Revert
                    </button>
                  </form>
                  <% } else { %>
                    <a href="/host/setup"
                      class="inline-flex items-center justify-center gap-2 px-6 py-2.5 bg-[#fe424d] text-white rounded-xl font-bold shadow hover:bg-[#e63946] transition-colors">
                      <i class="fa-solid fa-house-chimney-user"></i> Become a Host
                    </a>
                    <% } %>

                      <a href="/bookings/my"
                        class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-white border border-gray-200 text-gray-700 rounded-lg font-bold text-sm shadow-sm hover:bg-gray-50 transition-colors">
                        <i class="fa-solid fa-suitcase-rolling"></i> My Trips
                      </a>

                      <a href="/profile/edit"
                        class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-white border border-gray-200 text-gray-700 rounded-lg font-bold text-sm shadow-sm hover:bg-gray-50 transition-colors">
                        <i class="fa-solid fa-user-pen"></i> Edit
                      </a>
              </div>
              <% } %>
          </div>

          <div
            class="col-span-1 lg:col-span-4 flex flex-col items-center lg:items-end w-full lg:border-l border-gray-100 lg:pl-8 pt-6 lg:pt-0 border-t lg:border-t-0">

            <div class="flex items-center justify-center lg:justify-end gap-4 sm:gap-6 w-full mb-6">
              <div
                class="bg-gray-50 rounded-2xl p-5 border border-gray-100 flex-1 max-w-[140px] flex flex-col items-center justify-center text-center">
                <div class="text-[#fe424d] text-3xl font-black mb-1">
                  <%= user.listings ? user.listings.length : 0 %>
                </div>
                <div class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Listings</div>
              </div>
              <div
                class="bg-gray-50 rounded-2xl p-5 border border-gray-100 flex-1 max-w-[140px] flex flex-col items-center justify-center text-center">
                <div class="text-gray-900 text-3xl font-black mb-1">
                  <%= user.reviews ? user.reviews.length : 0 %>
                </div>
                <div class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Reviews</div>
              </div>
            </div>

            <% if (isOwner) { %>
              <div class="flex flex-row flex-wrap items-center justify-center lg:justify-end gap-5 w-full">
                <form action="/logout" method="POST" class="inline m-0">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit"
                    class="inline-flex items-center justify-center gap-1.5 text-sm text-gray-500 font-bold hover:text-gray-900 transition-colors">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i> Log Out
                  </button>
                </form>
                <button type="button" id="deleteAccountBtn"
                  class="inline-flex items-center justify-center gap-1.5 text-sm text-red-500 font-bold hover:text-red-700 transition-colors">
                  <i class="fa-solid fa-user-xmark"></i> Delete Account
                </button>
              </div>
              <% } %>

          </div>

        </div>
      </div>

      <div class="space-y-12 w-full">
        <section>
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-xl bg-red-50 flex items-center justify-center text-[#fe424d] text-xl">
              <i class="fa-solid fa-house-chimney"></i>
            </div>
            <h2 class="text-3xl font-black text-gray-900">
              <%= isOwner ? "My Listings" : (user.username + "'s Listings" ) %>
            </h2>
          </div>

          <% if (user.listings && user.listings.length> 0) { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 lg:gap-8">
              <% user.listings.forEach((listing)=> { %>
                <a href="/listings/<%= listing._id %>" class="block group">
                  <div class="glass-card rounded-2xl p-6 h-full flex flex-col relative overflow-hidden">
                    <div
                      class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-[#fe424d] to-[#ff7b82] transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500">
                    </div>

                    <div class="flex justify-between items-start mb-4">
                      <h3
                        class="text-xl font-black text-gray-900 group-hover:text-[#fe424d] transition-colors line-clamp-2 pr-4">
                        <%= listing.title %>
                      </h3>
                      <span
                        class="shrink-0 px-3 py-1 bg-green-100 text-green-700 text-xs font-bold rounded-full">Active</span>
                    </div>

                    <div class="flex items-center gap-2 text-gray-500 font-medium mb-6">
                      <i class="fa-solid fa-location-dot text-gray-400"></i>
                      <span class="line-clamp-1">
                        <%= listing.location %>
                      </span>
                    </div>

                    <div
                      class="mt-auto pt-4 border-t border-gray-100 flex justify-between items-center text-sm font-bold">
                      <span class="text-gray-400"><i class="fa-regular fa-clock mr-1"></i> Listed recently</span>
                      <span
                        class="text-[#fe424d] group-hover:translate-x-1 transition-transform flex items-center gap-1">
                        View <i class="fa-solid fa-chevron-right text-[10px]"></i>
                      </span>
                    </div>
                  </div>
                </a>
                <% }) %>
            </div>
            <% } else { %>
              <div class="glass-panel rounded-3xl p-12 text-center border-dashed border-2 border-gray-200">
                <div
                  class="w-20 h-20 mx-auto bg-gray-50 rounded-full flex items-center justify-center text-gray-300 text-3xl mb-4">
                  <i class="fa-solid fa-house-chimney-crack"></i>
                </div>
                <h3 class="text-xl font-black text-gray-900 mb-2">No listings yet</h3>
                <p class="text-gray-500 font-medium mb-6 max-w-md mx-auto">
                  <%= isOwner
                    ? "Ready to share your space? Start hosting today and welcome guests from around the world!"
                    : "This user hasn't posted any listings yet." %>
                </p>
                <% if (isOwner) { %>
                  <a href="/listings/new"
                    class="inline-flex items-center gap-2 px-6 py-3 bg-[#fe424d] text-white rounded-xl font-bold shadow-lg shadow-red-500/30 hover:bg-[#e63946] transition-all hover:-translate-y-0.5">
                    <i class="fa-solid fa-plus"></i> Create First Listing
                  </a>
                  <% } %>
              </div>
              <% } %>
        </section>

        <section>
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-xl bg-yellow-50 flex items-center justify-center text-yellow-500 text-xl">
              <i class="fa-solid fa-star"></i>
            </div>
            <h2 class="text-3xl font-black text-gray-900">
              <%= isOwner ? "My Reviews" : (user.username + "'s Reviews" ) %>
            </h2>
          </div>

          <% if (user.reviews && user.reviews.length> 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
              <% user.reviews.forEach((review)=> { %>
                <div class="glass-card rounded-2xl p-6 group relative">
                  <div
                    class="absolute top-6 right-6 text-gray-100 group-hover:text-red-50 transition-colors pointer-events-none">
                    <i class="fa-solid fa-quote-right text-6xl"></i>
                  </div>

                  <div class="relative z-10">
                    <div class="flex gap-1 mb-4">
                      <% for (let i=1; i <=5; i++) { %>
                        <i
                          class="fa-solid fa-star text-sm <%= i <= (review.rating || 0) ? 'text-yellow-400' : 'text-gray-200' %>"></i>
                        <% } %>
                    </div>

                    <p class="text-gray-700 font-medium leading-relaxed mb-6 italic">
                      "<%= review.comment ? review.comment : "No comment provided." %>"
                    </p>

                    <div
                      class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pt-4 border-t border-gray-100">
                      <div class="flex items-center gap-2 text-sm font-bold text-gray-400">
                        <i class="fa-solid fa-calendar-days"></i>
                        Recently reviewed
                      </div>

                      <% if (review.listing) { %>
                        <a href="/listings/<%= review.listing._id ? review.listing._id : review.listing %>"
                          class="inline-flex items-center gap-2 text-sm font-bold text-[#fe424d] hover:text-[#e63946] group-hover:translate-x-1 transition-all">
                          View Property <i class="fa-solid fa-arrow-right-long"></i>
                        </a>
                        <% } else { %>
                          <span
                            class="inline-flex items-center gap-2 text-sm font-bold text-gray-400 cursor-not-allowed">
                            <i class="fa-solid fa-ban"></i> Property Deleted
                          </span>
                          <% } %>
                    </div>
                  </div>
                </div>
                <% }) %>
            </div>
            <% } else { %>
              <div class="glass-panel rounded-3xl p-12 text-center border-dashed border-2 border-gray-200">
                <div
                  class="w-20 h-20 mx-auto bg-gray-50 rounded-full flex items-center justify-center text-gray-300 text-3xl mb-4">
                  <i class="fa-regular fa-comment-dots"></i>
                </div>
                <h3 class="text-xl font-black text-gray-900 mb-2">No reviews yet</h3>
                <p class="text-gray-500 font-medium mb-0">
                  <%= isOwner ? "Your shared experiences will appear here." : "This user hasn't written any reviews." %>
                </p>
              </div>
              <% } %>
        </section>

      </div>
    </div>
  </div>

  <div id="revertModal" class="fixed inset-0 items-center justify-center p-4"
    style="display: none; z-index: 9999; background-color: rgba(0, 0, 0, 0.6); backdrop-filter: blur(4px);">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden transform transition-all duration-300">
      <div class="p-8">
        <div
          class="w-16 h-16 mx-auto bg-red-100 rounded-full flex items-center justify-center text-[#fe424d] text-2xl mb-6 shadow-sm">
          <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <h2 class="text-2xl font-black text-gray-900 text-center mb-4">Are you absolutely sure?</h2>
        <p class="text-gray-500 font-medium text-center mb-8">
          Reverting to a guest account will permanently delete all your active listings and remove your hosting
          privileges. This action cannot be undone.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <button type="button" onclick="document.getElementById('revertModal').style.display = 'none'"
            class="w-full flex-1 px-5 py-3 rounded-xl bg-gray-100 text-gray-700 font-bold hover:bg-gray-200 transition-colors">
            Cancel
          </button>
          <button type="button" onclick="document.getElementById('revertForm').submit()"
            class="w-full flex-1 px-5 py-3 rounded-xl bg-[#fe424d] text-white font-bold hover:bg-[#e63946] transition-colors shadow-md shadow-red-500/20">
            Yes, Revert
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const csrfToken = "<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>";

    const deleteBtn = document.getElementById("deleteAccountBtn");
    if (deleteBtn) {
      deleteBtn.addEventListener("click", () => {
        if (confirm("Are you sure? This will permanently delete your account, listings, and reviews!")) {
          fetch('/delete', {
            method: 'POST',
            headers: { 'CSRF-Token': csrfToken }
          })
            .then(res => {
              if (res.ok) {
                if (window.showFlash) window.showFlash('Your account has been permanently deleted.', 'success');
                setTimeout(() => { window.location.href = '/'; }, 1000);
              } else {
                res.text().then(msg => {
                  if (window.showFlash) window.showFlash(msg || 'Something went wrong.', 'error');
                });
              }
            })
            .catch(err => {
              if (window.showFlash) window.showFlash('Something went wrong.', 'error');
            });
        }
      });
    }
  </script>