<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="icon" type="image/png" href="/images/favicon-removebg-preview.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Stayzio</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@300;400;500;600;700;800;900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="stylesheet" href="/css/output.css">

    <style>
        body {
            font-family: 'Roboto Slab', serif;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
        }

        .form-container {
            position: relative;
            overflow: hidden;
            min-height: 500px;
        }

        .form-step {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            opacity: 0;
            transform: translateX(50px);
            pointer-events: none;
        }

        .form-step.active {
            opacity: 1;
            transform: translateX(0);
            pointer-events: auto;
            position: relative;
        }

        .form-step.exit {
            opacity: 0;
            transform: translateX(-50px);
            position: absolute;
        }

        .input-group input {
            transition: all 0.3s ease;
        }

        .input-group input:focus {
            box-shadow: 0 0 0 4px rgba(254, 66, 77, 0.15);
        }

        .loading-spinner {
            display: none;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .overflow-y-auto::-webkit-scrollbar {
            width: 8px;
        }

        .overflow-y-auto::-webkit-scrollbar-track {
            background: #f8fafc;
            border-radius: 4px;
        }

        .overflow-y-auto::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }

        .overflow-y-auto::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
</head>

<body class="bg-gray-50 antialiased overflow-x-hidden min-h-screen flex items-center justify-center">

    <a href="/"
        class="absolute top-6 left-6 z-50 text-gray-900 bg-white/80 backdrop-blur px-4 py-2 rounded-full font-bold shadow-md hover:bg-white transition-all flex items-center gap-2 hover:-translate-y-1">
        <i class="fa-solid fa-arrow-left"></i> Home
    </a>

    <div
        class="w-full h-screen lg:h-[90vh] lg:max-w-6xl lg:rounded-3xl overflow-hidden flex shadow-2xl relative bg-white">

        <div class="hidden lg:block lg:w-1/2 relative bg-black">
            <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?q=80&w=2070&auto=format&fit=crop"
                alt="Stayzio Signup" class="absolute inset-0 w-full h-full object-cover opacity-60">

            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/90 via-gray-900/40 to-transparent"></div>

            <div class="absolute bottom-12 left-12 right-12 text-white">
                <img src="/images/logonobg.png" alt="Stayzio" class="h-16 w-auto mb-6">
                <h2 class="text-4xl font-black mb-4 leading-tight">Join the community of travelers.</h2>
                <p class="text-lg text-gray-300 font-medium">Create an account to unlock exclusive stays, personalized
                    experiences, and become a host.</p>
            </div>
        </div>

        <div
            class="w-full lg:w-1/2 h-full flex flex-col justify-start sm:justify-center items-center p-8 sm:p-12 lg:p-16 bg-white relative overflow-y-auto">
            <div class="w-full max-w-md form-container my-auto py-8 lg:py-12">

                <div id="step-signup" class="form-step active">
                    <div class="text-center mb-8">
                        <img src="/images/logonobg.png" alt="Stayzio" class="h-12 w-auto mx-auto mb-4 lg:hidden">
                        <h1 class="text-3xl font-black text-gray-900 mb-2">Create Account</h1>
                        <p class="text-gray-500 font-medium">Enter your details to get started</p>
                    </div>

                    <form id="signupForm" class="space-y-5">
                        <input type="hidden" name="_csrf" id="csrfToken" value="<%= csrfToken %>">

                        <div class="input-group">
                            <label class="block text-sm font-bold text-gray-700 mb-1">Username</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fa-solid fa-user text-gray-400"></i>
                                </div>
                                <input type="text" name="username" id="username" required placeholder="johndoe"
                                    class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#fe424d] focus:bg-white font-medium">
                            </div>
                        </div>

                        <div class="input-group">
                            <label class="block text-sm font-bold text-gray-700 mb-1">Email Address</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fa-solid fa-envelope text-gray-400"></i>
                                </div>
                                <input type="email" name="email" id="email" required placeholder="john@example.com"
                                    class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#fe424d] focus:bg-white font-medium">
                            </div>
                        </div>

                        <div class="input-group">
                            <label class="block text-sm font-bold text-gray-700 mb-1">Password</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fa-solid fa-lock text-gray-400"></i>
                                </div>
                                <input type="password" name="password" id="password" required placeholder="••••••••"
                                    class="w-full pl-11 pr-12 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#fe424d] focus:bg-white font-medium">
                                <button type="button"
                                    class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-gray-600 toggle-password">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </div>
                            <div class="mt-2">
                                <div class="flex justify-between items-center mb-1">
                                    <span class="text-xs font-bold text-gray-500" id="strengthText">Password
                                        Strength</span>
                                </div>
                                <div class="flex gap-1 h-1.5 w-full bg-gray-100 rounded-full overflow-hidden">
                                    <div class="h-full transition-all duration-300 w-0" id="strengthBar1"></div>
                                    <div class="h-full transition-all duration-300 w-0" id="strengthBar2"></div>
                                    <div class="h-full transition-all duration-300 w-0" id="strengthBar3"></div>
                                    <div class="h-full transition-all duration-300 w-0" id="strengthBar4"></div>
                                </div>
                                <ul class="text-[11px] text-gray-500 mt-2 space-y-1 font-medium hidden"
                                    id="strengthReqs">
                                    <li id="reqLength"><i class="fa-solid fa-circle-xmark text-red-400 mr-1"></i> At
                                        least 8 characters</li>
                                    <li id="reqUpper"><i class="fa-solid fa-circle-xmark text-red-400 mr-1"></i> At
                                        least 1 uppercase letter</li>
                                    <li id="reqNumber"><i class="fa-solid fa-circle-xmark text-red-400 mr-1"></i> At
                                        least 1 number</li>
                                    <li id="reqSpecial"><i class="fa-solid fa-circle-xmark text-red-400 mr-1"></i> At
                                        least 1 special character</li>
                                </ul>
                            </div>
                        </div>

                        <div class="input-group">
                            <label class="block text-sm font-bold text-gray-700 mb-1">Confirm Password</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fa-solid fa-lock text-gray-400"></i>
                                </div>
                                <input type="password" name="confirmPassword" id="confirmPassword" required
                                    placeholder="••••••••"
                                    class="w-full pl-11 pr-12 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#fe424d] focus:bg-white font-medium">
                                <button type="button"
                                    class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-gray-600 toggle-password">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </div>
                        </div>

                        <div class="flex items-start gap-2 mt-4">
                            <input type="checkbox" id="termsCheckbox" required
                                class="mt-1 w-4 h-4 text-[#fe424d] border-gray-300 rounded focus:ring-[#fe424d]">
                            <label for="termsCheckbox" class="text-sm font-medium text-gray-600">
                                I confirm that I am 18+ and I agree to Stayzio's
                                <a href="/terms" class="text-[#fe424d] hover:underline">Terms of Service</a>,
                                <a href="/privacy" class="text-[#fe424d] hover:underline">Privacy Policy</a>, and
                                <a href="/cookie" class="text-[#fe424d] hover:underline">Cookie Policy</a>.
                            </label>
                        </div>

                        <button type="submit" id="signupSubmitBtn"
                            class="w-full py-3.5 px-4 bg-[#fe424d] hover:bg-[#e63946] text-white font-black rounded-xl shadow-lg shadow-red-500/30 transition-all flex items-center justify-center gap-2">
                            <span>Sign Up</span>
                            <div class="loading-spinner" id="signupSpinner"></div>
                        </button>
                    </form>

                    <p class="text-center text-sm text-gray-600 mt-8 font-medium">
                        Already have an account?
                        <a href="/login" class="text-[#fe424d] font-bold hover:underline">Log in</a>
                    </p>
                </div>

                <div id="step-otp" class="form-step">
                    <div class="text-center mb-8">
                        <div
                            class="w-16 h-16 bg-green-100 text-green-500 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
                            <i class="fa-solid fa-envelope-open-text"></i>
                        </div>
                        <h1 class="text-3xl font-black text-gray-900 mb-2">Verify Email</h1>
                        <p class="text-gray-500 font-medium">We sent a 6-digit code to <br><span id="displayEmail"
                                class="text-gray-900 font-bold">your email</span></p>
                    </div>

                    <form id="otpForm" class="space-y-6">
                        <input type="hidden" name="email" id="otpEmailInput">

                        <div class="flex justify-center gap-3" id="otpInputs">
                            <input type="text" maxlength="1"
                                class="w-12 h-14 text-center text-2xl font-black bg-gray-50 border border-gray-200 rounded-xl focus:border-[#fe424d] focus:bg-white focus:outline-none transition-colors"
                                required>
                            <input type="text" maxlength="1"
                                class="w-12 h-14 text-center text-2xl font-black bg-gray-50 border border-gray-200 rounded-xl focus:border-[#fe424d] focus:bg-white focus:outline-none transition-colors"
                                required>
                            <input type="text" maxlength="1"
                                class="w-12 h-14 text-center text-2xl font-black bg-gray-50 border border-gray-200 rounded-xl focus:border-[#fe424d] focus:bg-white focus:outline-none transition-colors"
                                required>
                            <input type="text" maxlength="1"
                                class="w-12 h-14 text-center text-2xl font-black bg-gray-50 border border-gray-200 rounded-xl focus:border-[#fe424d] focus:bg-white focus:outline-none transition-colors"
                                required>
                            <input type="text" maxlength="1"
                                class="w-12 h-14 text-center text-2xl font-black bg-gray-50 border border-gray-200 rounded-xl focus:border-[#fe424d] focus:bg-white focus:outline-none transition-colors"
                                required>
                            <input type="text" maxlength="1"
                                class="w-12 h-14 text-center text-2xl font-black bg-gray-50 border border-gray-200 rounded-xl focus:border-[#fe424d] focus:bg-white focus:outline-none transition-colors"
                                required>
                        </div>

                        <input type="hidden" name="otp" id="fullOtpInput">

                        <button type="submit" id="otpSubmitBtn"
                            class="w-full py-3.5 px-4 bg-gray-900 hover:bg-black text-white font-black rounded-xl shadow-lg transition-all flex items-center justify-center gap-2">
                            <span>Verify Code</span>
                            <div class="loading-spinner" id="otpSpinner"></div>
                        </button>
                    </form>

                    <div class="text-center mt-6">
                        <button id="resendOtpBtn"
                            class="text-sm text-gray-500 font-bold hover:text-[#fe424d] transition-colors">
                            Didn't receive it? Resend Code
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        const signupForm = document.getElementById('signupForm');
        const otpForm = document.getElementById('otpForm');
        const stepSignup = document.getElementById('step-signup');
        const stepOtp = document.getElementById('step-otp');
        const csrfToken = document.getElementById('csrfToken').value;

        document.querySelectorAll('.toggle-password').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const input = e.currentTarget.previousElementSibling;
                const icon = e.currentTarget.querySelector('i');
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.replace('fa-eye', 'fa-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.replace('fa-eye-slash', 'fa-eye');
                }
            });
        });

        const passwordInput = document.getElementById('password');
        const strengthBars = [
            document.getElementById('strengthBar1'),
            document.getElementById('strengthBar2'),
            document.getElementById('strengthBar3'),
            document.getElementById('strengthBar4')
        ];
        const strengthText = document.getElementById('strengthText');
        const strengthReqs = document.getElementById('strengthReqs');

        const reqs = {
            length: document.getElementById('reqLength'),
            upper: document.getElementById('reqUpper'),
            number: document.getElementById('reqNumber'),
            special: document.getElementById('reqSpecial')
        };

        let isPasswordStrong = false;

        passwordInput.addEventListener('input', (e) => {
            const val = e.target.value;
            strengthReqs.classList.remove('hidden');

            const hasLength = val.length >= 8;
            const hasUpper = /[A-Z]/.test(val);
            const hasNumber = /[0-9]/.test(val);
            const hasSpecial = /[^A-Za-z0-9]/.test(val);

            updateReqUI(reqs.length, hasLength);
            updateReqUI(reqs.upper, hasUpper);
            updateReqUI(reqs.number, hasNumber);
            updateReqUI(reqs.special, hasSpecial);

            let score = 0;
            if (hasLength) score++;
            if (hasUpper) score++;
            if (hasNumber) score++;
            if (hasSpecial) score++;

            isPasswordStrong = score >= 3 && hasLength;

            strengthBars.forEach(bar => { bar.style.width = '0'; bar.className = 'h-full transition-all duration-300 w-0'; });

            if (val.length === 0) {
                strengthText.innerText = "Password Strength";
                strengthText.className = "text-xs font-bold text-gray-500";
                strengthReqs.classList.add('hidden');
            } else if (score === 1) {
                strengthBars[0].style.width = '100%';
                strengthBars[0].classList.add('bg-red-500');
                strengthText.innerText = "Weak";
                strengthText.className = "text-xs font-bold text-red-500";
            } else if (score === 2) {
                strengthBars[0].style.width = '100%'; strengthBars[1].style.width = '100%';
                strengthBars[0].classList.add('bg-yellow-400'); strengthBars[1].classList.add('bg-yellow-400');
                strengthText.innerText = "Fair";
                strengthText.className = "text-xs font-bold text-yellow-500";
            } else if (score === 3) {
                strengthBars[0].style.width = '100%'; strengthBars[1].style.width = '100%'; strengthBars[2].style.width = '100%';
                strengthBars[0].classList.add('bg-blue-400'); strengthBars[1].classList.add('bg-blue-400'); strengthBars[2].classList.add('bg-blue-400');
                strengthText.innerText = "Good";
                strengthText.className = "text-xs font-bold text-blue-500";
            } else if (score === 4) {
                strengthBars.forEach(bar => { bar.style.width = '100%'; bar.classList.add('bg-green-500'); });
                strengthText.innerText = "Strong";
                strengthText.className = "text-xs font-bold text-green-500";
            }
        });

        function updateReqUI(el, isMet) {
            const icon = el.querySelector('i');
            if (isMet) {
                icon.classList.replace('fa-circle-xmark', 'fa-circle-check');
                icon.classList.replace('text-red-400', 'text-green-500');
                el.classList.add('text-green-600');
            } else {
                icon.classList.replace('fa-circle-check', 'fa-circle-xmark');
                icon.classList.replace('text-green-500', 'text-red-400');
                el.classList.remove('text-green-600');
            }
        }

        signupForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            const pass = document.getElementById('password').value;
            const confPass = document.getElementById('confirmPassword').value;
            if (pass !== confPass) {
                document.getElementById('confirmPassword').focus();
                return showFlash("Passwords do not match.", "error");
            }

            const terms = document.getElementById('termsCheckbox').checked;
            if (!terms) {
                return showFlash("You must be 18+ and agree to the terms to continue.", "error");
            }

            if (!isPasswordStrong) {
                passwordInput.focus();
                return showFlash("Please choose a stronger password before submitting.", "error");
            }

            const btn = document.getElementById('signupSubmitBtn');
            const spinner = document.getElementById('signupSpinner');
            btn.disabled = true;
            spinner.style.display = 'block';

            const formData = new URLSearchParams(new FormData(signupForm));

            try {
                const response = await fetch('/signup', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'Accept': 'application/json'
                    },
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    document.getElementById('displayEmail').innerText = document.getElementById('email').value;
                    document.getElementById('otpEmailInput').value = document.getElementById('email').value;

                    stepSignup.classList.remove('active');
                    stepSignup.classList.add('exit');

                    setTimeout(() => {
                        stepOtp.classList.add('active');
                        document.querySelector('#otpInputs input').focus();
                    }, 100);

                    showFlash(data.message, 'success');
                } else {
                    showFlash(data.message, 'error');
                }
            } catch (err) {
                showFlash('Network error occurred. Please try again.', 'error');
            } finally {
                btn.disabled = false;
                spinner.style.display = 'none';
            }
        });

        const otpInputs = document.querySelectorAll('#otpInputs input');
        otpInputs.forEach((input, index) => {
            input.addEventListener('keyup', (e) => {
                if (e.key >= 0 && e.key <= 9) {
                    if (index < otpInputs.length - 1) otpInputs[index + 1].focus();
                } else if (e.key === 'Backspace') {
                    if (index > 0) otpInputs[index - 1].focus();
                }
            });
            input.addEventListener('paste', (e) => {
                e.preventDefault();
                const pastedData = e.clipboardData.getData('text').slice(0, 6).replace(/[^0-9]/g, '');
                for (let i = 0; i < pastedData.length; i++) {
                    otpInputs[i].value = pastedData[i];
                    if (i < otpInputs.length - 1) otpInputs[i + 1].focus();
                }
            });
        });

        otpForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            let otpStr = '';
            otpInputs.forEach(i => otpStr += i.value);
            document.getElementById('fullOtpInput').value = otpStr;

            const btn = document.getElementById('otpSubmitBtn');
            const spinner = document.getElementById('otpSpinner');
            btn.disabled = true;
            spinner.style.display = 'block';

            const formData = new URLSearchParams(new FormData(otpForm));
            formData.append('_csrf', csrfToken);

            try {
                const response = await fetch('/verify-otp', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'Accept': 'application/json'
                    },
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    window.location.href = data.redirect || '/listings';
                } else {
                    showFlash(data.message, 'error');
                    otpInputs.forEach(i => i.value = '');
                    otpInputs[0].focus();
                }
            } catch (err) {
                showFlash('Network error occurred. Please try again.', 'error');
            } finally {
                btn.disabled = false;
                spinner.style.display = 'none';
            }
        });

        document.getElementById('resendOtpBtn').addEventListener('click', async (e) => {
            e.preventDefault();
            const email = document.getElementById('otpEmailInput').value;
            const btn = e.currentTarget;
            if (btn.disabled) return;

            btn.disabled = true;
            btn.innerText = 'Sending...';

            let startCooldown = false;

            try {
                const response = await fetch('/resend-otp', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'Accept': 'application/json'
                    },
                    body: `email=${encodeURIComponent(email)}&_csrf=${encodeURIComponent(csrfToken)}`
                });

                const data = await response.json();

                if (response.ok) {
                    window.showFlash(data.message || 'A new code was sent.', 'success');
                    startCooldown = true;
                } else {
                    window.showFlash(data.message || 'Failed to resend code.', 'error');
                    if (response.status === 429) {
                        startCooldown = true;
                    } else {
                        btn.disabled = false;
                        btn.innerText = "Didn't receive it? Resend Code";
                    }
                }
            } catch (err) {
                window.showFlash('Network error occurred.', 'error');
                btn.innerText = "Didn't receive it? Resend Code";
                btn.disabled = false;
            }

            if (startCooldown) {
                let timeLeft = 120; // 2 minutes
                btn.innerText = `Resend in ${timeLeft}s`;

                const timer = setInterval(() => {
                    timeLeft--;
                    if (timeLeft <= 0) {
                        clearInterval(timer);
                        btn.innerText = "Didn't receive it? Resend Code";
                        btn.disabled = false;
                    } else {
                        btn.innerText = `Resend in ${timeLeft}s`;
                    }
                }, 1000);
            }
        });
    </script>
    <%- include('../includes/flash.ejs') %>
</body>

</html>