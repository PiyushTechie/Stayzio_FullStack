<% layout('layouts/boilerplate') -%>

  <div class="min-h-screen bg-gray-50 pb-20" style="padding-top: 140px;">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="bg-white rounded-[2rem] shadow-xl border border-gray-100 overflow-hidden">

        <div class="bg-gradient-to-br from-gray-900 to-gray-800 p-10 text-center relative overflow-hidden">
          <div
            class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white to-transparent">
          </div>
          <div
            class="w-16 h-16 mx-auto bg-white/20 backdrop-blur-md rounded-2xl flex items-center justify-center text-white text-3xl mb-4 shadow-inner relative z-10">
            <i class="fa-solid fa-pen-to-square"></i>
          </div>
          <h2 class="text-3xl font-black text-white relative z-10 mb-2">Edit Listing</h2>
          <p class="text-gray-300 font-medium relative z-10">Update your property details to attract more guests.</p>
        </div>

        <div class="p-8 sm:p-12">
          <form id="listingForm" method="post" action="/listings/<%= listing._id %>?_method=PUT" novalidate
            enctype="multipart/form-data">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="space-y-8">

              <div>
                <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                    class="fa-solid fa-heading text-gray-500"></i> Property Title</label>
                <input type="text" name="listing[title]" value="<%= listing.title %>"
                  class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-gray-500 focus:ring-4 focus:ring-gray-500/20"
                  placeholder="e.g., Cozy Beachfront Villa" required>
                <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                    class="fa-solid fa-circle-exclamation mr-1"></i> Please enter a catchy title.</div>
              </div>

              <div>
                <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                    class="fa-solid fa-align-left text-gray-500"></i> Description</label>
                <textarea name="listing[description]"
                  class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-gray-500 focus:ring-4 focus:ring-gray-500/20"
                  rows="4" placeholder="Describe your property..." required><%= listing.description %></textarea>
                <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                    class="fa-solid fa-circle-exclamation mr-1"></i> A description is required.</div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                <div>
                  <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                      class="fa-solid fa-layer-group text-gray-500"></i> Category</label>
                  <select name="listing[category]"
                    class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-gray-500 focus:ring-4 focus:ring-gray-500/20 appearance-none bg-[url('data:image/svg+xml;utf8,<svg fill=\'#6b7280\' height=\'24\' viewBox=\'0 0 24 24\' width=\'24\' xmlns=\'http://www.w3.org/2000/svg\'><path d=\'M7 10l5 5 5-5z\'/></svg>')] bg-no-repeat bg-[position:right_10px_center]"
                    required>
                    <option value="rooms" <%=listing.category==="rooms" ? "selected" : "" %>>Rooms</option>
                    <option value="cities" <%=listing.category==="cities" ? "selected" : "" %>>Iconic Cities</option>
                    <option value="mountains" <%=listing.category==="mountains" ? "selected" : "" %>>Mountains</option>
                    <option value="castles" <%=listing.category==="castles" ? "selected" : "" %>>Castles</option>
                    <option value="pools" <%=listing.category==="pools" ? "selected" : "" %>>Amazing Pools</option>
                    <option value="camping" <%=listing.category==="camping" ? "selected" : "" %>>Camping</option>
                    <option value="farms" <%=listing.category==="farms" ? "selected" : "" %>>Farms</option>
                    <option value="beach" <%=listing.category==="beach" ? "selected" : "" %>>Beachfront</option>
                    <option value="luxury" <%=listing.category==="luxury" ? "selected" : "" %>>Luxury</option>
                    <option value="cabins" <%=listing.category==="cabins" ? "selected" : "" %>>Cabins</option>
                    <option value="boats" <%=listing.category==="boats" ? "selected" : "" %>>Boats</option>
                  </select>
                  <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                      class="fa-solid fa-circle-exclamation mr-1"></i> Please select a category.</div>
                </div>

                <div>
                  <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                      class="fa-solid fa-building text-gray-500"></i> Property Type</label>
                  <select name="listing[propertyType]"
                    class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-gray-500 focus:ring-4 focus:ring-gray-500/20 appearance-none bg-[url('data:image/svg+xml;utf8,<svg fill=\'#6b7280\' height=\'24\' viewBox=\'0 0 24 24\' width=\'24\' xmlns=\'http://www.w3.org/2000/svg\'><path d=\'M7 10l5 5 5-5z\'/></svg>')] bg-no-repeat bg-[position:right_10px_center]"
                    required>
                    <option value="Apartment" <%=listing.propertyType==="Apartment" ? "selected" : "" %>>Apartment
                    </option>
                    <option value="House" <%=listing.propertyType==="House" ? "selected" : "" %>>House</option>
                    <option value="Cabin" <%=listing.propertyType==="Cabin" ? "selected" : "" %>>Cabin</option>
                    <option value="Villa" <%=listing.propertyType==="Villa" ? "selected" : "" %>>Villa</option>
                    <option value="Hotel" <%=listing.propertyType==="Hotel" ? "selected" : "" %>>Hotel</option>
                    <option value="Guesthouse" <%=listing.propertyType==="Guesthouse" ? "selected" : "" %>>Guesthouse
                    </option>
                    <option value="Other" <%=listing.propertyType==="Other" ? "selected" : "" %>>Other</option>
                  </select>
                  <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                      class="fa-solid fa-circle-exclamation mr-1"></i> Please select a property type.</div>
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                <div>
                  <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                      class="fa-solid fa-indian-rupee-sign text-gray-500"></i> Price per Night</label>
                  <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-500 font-bold">₹</span>
                    <input type="number" name="listing[price]" value="<%= listing.price %>"
                      class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-gray-500 focus:ring-4 focus:ring-gray-500/20 pl-10"
                      placeholder="0" required min="1" oninput="if(this.value < 0) this.value = Math.abs(this.value)">
                  </div>
                  <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                      class="fa-solid fa-circle-exclamation mr-1"></i> Please enter a valid price.</div>
                </div>

                <div>
                  <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                      class="fa-solid fa-bed text-gray-500"></i> Number of Beds</label>
                  <input type="number" name="listing[beds]" value="<%= listing.beds || 1 %>"
                    class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-gray-500 focus:ring-4 focus:ring-gray-500/20"
                    placeholder="1" required min="1" oninput="if(this.value < 1 && this.value !== '') this.value = 1">
                  <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                      class="fa-solid fa-circle-exclamation mr-1"></i> Please enter number of beds.</div>
                </div>
              </div>

              <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
                  <div>
                    <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-3"><i
                        class="fa-regular fa-image text-gray-500"></i> Current Image</label>
                    <div class="rounded-xl overflow-hidden shadow-md border-4 border-white aspect-video relative group">
                      <img src="<%= listing.image.url %>" alt="<%= listing.title %>"
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                      <div
                        class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                        <span class="text-white font-bold text-sm bg-black/50 px-3 py-1 rounded-full"><i
                            class="fa-solid fa-eye"></i> Active</span>
                      </div>
                    </div>
                  </div>

                  <div>
                    <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-3"><i
                        class="fa-solid fa-camera-rotate text-gray-500"></i> Update Image (Optional)</label>
                    <div class="relative w-full h-full min-h-[150px] group">
                      <input type="file" name="listing[image]" id="file-input"
                        class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" accept="image/*">
                      <div id="file-drop-zone"
                        class="border-2 border-dashed border-gray-300 rounded-2xl cursor-pointer transition-all duration-300 group-hover:border-gray-500 group-hover:bg-gray-100 h-full flex flex-col items-center justify-center m-0 bg-white">
                        <div
                          class="w-12 h-12 bg-gray-100 text-gray-400 rounded-full flex items-center justify-center text-xl mb-2">
                          <i class="fa-solid fa-cloud-arrow-up"></i>
                        </div>
                        <h4 class="text-sm font-bold text-gray-700 mb-1" id="file-name-display">Select new image</h4>
                        <p class="text-xs font-medium text-gray-400">(Max 5MB)</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                <div>
                  <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                      class="fa-solid fa-location-dot text-gray-500"></i> Location</label>
                  <input type="text" name="listing[location]" value="<%= listing.location %>"
                    class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-gray-500 focus:ring-4 focus:ring-gray-500/20"
                    placeholder="City, State" required>
                  <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                      class="fa-solid fa-circle-exclamation mr-1"></i> Location is required.</div>
                </div>

                <div>
                  <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                      class="fa-solid fa-globe text-gray-500"></i> Country</label>
                  <input type="text" name="listing[country]" value="<%= listing.country %>"
                    class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-gray-500 focus:ring-4 focus:ring-gray-500/20"
                    placeholder="e.g., India" required>
                  <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                      class="fa-solid fa-circle-exclamation mr-1"></i> Country is required.</div>
                </div>
              </div>

              <div class="pt-6 border-t border-gray-100 flex gap-4">
                <a href="/listings/<%= listing._id %>"
                  class="w-1/3 py-4 rounded-xl font-bold text-center text-gray-600 bg-gray-100 hover:bg-gray-200 transition-colors no-underline">
                  Cancel
                </a>
                <button type="submit"
                  class="bg-gradient-to-br from-gray-800 to-gray-900 text-white w-full p-5 rounded-2xl font-black text-lg shadow-lg shadow-gray-900/20 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-gray-900/30 flex-1 flex justify-center items-center gap-3 !mt-0 !w-auto">
                  <i class="fa-solid fa-floppy-disk"></i> Save Changes
                </button>
              </div>

            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script>
    const fileInput = document.getElementById('file-input');
    const fileNameDisplay = document.getElementById('file-name-display');

    fileInput.addEventListener('change', function (e) {
      if (e.target.files.length > 0) {
        fileNameDisplay.textContent = e.target.files[0].name;
        fileNameDisplay.classList.add('text-gray-700');
      } else {
        fileNameDisplay.textContent = 'Select new image';
        fileNameDisplay.classList.remove('text-gray-700');
      }
    });

    const form = document.getElementById('listingForm');
    const inputs = form.querySelectorAll('input[required], textarea[required], select[required]');

    function showError(input) {
      input.classList.remove('border-gray-200');
      input.classList.add('border-red-500', 'bg-red-50');
      const errorDiv = input.closest('div').querySelector('.text-red-500.hidden');
      if (errorDiv) {
        errorDiv.classList.remove('hidden');
      }
      if (input.type === 'file') {
        const dropZone = document.getElementById('file-drop-zone');
        dropZone.classList.remove('border-gray-300');
        dropZone.classList.add('border-red-500', 'bg-red-50');
      }
    }

    function hideError(input) {
      input.classList.add('border-gray-200');
      input.classList.remove('border-red-500', 'bg-red-50');
      const errorDiv = input.closest('div').querySelector('.text-red-500:not(.hidden)');
      if (errorDiv) {
        errorDiv.classList.add('hidden');
      }
      if (input.type === 'file') {
        const dropZone = document.getElementById('file-drop-zone');
        dropZone.classList.add('border-gray-300');
        dropZone.classList.remove('border-red-500', 'bg-red-50');
      }
    }

    form.addEventListener('submit', function (event) {
      let isValid = true;
      inputs.forEach(input => {
        if (!input.checkValidity()) {
          isValid = false;
          showError(input);
        } else {
          hideError(input);
        }
      });

      if (!isValid) {
        event.preventDefault();
      }
    });

    inputs.forEach(input => {
      input.addEventListener('input', function () {
        if (this.checkValidity()) {
          hideError(this);
        }
      });
      input.addEventListener('change', function () {
        if (this.checkValidity()) {
          hideError(this);
        }
      });
    });
  </script>