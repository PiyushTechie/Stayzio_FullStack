<% layout("/layouts/infoBoilerplate") %>

    <style>
        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.5);
        }

        .exp-item {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .exp-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
        }

        .exp-img-container {
            overflow: hidden;
        }

        .exp-img {
            transition: transform 0.7s ease;
        }

        .exp-item:hover .exp-img {
            transform: scale(1.05);
        }
    </style>

    <div class="relative w-full h-[40vh] min-h-[300px] flex items-center justify-center overflow-hidden bg-gray-900">
        <div class="absolute inset-0 bg-gradient-to-b from-[#fe424d]/20 to-black/80"></div>
        <div class="relative z-10 text-center px-4 max-w-4xl mx-auto mt-16">
            <h1 class="text-4xl md:text-6xl font-black text-white mb-4 leading-tight drop-shadow-2xl">
                Amazing <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-[#fe424d] to-orange-400">Experiences</span>
            </h1>
            <p class="text-lg text-gray-300 font-medium drop-shadow-md max-w-2xl mx-auto">
                Real adventures, hosted by real people. Discover authentic stays and curated activities.
            </p>
        </div>
    </div>

    <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="space-y-12">

            <% if (experiences && experiences.length> 0) { %>
                <% for(let listing of experiences) { %>
                    <div
                        class="exp-item glass-card rounded-3xl overflow-hidden flex flex-col md:flex-row relative shadow-xl">

                        <div class="w-full md:w-5/12 h-64 md:h-auto exp-img-container relative">
                            <% if (listing.image && listing.image.url) { %>
                                <img src="<%= listing.image.url %>" alt="<%= listing.title %>"
                                    class="exp-img w-full h-full object-cover">
                                <% } else { %>
                                    <div
                                        class="w-full h-full bg-gray-200 flex items-center justify-center text-gray-400">
                                        <i class="fa-solid fa-image text-4xl"></i>
                                    </div>
                                    <% } %>
                                        <div
                                            class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1.5 rounded-xl text-sm font-black text-[#fe424d] shadow-md">
                                            Featured
                                        </div>
                        </div>

                        <div class="w-full md:w-7/12 p-8 flex flex-col justify-between">
                            <div>
                                <div class="flex justify-between items-start mb-2">
                                    <h3 class="text-3xl font-black text-gray-900 leading-tight">
                                        <%= listing.title %>
                                    </h3>
                                    <div
                                        class="flex items-center gap-1 text-sm font-bold text-gray-500 bg-gray-100 px-3 py-1 rounded-full">
                                        <i class="fa-solid fa-star text-[#fe424d]"></i>
                                        <%= listing.reviews.length> 0 ? (listing.reviews.reduce((acc, rev) => acc +
                                            rev.rating, 0) / listing.reviews.length).toFixed(1) : 'New' %>
                                    </div>
                                </div>

                                <p class="text-gray-500 font-medium mb-4 flex items-center gap-2">
                                    <i class="fa-solid fa-location-dot"></i>
                                    <%= listing.location %>, <%= listing.country %>
                                </p>

                                <p class="text-gray-600 mb-6 line-clamp-3 leading-relaxed">
                                    <%= listing.description %>
                                </p>
                            </div>

                            <div class="flex items-center justify-between pt-6 border-t border-gray-100 mt-auto">
                                <div>
                                    <span class="text-3xl font-black text-gray-900">&#8377; <%=
                                            listing.price.toLocaleString("en-IN") %></span>
                                    <span class="text-sm font-medium text-gray-500">/ night</span>
                                </div>
                                <a href="/listings/<%= listing._id %>"
                                    class="px-8 py-3 bg-[#fe424d] hover:bg-[#e63946] text-white font-black rounded-full shadow-lg shadow-red-500/30 transition-all hover:scale-105 active:scale-95">
                                    Book Now
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 mb-16 pl-4 md:pl-12 border-l-4 border-gray-200">
                        <h4 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
                            <i class="fa-solid fa-comments text-gray-400"></i> Recent Reviews
                        </h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                            <div class="bg-gray-50 p-5 rounded-2xl border border-gray-100 shadow-sm">
                                <div class="flex items-center gap-3 mb-3">
                                    <div
                                        class="w-10 h-10 rounded-full bg-gradient-to-br from-[#fe424d] to-orange-400 text-white flex items-center justify-center font-bold">
                                        S
                                    </div>
                                    <div>
                                        <p class="font-bold text-gray-900 text-sm">Sarah Mitchell</p>
                                        <div class="text-[#fe424d] text-xs">
                                            <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i
                                                class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i
                                                class="fa-solid fa-star"></i>
                                        </div>
                                    </div>
                                </div>
                                <p class="text-gray-600 text-sm line-clamp-2">"Absolutely incredible experience! The
                                    host went above and beyond to make our stay perfect. I cannot recommend this highly
                                    enough."</p>
                            </div>

                            <div class="bg-gray-50 p-5 rounded-2xl border border-gray-100 shadow-sm">
                                <div class="flex items-center gap-3 mb-3">
                                    <div
                                        class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-teal-400 text-white flex items-center justify-center font-bold">
                                        J
                                    </div>
                                    <div>
                                        <p class="font-bold text-gray-900 text-sm">James Davidson</p>
                                        <div class="text-[#fe424d] text-xs">
                                            <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i
                                                class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i
                                                class="fa-solid fa-star"></i>
                                        </div>
                                    </div>
                                </div>
                                <p class="text-gray-600 text-sm line-clamp-2">"Worth every single penny. The location is
                                    breathtaking and the amenities are top-notch. Will definitely be booking again next
                                    year!"</p>
                            </div>

                            <% if (listing.reviews && listing.reviews.length> 0) { %>
                                <% for(let i=0; i < Math.min(listing.reviews.length, 2); i++) { %>
                                    <% let review=listing.reviews[i]; %>
                                        <div class="bg-gray-50 p-5 rounded-2xl border border-gray-100 shadow-sm">
                                            <div class="flex items-center gap-3 mb-3">
                                                <div
                                                    class="w-10 h-10 rounded-full bg-gradient-to-br from-gray-700 to-gray-500 text-white flex items-center justify-center font-bold">
                                                    <%= review.author ? review.author.username.charAt(0).toUpperCase()
                                                        : 'U' %>
                                                </div>
                                                <div>
                                                    <p class="font-bold text-gray-900 text-sm">
                                                        <%= review.author ? review.author.username : 'User' %>
                                                    </p>
                                                    <div class="text-[#fe424d] text-xs">
                                                        <% for(let s=0; s < review.rating; s++) { %><i
                                                                class="fa-solid fa-star"></i>
                                                            <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                            <p class="text-gray-600 text-sm line-clamp-2">"<%= review.comment %>"</p>
                                        </div>
                                        <% } %>
                                            <% } %>
                        </div>
                        <% if (listing.reviews && listing.reviews.length> 0) { %>
                            <a href="/listings/<%= listing._id %>"
                                class="inline-block mt-4 text-sm font-bold text-[#fe424d] hover:underline">
                                Read all <%= listing.reviews.length + 2 %> reviews &rarr;
                            </a>
                            <% } else { %>
                                <a href="/listings/<%= listing._id %>"
                                    class="inline-block mt-4 text-sm font-bold text-[#fe424d] hover:underline">
                                    Read all 2 reviews &rarr;
                                </a>
                                <% } %>
                    </div>
                    <% } %>
                        <% } else { %>
                            <div class="text-center py-20 bg-gray-50 rounded-3xl border border-gray-200">
                                <i class="fa-regular fa-compass text-6xl text-gray-300 mb-4"></i>
                                <h3 class="text-2xl font-bold text-gray-900 mb-2">No experiences found</h3>
                                <p class="text-gray-500">We couldn't find any amazing experiences right now.</p>
                            </div>
                            <% } %>

        </div>
    </div>