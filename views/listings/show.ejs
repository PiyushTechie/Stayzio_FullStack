<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Stayzio</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet"
    crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://api.mapbox.com/mapbox-gl-js/v3.14.0/mapbox-gl.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <link rel="stylesheet" href="/css/output.css">

  <script src="https://api.mapbox.com/mapbox-gl-js/v3.14.0/mapbox-gl.js"></script>
  <link rel="icon" type="image/png" href="/images/favicon-removebg-preview.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@300;400;500;600;700;800;900&display=swap"
    rel="stylesheet">

  <style>
    body {
      font-family: 'Roboto Slab', serif;
    }
  </style>

  <script>
    const mapToken = "<%= process.env.MAP_TOKEN%>";
    const coordinates = <% -JSON.stringify(listing.geometry.coordinates) %>;
    const listingDataforMap = {
      title: "<%= listing.title %>",
      location: "<%= listing.location %>",
      country: "<%= listing.country %>"
    };
  </script>
</head>

<body class="bg-gray-50 min-h-screen">
  <%- include("../includes/navbar.ejs") %>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16" style="padding-top: 100px;">

      <div class="mb-6">
        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4">
          <div class="flex-1">
            <h1 class="text-3xl lg:text-4xl font-black text-gray-900 mb-3">
              <%= listing.title %>
            </h1>
            <div class="flex flex-wrap items-center gap-3">
              <div class="flex items-center gap-2 text-gray-600">
                <i class="fa-solid fa-location-dot text-[#fe424d]"></i>
                <span class="font-medium">
                  <%= listing.location %>, <%= listing.country %>
                </span>
              </div>
              <span
                class="inline-flex items-center gap-2 px-3 py-1 bg-gray-100 rounded-full text-sm font-bold capitalize text-gray-800">
                <i class="fa-solid fa-layer-group text-[#fe424d]"></i>
                <%= listing.category %>
              </span>
            </div>
          </div>
          <div class="flex flex-wrap gap-2">
            <a href="/listings"
              class="inline-flex items-center gap-2 px-4 py-2 font-bold rounded-lg border border-gray-300 text-gray-700 bg-white hover:bg-gray-50 transition-colors shadow-sm">
              <i class="fa-solid fa-arrow-left"></i> Back
            </a>
            <% if (currentUser && listing.owner._id.equals(currentUser._id)) { %>
              <a href="/listings/<%= listing._id %>/edit"
                class="inline-flex items-center gap-2 px-4 py-2 font-bold rounded-lg border border-gray-300 text-gray-700 bg-white hover:bg-gray-50 transition-colors shadow-sm">
                <i class="fa-solid fa-pen-to-square"></i> Edit
              </a>
              <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit"
                  class="inline-flex items-center gap-2 px-4 py-2 font-bold rounded-lg bg-red-600 text-white hover:bg-red-700 transition-colors shadow-md">
                  <i class="fa-solid fa-trash"></i> Delete
                </button>
              </form>
              <% } %>
          </div>
        </div>
      </div>

      <div class="mb-8 rounded-2xl overflow-hidden shadow-md">
        <img src="<%= listing.image.url %>" alt="<%= listing.title %>"
          class="w-full h-[500px] object-cover hover:scale-[1.02] transition-transform duration-700">
      </div>

      <div class="grid lg:grid-cols-3 gap-8">

        <div class="lg:col-span-2 space-y-8">

          <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8">
            <h2 class="text-2xl font-black text-gray-900 mb-6">Your Host</h2>

            <div class="flex flex-col sm:flex-row items-start gap-6">
              <img
                src="<%= (listing.owner && listing.owner.profile && listing.owner.profile.photo && listing.owner.profile.photo.url) ? listing.owner.profile.photo.url : '/images/default-profile.png' %>"
                alt="Host Image" class="w-20 h-20 rounded-full object-cover shadow-md border-2 border-white" />

              <div class="flex-1 w-full">
                <h3 class="font-bold text-gray-900 text-xl mb-1">
                  <%= listing.owner?.hostDetails?.name || listing.owner?.username || "Unknown Host" %>
                </h3>

                <% if (listing.owner?.hostDetails?.joinedAt) { %>
                  <p class="text-gray-500 text-sm mb-4 font-medium">
                    Host since <%= new Date(listing.owner.hostDetails.joinedAt).toLocaleDateString("en-IN") %>
                  </p>
                  <% } %>

                    <% if (listing.owner?.hostDetails?.bio) { %>
                      <p class="text-gray-700 leading-relaxed text-[15px] mb-4 bg-gray-50 p-4 rounded-xl">
                        <%= listing.owner.hostDetails.bio %>
                      </p>
                      <% } %>

                        <div class="flex flex-wrap gap-4 text-sm text-gray-600 items-center font-medium">
                          <% if (listing.owner?.hostDetails?.phone) { %>
                            <div
                              class="flex items-center gap-2 bg-gray-50 px-3 py-1.5 rounded-lg border border-gray-100">
                              <i class="fa-solid fa-phone text-gray-400"></i>
                              <span>
                                <%= listing.owner.hostDetails.phone %>
                              </span>
                            </div>
                            <% } %>
                              <% if (listing.owner?.email) { %>
                                <div
                                  class="flex items-center gap-2 bg-gray-50 px-3 py-1.5 rounded-lg border border-gray-100">
                                  <i class="fa-solid fa-envelope text-gray-400"></i>
                                  <span>
                                    <%= listing.owner.email %>
                                  </span>
                                </div>
                                <% } %>
                                  <% if (listing.owner?.hostDetails?.country) { %>
                                    <div
                                      class="flex items-center gap-2 bg-gray-50 px-3 py-1.5 rounded-lg border border-gray-100">
                                      <i class="fa-solid fa-location-dot text-gray-400"></i>
                                      <span>
                                        <%= listing.owner.hostDetails.country %>
                                      </span>
                                    </div>
                                    <% } %>
                        </div>

                        <div class="mt-6 pt-6 border-t border-gray-100 flex flex-wrap items-center gap-3">
                          <% if (!currentUser || currentUser._id.toString() !==listing.owner._id.toString()) { %>
                            <a href="/message/<%= listing._id %>"
                              class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-[#fe424d] text-white font-bold rounded-xl hover:bg-[#e63946] transition-all duration-300 shadow-md transform hover:-translate-y-0.5">
                              <i class="fa-solid fa-paper-plane"></i>
                              <span>Message Host</span>
                            </a>
                            <% } %>
                              <% if (currentUser) { %>
                                <a href="/conversations"
                                  class="inline-flex items-center gap-2 px-6 py-3 text-sm text-gray-700 bg-white hover:bg-gray-50 rounded-xl transition-all duration-300 font-bold border border-gray-200 shadow-sm">
                                  <i class="fa-solid fa-comments text-gray-400"></i>
                                  <span>View Inbox</span>
                                </a>
                                <% } %>
                        </div>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8">
            <h2 class="text-2xl font-black text-gray-900 mb-6">About This Property</h2>
            <p class="text-gray-700 leading-relaxed text-[15px]">
              <%= listing.description %>
            </p>
          </div>

          <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8">
            <h2 class="text-2xl font-black text-gray-900 mb-6">Property Details</h2>
            <div class="grid sm:grid-cols-2 gap-4">
              <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm">
                  <i class="fa-solid fa-location-dot text-[#fe424d] text-lg"></i>
                </div>
                <div>
                  <div class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-0.5">Location</div>
                  <div class="font-bold text-gray-900">
                    <%= listing.location %>
                  </div>
                </div>
              </div>
              <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm">
                  <i class="fa-solid fa-flag text-[#fe424d] text-lg"></i>
                </div>
                <div>
                  <div class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-0.5">Country</div>
                  <div class="font-bold text-gray-900">
                    <%= listing.country %>
                  </div>
                </div>
              </div>
              <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm">
                  <i class="fa-solid fa-house text-[#fe424d] text-lg"></i>
                </div>
                <div>
                  <div class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-0.5">Property Type</div>
                  <div class="font-bold text-gray-900 capitalize">
                    <%= listing.propertyType || 'Property' %>
                  </div>
                </div>
              </div>
              <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm">
                  <i class="fa-solid fa-bed text-[#fe424d] text-lg"></i>
                </div>
                <div>
                  <div class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-0.5">Beds</div>
                  <div class="font-bold text-gray-900">
                    <%= listing.beds || 1 %> Bed<%= (listing.beds || 1) !==1 ? 's' : '' %>
                  </div>
                </div>
              </div>
              <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm">
                  <i class="fa-solid fa-layer-group text-[#fe424d] text-lg"></i>
                </div>
                <div>
                  <div class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-0.5">Category</div>
                  <div class="font-bold text-gray-900 capitalize">
                    <%= listing.category %>
                  </div>
                </div>
              </div>
              <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm">
                  <i class="fa-solid fa-rupee-sign text-[#fe424d] text-lg"></i>
                </div>
                <div>
                  <div class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-0.5">Price</div>
                  <div class="font-bold text-gray-900">₹ <%= listing.price ? listing.price.toLocaleString("en-IN")
                      : 'N/A' %> / night</div>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8">
            <h2 class="text-2xl font-black text-gray-900 mb-6">What this place offers</h2>
            <div class="grid grid-cols-2 gap-y-6 gap-x-8">
              <% if (listing.amenities && listing.amenities.length> 0) { %>
                <% const iconMap={ 'Wifi' : 'fa-wifi' , 'Pool' : 'fa-water-ladder' , 'Kitchen' : 'fa-kitchen-set'
                  , 'Free Parking' : 'fa-square-parking' , 'Air Conditioning' : 'fa-snowflake' , 'TV' : 'fa-tv' }; %>
                  <% listing.amenities.forEach(amenity=> { %>
                    <div class="flex items-center gap-4 text-gray-700">
                      <i
                        class="fa-solid <%= iconMap[amenity] || 'fa-check' %> w-6 text-center text-xl text-gray-400"></i>
                      <span class="font-bold">
                        <%= amenity %>
                      </span>
                    </div>
                    <% }) %>
                      <% } else { %>
                        <div class="text-gray-500 font-medium italic col-span-2">No amenities listed</div>
                        <% } %>
            </div>
          </div>

          <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8">
            <div class="flex justify-between items-center mb-6">
              <h2 class="text-2xl font-black text-gray-900 mb-0">Where You'll Be</h2>
              <button id="loadMapBtn"
                class="inline-flex items-center gap-2 px-4 py-2 font-bold rounded-lg bg-[#fe424d] text-white hover:bg-[#e63946] transition-colors shadow-sm text-sm">
                <i class="fa-solid fa-map-location-dot"></i> Show Map
              </button>
            </div>
            <div id="map" class="rounded-xl overflow-hidden border border-gray-200 shadow-inner"
              style="display:none; height: 400px; width: 100%;"></div>
          </div>

        </div>

        <div class="lg:col-span-1 relative">
          <div
            class="bg-white rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-gray-200 sticky top-28 p-6 sm:p-8">
            <div class="mb-6 border-b border-gray-100 pb-6">
              <div class="text-sm text-gray-500 font-bold uppercase tracking-wider mb-1">Price per Night</div>
              <div class="text-4xl font-black text-[#fe424d]">
                ₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : 'N/A' %>
              </div>
            </div>

            <form id="booking-form" action="/bookings/details" method="GET" class="needs-validation" novalidate>
              <input type="hidden" name="listingId" value="<%= listing._id %>">

              <div class="mb-5">
                <label class="block text-sm font-bold text-gray-700 mb-2">Check-in Date</label>
                <input type="text" id="checkIn" name="checkIn"
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-[#fe424d] outline-none font-medium bg-gray-50"
                  required placeholder="Select date">
              </div>

              <div class="mb-6">
                <label class="block text-sm font-bold text-gray-700 mb-2">Check-out Date</label>
                <input type="text" id="checkOut" name="checkOut"
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-[#fe424d] outline-none font-medium bg-gray-50"
                  required placeholder="Select date">
              </div>

              <div id="date-error" class="text-red-600 text-sm text-center mb-4 font-bold min-h-[1.25rem]"></div>

              <button type="submit" id="bookBtn"
                class="w-full inline-flex items-center justify-center gap-2 px-6 py-4 font-black rounded-xl text-white transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 text-lg"
                style="background-color: #fe424d;">
                <span class="button-text flex items-center gap-2">
                  <i class="fa-solid fa-calendar-check"></i> Reserve Now
                </span>
                <span class="button-loader hidden"><i class="fa-solid fa-circle-notch fa-spin"></i></span>
              </button>
              <p class="text-center text-sm text-gray-500 font-medium mt-4">You won't be charged yet</p>
            </form>
          </div>
        </div>
      </div>

      <hr class="my-12 border-gray-200">

      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8">
        <h2 class="text-2xl font-black text-gray-900 mb-8">Guest Reviews</h2>

        <% if (currentUser) { %>
          <div class="bg-gray-50 rounded-2xl p-6 sm:p-8 mb-10 border border-gray-200">
            <h3 class="font-black text-xl text-gray-900 mb-6">Share Your Experience</h3>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div class="mb-6">
                <label class="block text-sm font-bold text-gray-700 mb-3">Your Rating</label>
                <div class="star-rating flex gap-2 text-2xl cursor-pointer">
                  <i class="fa-solid fa-star text-yellow-400 transition-transform hover:scale-110" data-value="1"></i>
                  <i class="fa-solid fa-star text-gray-300 transition-transform hover:scale-110" data-value="2"></i>
                  <i class="fa-solid fa-star text-gray-300 transition-transform hover:scale-110" data-value="3"></i>
                  <i class="fa-solid fa-star text-gray-300 transition-transform hover:scale-110" data-value="4"></i>
                  <i class="fa-solid fa-star text-gray-300 transition-transform hover:scale-110" data-value="5"></i>
                </div>
                <input type="hidden" name="review[rating]" id="ratingValue" value="1" required>
              </div>

              <div class="mb-6">
                <label class="block text-sm font-bold text-gray-700 mb-2">Your Review</label>
                <textarea id="comment" name="review[comment]"
                  class="w-full px-4 py-4 rounded-xl border border-gray-300 focus:ring-2 focus:ring-[#fe424d] outline-none font-medium resize-none"
                  rows="4" placeholder="Tell us about your stay..." required></textarea>
              </div>

              <button type="submit"
                class="inline-flex items-center justify-center gap-2 px-6 py-3 font-bold rounded-xl bg-gray-900 text-white hover:bg-black transition-colors shadow-md">
                <i class="fa-solid fa-paper-plane"></i> Submit Review
              </button>
            </form>
          </div>
          <% } else { %>
            <div class="bg-gray-50 rounded-2xl p-12 text-center border border-gray-200 mb-10">
              <div
                class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-4 shadow-sm border border-gray-100">
                <i class="fa-solid fa-lock text-3xl text-gray-400"></i>
              </div>
              <h3 class="text-2xl font-black text-gray-900 mb-2">Login Required</h3>
              <p class="text-gray-500 font-medium mb-6">Please log in to share your review</p>
              <a href="/login"
                class="inline-flex items-center justify-center gap-2 px-6 py-3 font-bold rounded-xl bg-[#fe424d] text-white hover:bg-[#e63946] transition-colors shadow-sm">
                <i class="fa-solid fa-sign-in-alt"></i> Login to Continue
              </a>
            </div>
            <% } %>

              <% if (listing.reviews.length===0) { %>
                <div class="text-center py-16 bg-gray-50 rounded-2xl border border-dashed border-gray-300">
                  <div class="w-24 h-24 bg-white rounded-full flex items-center justify-center mx-auto mb-4 shadow-sm">
                    <i class="fa-regular fa-comments text-5xl text-gray-300"></i>
                  </div>
                  <h3 class="text-2xl font-black text-gray-900 mb-2">No Reviews Yet</h3>
                  <p class="text-gray-500 font-medium">Be the first to share your experience!</p>
                </div>
                <% } else { %>
                  <div class="grid md:grid-cols-2 gap-6">
                    <% listing.reviews.forEach(review=> { %>
                      <div
                        class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
                        <div class="flex items-start gap-4 mb-4">
                          <% if (review.author && review.author.username) { %>
                            <div
                              class="w-12 h-12 flex-shrink-0 relative overflow-hidden rounded-full border-2 border-gray-100">
                              <% if (review.author.profile && review.author.profile.photo &&
                                review.author.profile.photo.url) { %>
                                <img src="<%= review.author.profile.photo.url %>" alt="User Photo"
                                  class="w-full h-full object-cover" />
                                <% } else { %>
                                  <div
                                    class="w-full h-full bg-gray-900 flex items-center justify-center text-white font-bold text-lg">
                                    <%= review.author.username.charAt(0).toUpperCase() %>
                                  </div>
                                  <% } %>
                            </div>
                            <div class="flex-1">
                              <div class="font-bold text-gray-900 text-lg">
                                <%= review.author.username %>
                              </div>
                              <div class="flex gap-1 mt-1">
                                <% for (let i=1; i <=5; i++) { %>
                                  <i class="<%= i <= review.rating ? 'fa-solid fa-star text-yellow-400' : 'fa-solid fa-star text-gray-200' %>"
                                    style="font-size: 0.875rem;"></i>
                                  <% } %>
                              </div>
                            </div>
                            <% } else { %>
                              <div
                                class="w-12 h-12 flex-shrink-0 rounded-full bg-gray-200 flex items-center justify-center border-2 border-gray-100">
                                <i class="fa-solid fa-user-secret text-gray-500 text-xl"></i>
                              </div>
                              <div class="flex-1">
                                <div class="font-bold text-gray-900 text-lg italic">Anonymous</div>
                                <div class="flex gap-1 mt-1">
                                  <% for (let i=1; i <=5; i++) { %>
                                    <i class="<%= i <= review.rating ? 'fa-solid fa-star text-yellow-400' : 'fa-solid fa-star text-gray-200' %>"
                                      style="font-size: 0.875rem;"></i>
                                    <% } %>
                                </div>
                              </div>
                              <% } %>
                        </div>

                        <p class="text-gray-700 font-medium leading-relaxed mb-4 bg-gray-50 p-4 rounded-xl">
                          <%= review.comment %>
                        </p>

                        <% if (currentUser && review.author && review.author._id.equals(currentUser._id)) { %>
                          <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                            method="POST">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit"
                              class="inline-flex items-center gap-2 text-red-600 text-sm font-bold hover:text-red-700 transition-colors">
                              <i class="fa-solid fa-trash"></i> Delete Review
                            </button>
                          </form>
                          <% } %>
                      </div>
                      <% }) %>
                  </div>
                  <% } %>
      </div>
    </div>

    <%- include("../includes/footer.ejs") %>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"
        crossorigin="anonymous"></script>
      <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
      <script src="/js/map.js"></script>
      <script src="/js/script.js"></script>

      <script>
        const stars = document.querySelectorAll('.star-rating .fa-star');
        const ratingInput = document.getElementById('ratingValue');

        if (stars.length > 0) {
          const updateStars = (rating) => {
            stars.forEach(star => {
              const val = parseInt(star.getAttribute('data-value'));
              if (val <= rating) {
                star.classList.remove('text-gray-300');
                star.classList.add('text-yellow-400');
              } else {
                star.classList.add('text-gray-300');
                star.classList.remove('text-yellow-400');
              }
            });
          };

          stars.forEach(star => {
            star.addEventListener('click', () => {
              const rating = parseInt(star.getAttribute('data-value'));
              ratingInput.value = rating;
              updateStars(rating);
            });
          });

          document.querySelector('.star-rating').addEventListener('mouseleave', () => {
            updateStars(parseInt(ratingInput.value));
          });

          updateStars(parseInt(ratingInput.value)); // Initialize
        }

        const mapBtn = document.getElementById('loadMapBtn');
        const mapDiv = document.getElementById('map');
        let mapInitialized = false;

        mapBtn.addEventListener('click', () => {
          const isHidden = mapDiv.style.display === 'none';
          mapDiv.style.display = isHidden ? 'block' : 'none';
          mapBtn.innerHTML = isHidden ? '<i class="fa-solid fa-eye-slash"></i> Hide Map' : '<i class="fa-solid fa-map-location-dot"></i> Show Map';

          if (isHidden && !mapInitialized) {
            initializeMap();
            mapInitialized = true;
          }
        });

        fetch(`/bookings/api/booked-dates?listingId=<%= listing._id %>`)
          .then(res => res.json())
          .then(data => {
            const disabledRanges = data.bookings.map(b => ({ from: b.checkIn, to: b.checkOut }));
            const flatpickrConfig = {
              dateFormat: "Y-m-d",
              altInput: true,
              altFormat: "d-m-Y",
              minDate: "today",
              disable: disabledRanges,
            };
            flatpickr("#checkIn", flatpickrConfig);
            flatpickr("#checkOut", flatpickrConfig);
          })
          .catch(err => {
            console.error("Failed to load booked dates:", err);
            const fallbackConfig = {
              dateFormat: "Y-m-d",
              altInput: true,
              altFormat: "d-m-Y",
              minDate: "today"
            };
            flatpickr("#checkIn", fallbackConfig);
            flatpickr("#checkOut", fallbackConfig);
          });

        const bookingForm = document.getElementById('booking-form');
        const bookBtn = document.getElementById("bookBtn");

        if (bookingForm) {
          bookingForm.addEventListener('submit', function (event) {
            const checkInInput = document.getElementById('checkIn');
            const checkOutInput = document.getElementById('checkOut');
            const dateError = document.getElementById('date-error');

            dateError.textContent = '';
            checkInInput.classList.remove('ring-2', 'ring-red-500');
            checkOutInput.classList.remove('ring-2', 'ring-red-500');

            const checkInValue = checkInInput.value;
            const checkOutValue = checkOutInput.value;

            if (!checkInValue || !checkOutValue) {
              event.preventDefault();
              dateError.textContent = 'Please select both check-in and check-out dates.';
              if (!checkInValue) checkInInput.classList.add('ring-2', 'ring-red-500');
              if (!checkOutValue) checkOutInput.classList.add('ring-2', 'ring-red-500');
              return;
            }

            const checkInDate = new Date(checkInValue);
            const checkOutDate = new Date(checkOutValue);

            if (checkOutDate <= checkInDate) {
              event.preventDefault();
              dateError.textContent = 'Check-out date must be after the check-in date.';
              checkOutInput.classList.add('ring-2', 'ring-red-500');
              return;
            }

            if (!bookingForm.checkValidity()) {
              event.preventDefault();
              bookingForm.reportValidity();
              return;
            }

            const btnText = bookBtn.querySelector('.button-text');
            const btnLoader = bookBtn.querySelector('.button-loader');
            if (btnText && btnLoader) {
              btnText.classList.add('hidden');
              btnLoader.classList.remove('hidden');
              btnLoader.classList.add('flex', 'justify-center', 'items-center', 'w-full');
            }
            bookBtn.disabled = true;
          });
        }
      </script>

      <%- include('../includes/flash.ejs') %>
</body>

</html>