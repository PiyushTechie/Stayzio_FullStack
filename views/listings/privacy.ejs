<% layout('layouts/infoBoilerplate') -%>

    <div class="bg-gradient-to-r from-gray-900 to-gray-800 pt-20 pb-16 relative overflow-hidden">
        <div
            class="absolute top-0 left-0 w-full h-full opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]">
        </div>
        <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10 text-center" data-aos="fade-up">
            <h1 class="text-4xl md:text-5xl font-black text-white mb-4 tracking-tight">
                <i class="fas fa-shield-alt text-[#fe424d] mr-3"></i> Privacy Policy
            </h1>
            <p class="text-xl text-gray-300 max-w-2xl mx-auto">Your privacy is important to us. Learn how we collect,
                use, and protect your information.</p>
            <p class="mt-6 text-sm text-gray-400 font-medium tracking-wider uppercase">Last updated: August 30, 2026</p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
        <div class="flex flex-col lg:flex-row gap-12">

            <div class="lg:w-1/4 hidden lg:block">
                <div
                    class="sticky top-28 bg-white border border-gray-100 rounded-3xl p-6 shadow-[0_8px_30px_rgb(0,0,0,0.04)]">
                    <h3 class="font-bold text-gray-900 mb-4 uppercase tracking-wider text-sm flex items-center gap-2">
                        <i class="fas fa-list text-[#fe424d]"></i> Contents
                    </h3>
                    <nav class="sticky-nav flex flex-col space-y-1">
                        <a href="#overview"
                            class="px-4 py-2 text-sm text-gray-500 rounded-lg border-l-2 border-transparent hover:bg-gray-50 transition-colors">Overview</a>
                        <a href="#information-we-collect"
                            class="px-4 py-2 text-sm text-gray-500 rounded-lg border-l-2 border-transparent hover:bg-gray-50 transition-colors">Information
                            We Collect</a>
                        <a href="#how-we-use"
                            class="px-4 py-2 text-sm text-gray-500 rounded-lg border-l-2 border-transparent hover:bg-gray-50 transition-colors">How
                            We Use Information</a>
                        <a href="#information-sharing"
                            class="px-4 py-2 text-sm text-gray-500 rounded-lg border-l-2 border-transparent hover:bg-gray-50 transition-colors">Information
                            Sharing</a>
                        <a href="#data-security"
                            class="px-4 py-2 text-sm text-gray-500 rounded-lg border-l-2 border-transparent hover:bg-gray-50 transition-colors">Data
                            Security</a>
                        <a href="#your-rights"
                            class="px-4 py-2 text-sm text-gray-500 rounded-lg border-l-2 border-transparent hover:bg-gray-50 transition-colors">Your
                            Rights</a>
                        <a href="#contact"
                            class="px-4 py-2 text-sm text-gray-500 rounded-lg border-l-2 border-transparent hover:bg-gray-50 transition-colors">Contact
                            Us</a>
                    </nav>
                </div>
            </div>

            <div
                class="lg:w-3/4 prose-content bg-white p-8 md:p-12 rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100">

                <div id="overview">
                    <h2><i class="fas fa-info-circle"></i> Overview</h2>
                    <p>Welcome to Stayzio! This Privacy Policy explains how Stayzio, Inc. ("we," "us," or "our")
                        collects, uses, discloses, and protects your personal information when you use our website,
                        mobile application, and services (collectively, the "Service").</p>

                    <div class="highlight-box">
                        <h4><i class="fas fa-key"></i> Key Points:</h4>
                        <ul>
                            <li>We collect information to provide and improve our accommodation booking services.</li>
                            <li>We never sell your personal data to third parties.</li>
                            <li>You have control over your data and can request deletion at any time.</li>
                            <li>We use industry-standard security measures to protect your information.</li>
                        </ul>
                    </div>
                </div>

                <div id="information-we-collect">
                    <h2><i class="fas fa-database"></i> Information We Collect</h2>
                    <h3>Personal Information</h3>
                    <p>When you create an account or use our services, we may collect:</p>
                    <ul>
                        <li><strong>Account Information:</strong> Name, email address, phone number, profile photo.</li>
                        <li><strong>Payment Information:</strong> Credit card details, billing address (processed
                            securely through third-party payment processors).</li>
                        <li><strong>Identity Verification:</strong> Government-issued ID, verification photos when
                            required.</li>
                    </ul>

                    <h3>Usage Information</h3>
                    <p>We automatically collect information about how you use our Service:</p>
                    <ul>
                        <li><strong>Usage Data:</strong> Pages viewed, search queries, booking history, preferences.
                        </li>
                        <li><strong>Location Data:</strong> Approximate location based on IP address.</li>
                    </ul>
                </div>

                <div id="how-we-use">
                    <h2><i class="fas fa-cogs"></i> How We Use Your Information</h2>
                    <p>We use your information for the following purposes:</p>
                    <ol>
                        <li><strong>Service Provision:</strong> Process bookings, facilitate communications between
                            hosts and guests.</li>
                        <li><strong>Account Management:</strong> Create and maintain your account, provide customer
                            support.</li>
                        <li><strong>Payment Processing:</strong> Handle transactions, prevent fraud, issue refunds.</li>
                        <li><strong>Safety & Security:</strong> Verify identities, prevent fraud, ensure platform
                            safety.</li>
                    </ol>
                </div>

                <div id="information-sharing">
                    <h2><i class="fas fa-share-alt"></i> Information Sharing</h2>
                    <p>We may share your information in the following circumstances:</p>
                    <ul>
                        <li>Your public profile information with hosts when you make a booking.</li>
                        <li>Your contact information with guests when they book your property (if you're a host).</li>
                        <li>Payment processors for transaction handling.</li>
                        <li>Cloud hosting providers for data storage.</li>
                    </ul>
                </div>

                <div id="data-security">
                    <h2><i class="fas fa-lock"></i> Data Security</h2>
                    <p>We implement comprehensive security measures to protect your personal information:</p>
                    <ul>
                        <li><strong>Encryption:</strong> All data transmission is encrypted using TLS/SSL.</li>
                        <li><strong>Access Controls:</strong> Strict access controls and authentication for our systems.
                        </li>
                        <li><strong>Secure Storage:</strong> Data stored in secure, encrypted databases with regular
                            backups.</li>
                    </ul>
                </div>

                <div id="your-rights">
                    <h2><i class="fas fa-user-shield"></i> Your Rights</h2>
                    <p>You have several rights regarding your personal information:</p>
                    <ul>
                        <li><strong>Access:</strong> Request a copy of the personal information we hold about you.</li>
                        <li><strong>Correction:</strong> Update or correct inaccurate information in your account.</li>
                        <li><strong>Deletion:</strong> Request deletion of your personal information (with certain
                            exceptions).</li>
                        <li><strong>Opt-out:</strong> Unsubscribe from marketing communications at any time.</li>
                    </ul>
                </div>

                <div id="contact">
                    <h2><i class="fas fa-envelope"></i> Contact Us</h2>
                    <p>If you have any questions, concerns, or requests regarding this Privacy Policy or your personal
                        information, please contact us:</p>

                    <div class="bg-gray-50 p-6 rounded-2xl border border-gray-200 mt-6">
                        <h4 class="font-bold text-gray-900 mb-2">Stayzio Privacy Team</h4>
                        <p class="mb-1"><strong class="text-gray-900">Email:</strong> <a
                                href="mailto:privacy@stayzio.com"
                                class="text-[#fe424d] hover:underline">privacy@stayzio.com</a></p>
                        <p class="mb-1"><strong class="text-gray-900">Address:</strong> Stayzio, Inc., Mumbai,
                            Maharashtra, India</p>
                    </div>
                </div>

            </div>
        </div>
    </div>