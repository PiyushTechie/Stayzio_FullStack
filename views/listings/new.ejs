<% layout('layouts/boilerplate') -%>

  <div class="min-h-screen bg-gray-50 pb-20" style="padding-top: 140px;">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="bg-white rounded-[2rem] shadow-xl border border-gray-100 overflow-hidden">

        <div class="bg-gradient-to-br from-red-500 to-red-400 p-10 text-center relative overflow-hidden">
          <div
            class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white to-transparent">
          </div>
          <div
            class="w-16 h-16 mx-auto bg-white/20 backdrop-blur-md rounded-2xl flex items-center justify-center text-white text-3xl mb-4 shadow-inner relative z-10">
            <i class="fa-solid fa-house-medical"></i>
          </div>
          <h2 class="text-3xl font-black text-white relative z-10 mb-2">Create a New Listing</h2>
          <p class="text-white/90 font-medium relative z-10">Share your incredible space with travelers worldwide.</p>
        </div>

        <div class="p-8 sm:p-12">
          <form id="listingForm" method="post" action="/listings" novalidate enctype="multipart/form-data">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="space-y-8">

              <div>
                <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                    class="fa-solid fa-heading text-red-500"></i> Property Title</label>
                <input type="text" name="listing[title]"
                  class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-red-500 focus:ring-4 focus:ring-red-500/20"
                  placeholder="e.g., Cozy Beachfront Villa" required>
                <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                    class="fa-solid fa-circle-exclamation mr-1"></i> Please enter a catchy title.</div>
              </div>

              <div>
                <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                    class="fa-solid fa-align-left text-red-500"></i> Description</label>
                <textarea name="listing[description]"
                  class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-red-500 focus:ring-4 focus:ring-red-500/20"
                  rows="4" placeholder="Describe your property, amenities, and what makes it truly special..."
                  required></textarea>
                <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                    class="fa-solid fa-circle-exclamation mr-1"></i> A description is required.</div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                <div>
                  <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                      class="fa-solid fa-layer-group text-red-500"></i> Category</label>
                  <select name="listing[category]"
                    class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-red-500 focus:ring-4 focus:ring-red-500/20 appearance-none bg-[url('data:image/svg+xml;utf8,<svg fill=\'#ef4444\' height=\'24\' viewBox=\'0 0 24 24\' width=\'24\' xmlns=\'http://www.w3.org/2000/svg\'><path d=\'M7 10l5 5 5-5z\'/></svg>')] bg-no-repeat bg-[position:right_10px_center]"
                    required>
                    <option selected disabled value="">Choose a category...</option>
                    <option value="rooms">Rooms</option>
                    <option value="cities">Iconic Cities</option>
                    <option value="mountains">Mountains</option>
                    <option value="castles">Castles</option>
                    <option value="pools">Amazing Pools</option>
                    <option value="camping">Camping</option>
                    <option value="farms">Farms</option>
                    <option value="beach">Beachfront</option>
                    <option value="luxury">Luxury</option>
                    <option value="cabins">Cabins</option>
                    <option value="boats">Boats</option>
                  </select>
                  <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                      class="fa-solid fa-circle-exclamation mr-1"></i> Please select a category.</div>
                </div>

                <div>
                  <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                      class="fa-solid fa-building text-red-500"></i> Property Type</label>
                  <select name="listing[propertyType]"
                    class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-red-500 focus:ring-4 focus:ring-red-500/20 appearance-none bg-[url('data:image/svg+xml;utf8,<svg fill=\'#ef4444\' height=\'24\' viewBox=\'0 0 24 24\' width=\'24\' xmlns=\'http://www.w3.org/2000/svg\'><path d=\'M7 10l5 5 5-5z\'/></svg>')] bg-no-repeat bg-[position:right_10px_center]"
                    required>
                    <option selected disabled value="">Choose property type...</option>
                    <option value="Apartment">Apartment</option>
                    <option value="House">House</option>
                    <option value="Cabin">Cabin</option>
                    <option value="Villa">Villa</option>
                    <option value="Hotel">Hotel</option>
                    <option value="Guesthouse">Guesthouse</option>
                    <option value="Other">Other</option>
                  </select>
                  <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                      class="fa-solid fa-circle-exclamation mr-1"></i> Please select a property type.</div>
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                <div>
                  <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                      class="fa-solid fa-indian-rupee-sign text-red-500"></i> Price per Night</label>
                  <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-500 font-bold">₹</span>
                    <input type="number" name="listing[price]"
                      class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-red-500 focus:ring-4 focus:ring-red-500/20 pl-10"
                      placeholder="0" required min="1" oninput="if(this.value < 0) this.value = Math.abs(this.value)">
                  </div>
                  <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                      class="fa-solid fa-circle-exclamation mr-1"></i> Please enter a valid price.</div>
                </div>

                <div>
                  <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                      class="fa-solid fa-bed text-red-500"></i> Number of Beds</label>
                  <input type="number" name="listing[beds]"
                    class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-red-500 focus:ring-4 focus:ring-red-500/20"
                    value="1" required min="1" oninput="if(this.value < 1 && this.value !== '') this.value = 1">
                  <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                      class="fa-solid fa-circle-exclamation mr-1"></i> Please enter number of beds.</div>
                </div>
              </div>

              <div>
                <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                    class="fa-solid fa-camera text-red-500"></i> Property Photo</label>
                <div class="relative w-full group">
                  <input type="file" name="listing[image]" id="file-input"
                    class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" accept="image/*" required>
                  <div id="file-drop-zone"
                    class="border-2 border-dashed border-gray-300 bg-gray-50 rounded-2xl px-6 py-10 text-center cursor-pointer transition-all duration-300 group-hover:border-red-500 group-hover:bg-red-50 flex flex-col items-center justify-center">
                    <div
                      class="w-16 h-16 bg-red-100 text-red-500 rounded-full flex items-center justify-center text-2xl mb-3 shadow-sm">
                      <i class="fa-solid fa-cloud-arrow-up"></i>
                    </div>
                    <h4 class="text-lg font-black text-gray-900 mb-1" id="file-name-display">Click to upload image</h4>
                    <p class="text-sm font-bold text-gray-400">or drag and drop here (Max 5MB)</p>
                  </div>
                </div>
                <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                    class="fa-solid fa-circle-exclamation mr-1"></i> A stunning cover photo is required.</div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                <div>
                  <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                      class="fa-solid fa-location-dot text-red-500"></i> Location</label>
                  <input type="text" name="listing[location]"
                    class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-red-500 focus:ring-4 focus:ring-red-500/20"
                    placeholder="City, State" required>
                  <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                      class="fa-solid fa-circle-exclamation mr-1"></i> Location is required.</div>
                </div>

                <div>
                  <label class="flex items-center gap-2 text-[0.95rem] font-bold text-gray-700 mb-2"><i
                      class="fa-solid fa-globe text-red-500"></i> Country</label>
                  <input type="text" name="listing[country]"
                    class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-base text-gray-900 transition-all duration-300 focus:outline-none focus:bg-white focus:border-red-500 focus:ring-4 focus:ring-red-500/20"
                    placeholder="e.g., India" required>
                  <div class="hidden text-red-500 text-sm font-bold mt-2"><i
                      class="fa-solid fa-circle-exclamation mr-1"></i> Country is required.</div>
                </div>
              </div>

              <div class="pt-6">
                <button type="submit"
                  class="bg-gradient-to-br from-red-500 to-red-600 text-white w-full p-5 rounded-2xl font-black text-lg shadow-lg shadow-red-500/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-red-500/40 flex justify-center items-center gap-3">
                  <i class="fa-solid fa-plus-circle"></i> Create Listing
                </button>
              </div>

            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script>
    const fileInput = document.getElementById('file-input');
    const fileNameDisplay = document.getElementById('file-name-display');

    fileInput.addEventListener('change', function (e) {
      if (e.target.files.length > 0) {
        fileNameDisplay.textContent = e.target.files[0].name;
        fileNameDisplay.classList.add('text-red-500');
      } else {
        fileNameDisplay.textContent = 'Click to upload image';
        fileNameDisplay.classList.remove('text-red-500');
      }
    });

    const form = document.getElementById('listingForm');
    const inputs = form.querySelectorAll('input[required], textarea[required], select[required]');

    function showError(input) {
      input.classList.remove('border-gray-200');
      input.classList.add('border-red-500', 'bg-red-50');
      const errorDiv = input.closest('div').querySelector('.text-red-500.hidden');
      if (errorDiv) {
        errorDiv.classList.remove('hidden');
      }
      if (input.type === 'file') {
        const dropZone = document.getElementById('file-drop-zone');
        dropZone.classList.remove('border-gray-300');
        dropZone.classList.add('border-red-500', 'bg-red-50');
      }
    }

    function hideError(input) {
      input.classList.add('border-gray-200');
      input.classList.remove('border-red-500', 'bg-red-50');
      const errorDiv = input.closest('div').querySelector('.text-red-500:not(.hidden)');
      if (errorDiv) {
        errorDiv.classList.add('hidden');
      }
      if (input.type === 'file') {
        const dropZone = document.getElementById('file-drop-zone');
        dropZone.classList.add('border-gray-300');
        dropZone.classList.remove('border-red-500', 'bg-red-50');
      }
    }

    form.addEventListener('submit', function (event) {
      let isValid = true;
      inputs.forEach(input => {
        if (!input.checkValidity()) {
          isValid = false;
          showError(input);
        } else {
          hideError(input);
        }
      });

      if (!isValid) {
        event.preventDefault();
      }
    });

    inputs.forEach(input => {
      input.addEventListener('input', function () {
        if (this.checkValidity()) {
          hideError(this);
        }
      });
      input.addEventListener('change', function () {
        if (this.checkValidity()) {
          hideError(this);
        }
      });
    });
  </script>