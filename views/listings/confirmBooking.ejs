<% layout("/layouts/infoBoilerplate") %>

    <style>
        .corp-card {
            background-color: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 0.5rem;
        }

        .corp-header {
            border-bottom: 1px solid #e5e7eb;
            padding: 1.25rem 1.5rem;
            background-color: #f9fafb;
            border-top-left-radius: 0.5rem;
            border-top-right-radius: 0.5rem;
        }

        .corp-body {
            padding: 1.5rem;
        }

        .stepper {
            display: flex;
            align-items: center;
            margin-bottom: 2rem;
            border-bottom: 1px solid #e5e7eb;
            padding-bottom: 1rem;
        }

        .step-completed {
            color: #059669;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .step-active {
            color: #111827;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .step-divider {
            color: #059669;
            margin: 0 1rem;
        }

        .btn-primary {
            background-color: #fe424d;
            color: #ffffff;
            border: none;
            border-radius: 0.5rem;
            padding: 0.875rem 1.5rem;
            font-weight: 600;
            font-size: 1.125rem;
            cursor: pointer;
            transition: background-color 0.15s ease-in-out;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            gap: 0.5rem;
        }

        .btn-primary:hover {
            background-color: #e63946;
        }

        .btn-primary:disabled {
            opacity: 0.65;
            cursor: not-allowed;
        }

        .receipt-item {
            display: flex;
            justify-content: space-between;
            padding: 0.75rem 0;
        }

        .receipt-item.bordered {
            border-bottom: 1px solid #e5e7eb;
        }

        .btn-loader {
            display: none;
            width: 1.25rem;
            height: 1.25rem;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-top-color: #ffffff;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        .btn-primary.loading .btn-text {
            display: none;
        }

        .btn-primary.loading .btn-loader {
            display: block;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-24 bg-white min-h-screen">

        <div class="stepper max-w-4xl">
            <div class="step-completed">
                <span
                    class="w-6 h-6 rounded-full bg-emerald-600 text-white flex items-center justify-center text-xs font-bold"><i
                        class="fa-solid fa-check"></i></span>
                Guest Details
            </div>
            <div class="step-divider"><i class="fa-solid fa-arrow-right text-sm"></i></div>
            <div class="step-active">
                <span
                    class="w-6 h-6 rounded-full bg-gray-900 text-white flex items-center justify-center text-xs font-bold">2</span>
                Confirm & Pay
            </div>
        </div>

        <div class="mb-8">
            <h1 class="text-3xl font-semibold text-gray-900 mb-2">Review booking details</h1>
            <p class="text-gray-600">Please confirm your trip details before finalizing your payment.</p>
        </div>

        <div class="flex flex-col lg:flex-row gap-8">

            <div class="w-full lg:w-7/12">
                <div class="corp-card mb-6">
                    <div class="corp-header">
                        <h2 class="text-lg font-semibold text-gray-900">Trip Summary</h2>
                    </div>
                    <div class="corp-body">

                        <div class="flex flex-col sm:flex-row gap-6 mb-6 pb-6 border-b border-gray-200">
                            <div class="w-full sm:w-1/3 h-32 bg-gray-100 rounded-md overflow-hidden">
                                <% if (listing.image && listing.image.url) { %>
                                    <img src="<%= listing.image.url %>" alt="<%= listing.title %>"
                                        class="w-full h-full object-cover">
                                    <% } else { %>
                                        <div class="w-full h-full flex items-center justify-center text-gray-400">No
                                            Image</div>
                                        <% } %>
                            </div>
                            <div class="w-full sm:w-2/3">
                                <span
                                    class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Property</span>
                                <h3 class="text-xl font-semibold text-gray-900 mt-1 mb-2">
                                    <%= listing.title %>
                                </h3>
                                <p class="text-gray-600 text-sm">
                                    <%= listing.location %>, <%= listing.country %>
                                </p>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6 pb-6 border-b border-gray-200">
                            <div>
                                <p class="text-sm font-semibold text-gray-500 mb-1">Check-in</p>
                                <p class="text-base font-medium text-gray-900">
                                    <%= new Date(checkIn).toLocaleDateString('en-IN', { day:'numeric', month:'short',
                                        year:'numeric' }) %>
                                </p>
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-gray-500 mb-1">Check-out</p>
                                <p class="text-base font-medium text-gray-900">
                                    <%= new Date(checkOut).toLocaleDateString('en-IN', { day:'numeric', month:'short',
                                        year:'numeric' }) %>
                                </p>
                            </div>
                        </div>

                        <div class="mb-6 pb-6 border-b border-gray-200">
                            <p class="text-sm font-semibold text-gray-500 mb-3">Guests (<%= guests ? guests.length : 0
                                    %>)</p>
                            <% if (guests && guests.length) { %>
                                <ul class="space-y-2">
                                    <% guests.forEach((guest)=> { %>
                                        <li class="text-sm text-gray-800">
                                            <span class="font-medium">
                                                <%= guest.name %>
                                            </span> <span class="text-gray-500">(<%= guest.type %>, Age <%= guest.age %>
                                                        , <%= guest.gender %>)</span>
                                        </li>
                                        <% }) %>
                                </ul>
                                <% } else { %>
                                    <p class="text-sm text-gray-500">No guest details provided.</p>
                                    <% } %>
                        </div>

                        <div>
                            <p class="text-sm font-semibold text-gray-500 mb-1">Primary Contact</p>
                            <p class="text-base font-medium text-gray-900">
                                <%= contactNumber %>
                            </p>
                        </div>

                    </div>
                </div>
            </div>

            <div class="w-full lg:w-5/12">
                <div class="corp-card sticky top-28">
                    <div class="corp-header">
                        <h2 class="text-lg font-semibold text-gray-900">Price Details</h2>
                    </div>
                    <div class="corp-body">

                        <div class="mb-6 pb-6 border-b border-gray-200">
                            <% if (perNightPrices && perNightPrices.length) { %>
                                <% perNightPrices.forEach((night)=> {
                                    let label = new Date(night.date).toLocaleDateString('en-IN', { weekday:'short',
                                    day:'2-digit', month:'short' });
                                    let multiplierTag = '';
                                    if (night.isWeekend) multiplierTag += ' <span
                                        class="text-xs text-gray-500 ml-1">(Weekend rate)</span>';
                                    if (night.seasonalMultiplier && night.seasonalMultiplier !== 1) multiplierTag += '
                                    <span class="text-xs text-gray-500 ml-1">(Seasonal rate)</span>';
                                    if (night.demandMultiplier && night.demandMultiplier !== 1) multiplierTag += ' <span
                                        class="text-xs text-gray-500 ml-1">(High demand)</span>';
                                    %>
                                    <div class="receipt-item">
                                        <span class="text-sm text-gray-600"><%- label %> <%- multiplierTag %></span>
                                        <span class="text-sm text-gray-900">&#8377;<%= night.price.toFixed(2) %></span>
                                    </div>
                                    <% }) %>
                                        <% } %>
                        </div>

                        <div class="mb-6">
                            <div class="receipt-item">
                                <span class="text-base font-medium text-gray-900">Subtotal (<%= numberOfNights %>
                                        nights)</span>
                                <span class="text-base font-medium text-gray-900">&#8377;<%= subtotal.toFixed(2) %>
                                        </span>
                            </div>
                            <div class="receipt-item">
                                <span class="text-sm text-gray-600">Taxes (18% GST)</span>
                                <span class="text-sm text-gray-900">&#8377;<%= gst.toFixed(2) %></span>
                            </div>
                            <div class="receipt-item">
                                <span class="text-sm text-gray-600">Service Fee (5%)</span>
                                <span class="text-sm text-gray-900">&#8377;<%= convenienceFee.toFixed(2) %></span>
                            </div>
                        </div>

                        <div class="receipt-item border-t border-gray-200 pt-4 mb-8">
                            <span class="text-lg font-bold text-gray-900">Total (INR)</span>
                            <span class="text-xl font-bold text-gray-900">&#8377;<%= finalTotal.toFixed(2) %></span>
                        </div>

                        <form id="paymentForm" action="/bookings" method="POST">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn-primary" id="confirmBtn">
                                <span class="btn-text">Pay &#8377;<%= finalTotal.toFixed(2) %></span>
                                <div class="btn-loader"></div>
                            </button>

                            <div class="mt-4 flex items-center justify-center gap-2 text-xs text-gray-500">
                                <i class="fa-solid fa-lock"></i>
                                <span>Payments are secure and encrypted.</span>
                            </div>
                        </form>

                    </div>
                </div>
            </div>

        </div>
    </div>

    <script>
        const confirmBtn = document.getElementById("confirmBtn");
        const form = document.getElementById("paymentForm");

        form.addEventListener("submit", () => {
            confirmBtn.classList.add("loading");
            confirmBtn.disabled = true;
        });
    </script>