<% layout('layouts/boilerplate') -%>

  <style>
    .tab-btn.active {
      color: #111827;
      /* gray-900 */
      border-bottom: 2px solid #111827;
    }

    body.modal-open {
      overflow: hidden;
    }
  </style>

  <div class="min-h-screen bg-gray-50 pb-20 font-sans">

    <div class="bg-white border-b border-gray-200 pt-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center text-gray-700">
            <i class="fa-solid fa-suitcase-rolling text-xl"></i>
          </div>
          <div>
            <h1 class="text-4xl font-black text-gray-900">My Trips</h1>
            <p class="text-base font-medium text-gray-500 mt-2">Track and manage all your reservations</p>
          </div>
        </div>

        <div class="mt-8 flex gap-8 border-b border-gray-200" id="tabs-container">
          <button
            class="tab-btn active pb-3 text-base md:text-lg font-bold text-gray-500 hover:text-gray-900 transition-colors"
            data-filter="upcoming">
            Upcoming
          </button>
          <button
            class="tab-btn pb-3 text-base md:text-lg font-bold text-gray-500 hover:text-gray-900 transition-colors"
            data-filter="completed">
            Completed
          </button>
          <button
            class="tab-btn pb-3 text-base md:text-lg font-bold text-gray-500 hover:text-gray-900 transition-colors"
            data-filter="pending">
            Pending
          </button>
          <button
            class="tab-btn pb-3 text-base md:text-lg font-bold text-gray-500 hover:text-gray-900 transition-colors"
            data-filter="cancelled">
            Cancelled
          </button>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

      <% const now=new Date(); %>
        <% if (!bookings || bookings.length===0) { %>
          <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
            <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6 text-gray-400">
              <i class="fa-solid fa-calendar-xmark text-3xl"></i>
            </div>
            <h3 class="text-2xl font-black text-gray-900 mb-3">No Bookings Yet</h3>
            <p class="text-lg text-gray-500 mb-8">Start exploring amazing places and make your first reservation!</p>
            <a href="/listings"
              class="inline-flex items-center gap-2 px-6 py-3 bg-gray-900 text-white font-bold text-lg rounded-lg hover:bg-black transition-colors shadow-md no-underline hover:no-underline">
              Explore Stays
            </a>
          </div>
          <% } else { %>
            <div class="grid grid-cols-1 gap-6" id="bookings-grid">

              <div id="tab-empty-state" class="bg-white rounded-xl border border-gray-200 p-12 text-center"
                style="display: none;">
                <div
                  class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6 text-gray-400">
                  <i class="fa-solid fa-folder-open text-3xl"></i>
                </div>
                <h3 class="text-2xl font-black text-gray-900 mb-3">No Bookings Found</h3>
                <p class="text-lg text-gray-500 mb-0">You don't have any bookings in this category.</p>
              </div>

              <% bookings.forEach(b=> { %>
                <% const isUpcoming=b.checkIn> now && b.status === "confirmed";
                  const isCompleted = b.checkOut < now && b.status==="confirmed" ; const
                    isCancelled=b.status==="cancelled" ; const isPending=b.status==="pending" ||
                    b.status==="payment_pending" ; const status=isUpcoming ? 'upcoming' : isCompleted ? 'completed' :
                    isCancelled ? 'cancelled' : isPending ? 'pending' : 'other' ; const displayStyle=isUpcoming
                    ? 'block' : 'none' ; %>

                    <div
                      class="booking-card bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm hover:shadow-md transition-shadow"
                      data-status="<%= status %>" style="display: <%= displayStyle %>;">

                      <div class="p-6 sm:p-8">
                        <div class="flex flex-col xl:flex-row justify-between gap-6">

                          <div class="flex-1">
                            <div class="flex items-center gap-3 mb-3">
                              <% if (b.status==="confirmed" ) { %>
                                <span
                                  class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-bold bg-green-50 text-green-700 border border-green-200">
                                  <i class="fa-solid fa-circle-check"></i> Confirmed
                                </span>
                                <% } else if (isPending) { %>
                                  <span
                                    class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-bold bg-yellow-50 text-yellow-700 border border-yellow-200">
                                    <i class="fa-solid fa-clock"></i> Pending Payment
                                  </span>
                                  <% } else { %>
                                    <span
                                      class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-bold bg-red-50 text-red-700 border border-red-200">
                                      <i class="fa-solid fa-circle-xmark"></i> Cancelled
                                    </span>
                                    <% } %>
                                      <span class="text-xs text-gray-400 font-medium font-mono">ID: <%= b._id %></span>
                            </div>

                            <a href="/listings/<%= b.listing._id %>"
                              class="group block mb-1 no-underline hover:no-underline">
                              <h3 class="text-xl font-bold text-gray-900 group-hover:text-gray-600 transition-colors">
                                <%= b.listing.title %>
                              </h3>
                            </a>
                            <p class="text-gray-500 text-sm mb-4"><i
                                class="fa-solid fa-location-dot mr-1 text-gray-400"></i>
                              <%= b.listing.location %>, <%= b.listing.country %>
                            </p>

                            <div
                              class="flex flex-wrap items-center gap-6 text-sm text-gray-700 bg-gray-50 p-4 rounded-lg border border-gray-100">
                              <div>
                                <div class="text-xs text-gray-500 font-semibold uppercase tracking-wider mb-1">Check-in
                                </div>
                                <div class="font-bold">
                                  <%= b.checkIn.toDateString() %>
                                </div>
                              </div>
                              <div class="w-px h-8 bg-gray-300 hidden sm:block"></div>
                              <div>
                                <div class="text-xs text-gray-500 font-semibold uppercase tracking-wider mb-1">Check-out
                                </div>
                                <div class="font-bold">
                                  <%= b.checkOut.toDateString() %>
                                </div>
                              </div>
                              <div class="w-px h-8 bg-gray-300 hidden sm:block"></div>
                              <div>
                                <div class="text-xs text-gray-500 font-semibold uppercase tracking-wider mb-1">Total
                                </div>
                                <div class="font-bold">₹<%= (b.finalTotal || 0).toLocaleString('en-IN') %>
                                </div>
                              </div>
                            </div>
                          </div>

                          <div
                            class="flex flex-col sm:flex-row xl:flex-col justify-end xl:justify-start gap-3 border-t xl:border-t-0 xl:border-l border-gray-100 pt-4 xl:pt-0 xl:pl-6 shrink-0 w-full xl:w-48">

                            <button type="button"
                              class="view-details-btn inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-gray-900 hover:bg-black text-white text-sm font-bold rounded-lg transition-colors w-full"
                              data-modal-target="detailsModal<%= b._id %>">
                              <i class="fa-solid fa-file-lines"></i> Details
                            </button>

                            <% if (b.status==="confirmed" ) { %>
                              <a href="/bookings/<%= b._id %>/download" target="_blank"
                                class="inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-bold rounded-lg transition-colors w-full">
                                <i class="fa-solid fa-download"></i> Invoice
                              </a>
                              <% } %>

                                <% if (b.status !=="cancelled" && b.checkIn> now) { %>
                                  <button type="button"
                                    class="cancel-booking-btn inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-white border border-gray-300 hover:border-red-300 hover:bg-red-50 hover:text-red-600 text-gray-700 text-sm font-bold rounded-lg transition-colors w-full"
                                    data-booking-id="<%= b._id %>">
                                    <i class="fa-solid fa-xmark"></i> Cancel
                                  </button>
                                  <% } %>

                                    <% if (b.status==="cancelled" ) { %>
                                      <button type="button"
                                        class="delete-booking-btn inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-red-50 border border-red-200 hover:bg-red-100 text-red-700 text-sm font-bold rounded-lg transition-colors w-full"
                                        data-booking-id="<%= b._id %>">
                                        <i class="fa-solid fa-trash-can"></i> Remove
                                      </button>
                                      <% } %>

                          </div>

                        </div>
                      </div>
                    </div>

                    <div id="detailsModal<%= b._id %>"
                      class="modal-backdrop fixed inset-0 z-[100] items-center justify-center bg-gray-900/40 backdrop-blur-sm p-4 hidden opacity-0 transition-opacity duration-300">
                      <div
                        class="bg-white rounded-xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-y-auto transform scale-95 transition-transform duration-300 border border-gray-200">

                        <div
                          class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between z-10">
                          <h5 class="text-lg font-bold text-gray-900"><i
                              class="fa-solid fa-file-invoice text-gray-400 mr-2"></i> Booking Summary</h5>
                          <button type="button"
                            class="close-modal-btn text-gray-400 hover:text-gray-600 p-2 rounded-lg hover:bg-gray-100 transition-colors">
                            <i class="fa-solid fa-xmark text-xl pointer-events-none"></i>
                          </button>
                        </div>

                        <div class="p-6 sm:p-8 space-y-8">
                          <div>
                            <h6 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-3">Property
                              Information</h6>
                            <div class="bg-gray-50 rounded-lg p-5 border border-gray-200">
                              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                  <span class="block text-xs font-semibold text-gray-500">Stay</span>
                                  <span class="block text-gray-900 font-bold mt-1">
                                    <%= b.listing.title %>
                                  </span>
                                </div>
                                <div>
                                  <span class="block text-xs font-semibold text-gray-500">Host</span>
                                  <span class="block text-gray-900 font-bold mt-1">
                                    <%= b.listing.owner?.username || "Stayzio Host" %>
                                  </span>
                                </div>
                              </div>
                            </div>
                          </div>

                          <div>
                            <h6 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-3">Guests (<%=
                                b.guests ? b.guests.length : 0 %>)</h6>
                            <% if (b.guests && b.guests.length> 0) { %>
                              <div class="space-y-3">
                                <% b.guests.forEach(g=> { %>
                                  <div class="flex items-center gap-4 bg-white border border-gray-200 p-3 rounded-lg">
                                    <div
                                      class="w-10 h-10 rounded-full bg-gray-50 flex items-center justify-center text-gray-500 shrink-0 border border-gray-200">
                                      <i class="fa-solid <%= g.type === 'Adult' ? 'fa-user' : 'fa-child' %>"></i>
                                    </div>
                                    <div>
                                      <div class="font-bold text-gray-900">
                                        <%= g.name %>
                                      </div>
                                      <div class="text-xs text-gray-500">
                                        <%= g.type %> &bull; Age <%= g.age %> &bull; <%= g.gender %>
                                      </div>
                                    </div>
                                  </div>
                                  <% }) %>
                              </div>
                              <% } else { %>
                                <p class="text-sm text-gray-500 italic">No guest details provided.</p>
                                <% } %>
                          </div>

                          <div>
                            <h6 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-3">Contact
                              Information</h6>
                            <div
                              class="text-sm text-gray-900 font-medium bg-white border border-gray-200 p-4 rounded-lg">
                              <i class="fa-solid fa-phone text-gray-400 mr-2"></i>
                              <%= b.contactNumber || "N/A" %>
                            </div>
                          </div>

                          <% if (b.finalTotal) { const subtotal=b.finalTotal / 1.23; const gst=subtotal * 0.18; const
                            fee=subtotal * 0.05; %>
                            <div>
                              <h6 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-3">Payment
                                Breakdown</h6>
                              <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
                                <div class="p-5 space-y-3 text-sm text-gray-600">
                                  <div class="flex justify-between">
                                    <span>Subtotal</span>
                                    <span class="font-medium text-gray-900 font-mono">₹<%= subtotal.toFixed(2) %></span>
                                  </div>
                                  <div class="flex justify-between">
                                    <span>Taxes (18%)</span>
                                    <span class="font-medium text-gray-900 font-mono">₹<%= gst.toFixed(2) %></span>
                                  </div>
                                  <div class="flex justify-between">
                                    <span>Service Fee (5%)</span>
                                    <span class="font-medium text-gray-900 font-mono">₹<%= fee.toFixed(2) %></span>
                                  </div>
                                  <div class="flex justify-between items-center border-t border-gray-200 pt-3 mt-3">
                                    <span class="font-bold text-gray-900">Total Paid</span>
                                    <span class="text-lg font-black text-gray-900 font-mono">₹<%=
                                        b.finalTotal.toFixed(2) %></span>
                                  </div>
                                </div>
                              </div>
                            </div>
                            <% } %>
                        </div>
                      </div>
                    </div>
                    <% }) %>
            </div>
            <% } %>

    </div>
  </div>

  <div id="cancelModal"
    class="modal-backdrop fixed inset-0 z-[100] items-center justify-center bg-gray-900/40 backdrop-blur-sm p-4 hidden opacity-0 transition-opacity duration-300">
    <div
      class="bg-white rounded-xl shadow-2xl border border-gray-200 w-full max-w-md transform scale-95 transition-transform duration-300 overflow-hidden">
      <div class="p-6 sm:p-8">
        <div
          class="w-12 h-12 bg-red-50 rounded-full flex items-center justify-center mb-4 mx-auto border border-red-100">
          <i class="fa-solid fa-triangle-exclamation text-xl text-red-600"></i>
        </div>
        <h3 class="text-xl font-bold text-gray-900 text-center mb-2">Cancel Booking</h3>
        <p class="text-gray-500 text-center text-sm mb-8">Are you sure you want to cancel this booking? This action
          cannot be undone and standard cancellation policies apply.</p>

        <form id="cancelForm" method="POST" action="">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="flex flex-col-reverse sm:flex-row gap-3 justify-center">
            <button type="button"
              class="close-modal-btn w-full sm:w-auto px-5 py-2.5 bg-white border border-gray-300 text-gray-700 font-bold rounded-lg hover:bg-gray-50 transition-colors">Keep
              Booking</button>
            <button type="submit"
              class="w-full sm:w-auto px-5 py-2.5 bg-red-600 text-white font-bold rounded-lg hover:bg-red-700 shadow-sm transition-colors">Yes,
              Cancel</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div id="deleteModal"
    class="modal-backdrop fixed inset-0 z-[100] items-center justify-center bg-gray-900/40 backdrop-blur-sm p-4 hidden opacity-0 transition-opacity duration-300">
    <div
      class="bg-white rounded-xl shadow-2xl border border-gray-200 w-full max-w-md transform scale-95 transition-transform duration-300 overflow-hidden">
      <div class="p-6 sm:p-8">
        <div
          class="w-12 h-12 bg-red-50 rounded-full flex items-center justify-center mb-4 mx-auto border border-red-100">
          <i class="fa-solid fa-trash-can text-xl text-red-600"></i>
        </div>
        <h3 class="text-xl font-bold text-gray-900 text-center mb-2">Remove Record</h3>
        <p class="text-gray-500 text-center text-sm mb-8">Permanently remove this cancelled booking from your history?
          This cannot be undone.</p>

        <form id="deleteForm" method="POST" action="">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="flex flex-col-reverse sm:flex-row gap-3 justify-center">
            <button type="button"
              class="close-modal-btn w-full sm:w-auto px-5 py-2.5 bg-white border border-gray-300 text-gray-700 font-bold rounded-lg hover:bg-gray-50 transition-colors">Cancel</button>
            <button type="submit"
              class="w-full sm:w-auto px-5 py-2.5 bg-red-600 text-white font-bold rounded-lg hover:bg-red-700 shadow-sm transition-colors">Yes,
              Remove</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('.tab-btn');
      const cards = document.querySelectorAll('.booking-card');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          tabs.forEach(t => t.classList.remove('active', 'text-gray-900', 'border-gray-900'));
          tab.classList.add('active');

          const filter = tab.dataset.filter;

          let visibleCount = 0;
          cards.forEach(card => {
            if (card.dataset.status === filter) {
              card.style.display = 'block';
              visibleCount++;
            } else {
              card.style.display = 'none';
            }
          });

          const emptyState = document.getElementById('tab-empty-state');
          if (emptyState) {
            if (visibleCount === 0) {
              emptyState.style.display = 'block';
            } else {
              emptyState.style.display = 'none';
            }
          }
        });
      });

      const initialTab = document.querySelector('.tab-btn.active');
      if (initialTab) {
        initialTab.click();
      }

      const body = document.body;
      let activeModal = null;

      const openModal = (modalEl) => {
        if (!modalEl) return;
        activeModal = modalEl;
        modalEl.classList.remove('hidden');
        modalEl.classList.add('flex');
        body.classList.add('modal-open');
        setTimeout(() => {
          modalEl.classList.remove('opacity-0');
          modalEl.querySelector('.transform').classList.remove('scale-95');
          modalEl.querySelector('.transform').classList.add('scale-100');
        }, 10);
      };

      const closeModal = (modalEl) => {
        if (!modalEl) return;
        // Animate out
        modalEl.classList.add('opacity-0');
        modalEl.querySelector('.transform').classList.remove('scale-100');
        modalEl.querySelector('.transform').classList.add('scale-95');
        setTimeout(() => {
          modalEl.classList.add('hidden');
          modalEl.classList.remove('flex');
          body.classList.remove('modal-open');
          if (activeModal === modalEl) activeModal = null;
        }, 300);
      };

      document.querySelectorAll('.close-modal-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const modal = e.target.closest('.modal-backdrop');
          closeModal(modal);
        });
      });

      document.querySelectorAll('.modal-backdrop').forEach(backdrop => {
        backdrop.addEventListener('click', (e) => {
          if (e.target === backdrop) {
            closeModal(backdrop);
          }
        });
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && activeModal) {
          closeModal(activeModal);
        }
      });

      document.querySelectorAll('.view-details-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = btn.getAttribute('data-modal-target');
          const modal = document.getElementById(targetId);
          openModal(modal);
        });
      });

      const cancelModalEl = document.getElementById('cancelModal');
      const cancelForm = document.getElementById('cancelForm');
      document.querySelectorAll('.cancel-booking-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const bookingId = btn.getAttribute('data-booking-id');
          cancelForm.action = `/bookings/${bookingId}/cancel`;
          openModal(cancelModalEl);
        });
      });

      const deleteModalEl = document.getElementById('deleteModal');
      const deleteForm = document.getElementById('deleteForm');
      document.querySelectorAll('.delete-booking-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const bookingId = btn.getAttribute('data-booking-id');
          deleteForm.action = `/bookings/${bookingId}/delete`;
          openModal(deleteModalEl);
        });
      });

    });
  </script>