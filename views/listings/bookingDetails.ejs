<% layout("/layouts/infoBoilerplate") %>

    <style>
        .input-field {
            border: 1px solid #d1d5db;
            border-radius: 0.5rem;
            padding: 0.75rem 1rem;
            background-color: #ffffff;
            color: #111827;
            font-size: 1rem;
            width: 100%;
            transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
        }

        .input-field:focus {
            border-color: #fe424d;
            box-shadow: 0 0 0 3px rgba(254, 66, 77, 0.1);
            outline: none;
        }

        .stepper {
            display: flex;
            align-items: center;
            margin-bottom: 2rem;
            border-bottom: 1px solid #e5e7eb;
            padding-bottom: 1rem;
        }

        .step-active {
            color: #111827;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .step-inactive {
            color: #9ca3af;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .step-divider {
            color: #d1d5db;
            margin: 0 1rem;
        }

        .corp-card {
            background-color: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 0.5rem;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .btn-primary {
            background-color: #fe424d;
            color: #ffffff;
            border: none;
            border-radius: 0.5rem;
            padding: 0.75rem 1.5rem;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: background-color 0.15s ease-in-out;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-primary:hover {
            background-color: #e63946;
        }

        .btn-primary:disabled {
            opacity: 0.65;
            cursor: not-allowed;
        }

        .invalid-feedback {
            display: none;
            color: #dc2626;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }

        .was-validated input:invalid,
        .was-validated select:invalid {
            border-color: #dc2626;
        }

        .was-validated input:invalid~.invalid-feedback,
        .was-validated select:invalid~.invalid-feedback {
            display: block;
        }

        .btn-loader {
            display: none;
            width: 1.25rem;
            height: 1.25rem;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-top-color: #ffffff;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        .btn-primary.loading .btn-text {
            display: none;
        }

        .btn-primary.loading .btn-loader {
            display: block;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-24 bg-white min-h-screen">

        <div class="stepper">
            <div class="step-active">
                <span
                    class="w-6 h-6 rounded-full bg-gray-900 text-white flex items-center justify-center text-xs font-bold">1</span>
                Guest Details
            </div>
            <div class="step-divider"><i class="fa-solid fa-chevron-right text-xs"></i></div>
            <div class="step-inactive">
                <span
                    class="w-6 h-6 rounded-full border-2 border-gray-300 text-gray-400 flex items-center justify-center text-xs font-bold">2</span>
                Confirm & Pay
            </div>
        </div>

        <div class="mb-8">
            <h1 class="text-3xl font-semibold text-gray-900 mb-2">Who is coming?</h1>
            <p class="text-gray-600">Enter the details for all guests staying at the property. The primary contact will
                receive the booking confirmation.</p>
        </div>

        <form action="/bookings/details" method="POST" class="needs-validation" novalidate>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="corp-card">
                <h2 class="text-lg font-semibold text-gray-900 mb-4">Number of Guests</h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label for="adults" class="block text-sm font-medium text-gray-700 mb-1">Adults (18+)</label>
                        <input type="number" id="adults" class="input-field" value="1" min="1" max="8" required>
                    </div>
                    <div>
                        <label for="children" class="block text-sm font-medium text-gray-700 mb-1">Children
                            (0-17)</label>
                        <input type="number" id="children" class="input-field" value="0" min="0" max="6" required>
                    </div>
                </div>
            </div>

            <div id="guest-fields-container"></div>

            <div class="corp-card">
                <h2 class="text-lg font-semibold text-gray-900 mb-4">Primary Contact</h2>
                <div>
                    <label for="contactNumber" class="block text-sm font-medium text-gray-700 mb-1">Mobile
                        Number</label>
                    <input type="tel" id="contactNumber" name="contactNumber" class="input-field"
                        placeholder="e.g., +91 9876543210" required>
                    <div class="invalid-feedback">Please provide a valid contact number.</div>
                    <p class="text-xs text-gray-500 mt-2">We'll use this number to send you booking updates and
                        instructions.</p>
                </div>
            </div>

            <div class="mt-8 flex justify-end">
                <button type="submit" class="btn-primary w-full md:w-auto" id="submitBtn">
                    <span class="btn-text">Continue to Payment</span>
                    <div class="btn-loader"></div>
                </button>
            </div>
        </form>
    </div>

    <script>
        const MAX_ADULTS = 8;
        const MAX_CHILDREN = 5;
        const MAX_TOTAL_GUESTS = 13;

        const adultsInput = document.getElementById('adults');
        const childrenInput = document.getElementById('children');
        const container = document.getElementById('guest-fields-container');
        const submitButton = document.getElementById('submitBtn');

        function handleGuestChange(event) {
            let adults = parseInt(adultsInput.value, 10) || 0;
            let children = parseInt(childrenInput.value, 10) || 0;

            if (adults > MAX_ADULTS) { adultsInput.value = MAX_ADULTS; adults = MAX_ADULTS; }
            if (children > MAX_CHILDREN) { childrenInput.value = MAX_CHILDREN; children = MAX_CHILDREN; }

            if (adults + children > MAX_TOTAL_GUESTS) {
                alert(`You cannot select more than ${MAX_TOTAL_GUESTS} guests in total.`);
                const overage = (adults + children) - MAX_TOTAL_GUESTS;
                event.target.value = parseInt(event.target.value, 10) - overage;
            }

            generateGuestFields();
        }

        function generateGuestFields() {
            container.innerHTML = '';
            const adults = parseInt(adultsInput.value) || 0;
            const children = parseInt(childrenInput.value) || 0;

            for (let i = 0; i < adults; i++) container.appendChild(createGuestFieldElement('Adult', i));
            for (let i = 0; i < children; i++) container.appendChild(createGuestFieldElement('Child', i));
        }

        function createGuestFieldElement(type, index) {
            const offsetIndex = type === 'Adult' ? index : parseInt(adultsInput.value) + index;
            const div = document.createElement('div');
            div.className = 'corp-card';

            div.innerHTML = `
            <div class="flex items-center justify-between mb-4 border-b border-gray-100 pb-3">
                <h3 class="text-base font-semibold text-gray-900">${type} ${index + 1}</h3>
            </div>
            
            <input type="hidden" name="guests[${offsetIndex}][type]" value="${type}">
            
            <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
                <div class="md:col-span-6">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
                    <input type="text" name="guests[${offsetIndex}][name]" class="input-field" required>
                    <div class="invalid-feedback">Name is required.</div>
                </div>
                <div class="md:col-span-3">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Age</label>
                    <input type="number" name="guests[${offsetIndex}][age]" class="input-field"
                        min="${type === 'Adult' ? 18 : 0}" max="${type === 'Adult' ? 120 : 17}" required>
                    <div class="invalid-feedback">Valid age required.</div>
                </div>
                <div class="md:col-span-3">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Gender</label>
                    <select name="guests[${offsetIndex}][gender]" class="input-field" required>
                        <option value="" selected disabled>Select...</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                    <div class="invalid-feedback">Please select gender.</div>
                </div>
            </div>
        `;
            return div;
        }

        (function () {
            'use strict';
            window.addEventListener('load', function () {
                var forms = document.getElementsByClassName('needs-validation');
                Array.prototype.filter.call(forms, function (form) {
                    form.addEventListener('submit', function (event) {
                        if (form.checkValidity() === false) {
                            event.preventDefault();
                            event.stopPropagation();
                        } else {
                            submitButton.classList.add('loading');
                            submitButton.disabled = true;
                        }
                        form.classList.add('was-validated');
                    }, false);
                });
            }, false);
        })();

        adultsInput.addEventListener('input', handleGuestChange);
        childrenInput.addEventListener('input', handleGuestChange);
        generateGuestFields();
    </script>