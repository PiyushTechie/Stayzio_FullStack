<% layout('layouts/infoBoilerplate') -%>

    <div class="bg-gradient-to-r from-gray-900 to-gray-800 pt-20 pb-16 relative overflow-hidden">
        <div
            class="absolute top-0 left-0 w-full h-full opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]">
        </div>
        <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10 text-center" data-aos="fade-up">
            <h1 class="text-4xl md:text-5xl font-black text-white mb-4 tracking-tight">
                <i class="fas fa-headset text-[#fe424d] mr-3"></i> Help Center
            </h1>
            <p class="text-xl text-gray-300 max-w-2xl mx-auto">We are here to help. Find answers or reach out to our
                24/7 support team.</p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
        <div class="flex flex-col lg:flex-row gap-12">

            <div class="lg:w-1/4 hidden lg:block">
                <div
                    class="sticky top-28 bg-white border border-gray-100 rounded-3xl p-6 shadow-[0_8px_30px_rgb(0,0,0,0.04)]">
                    <h3 class="font-bold text-gray-900 mb-4 uppercase tracking-wider text-sm flex items-center gap-2">
                        <i class="fas fa-list text-[#fe424d]"></i> Contents
                    </h3>
                    <nav class="sticky-nav flex flex-col space-y-1">
                        <a href="#faq-preview"
                            class="px-4 py-2 text-sm text-gray-500 rounded-lg border-l-2 border-transparent hover:bg-gray-50 transition-colors">Quick
                            Answers</a>
                        <a href="#contact-form"
                            class="px-4 py-2 text-sm text-gray-500 rounded-lg border-l-2 border-transparent hover:bg-gray-50 transition-colors">Send
                            a Message</a>
                        <a href="#direct-contact"
                            class="px-4 py-2 text-sm text-gray-500 rounded-lg border-l-2 border-transparent hover:bg-gray-50 transition-colors">Direct
                            Contact</a>
                    </nav>
                </div>
            </div>

            <div
                class="lg:w-3/4 prose-content bg-white p-8 md:p-12 rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100">

                <div id="faq-preview">
                    <h2><i class="fas fa-search"></i> Quick Answers</h2>
                    <p>Before sending a message, check if your question has already been answered:</p>
                    <div class="space-y-4 mt-6">
                        <div class="p-5 border border-gray-100 rounded-xl bg-gray-50">
                            <h4 class="font-bold text-gray-900 mb-2">How do I cancel a booking?</h4>
                            <p class="text-gray-600 mb-0">Go to your account, select 'Trips', click on the reservation,
                                and select 'Cancel Reservation'. Please review the cancellation policy first.</p>
                        </div>
                        <div class="p-5 border border-gray-100 rounded-xl bg-gray-50">
                            <h4 class="font-bold text-gray-900 mb-2">When will I be charged?</h4>
                            <p class="text-gray-600 mb-0">Your payment method will be charged in full as soon as the
                                host accepts your booking request.</p>
                        </div>
                    </div>
                    <div class="mt-6">
                        <a href="/faq" class="text-[#fe424d] font-semibold hover:underline">View all FAQs &rarr;</a>
                    </div>
                </div>

                <div id="contact-form" class="mt-12">
                    <h2><i class="fas fa-paper-plane"></i> Send a Message</h2>
                    <p>Can't find what you're looking for? Send us a message and our support team will get back to you
                        within 24 hours.</p>

                    <form action="/contact" method="POST" class="mt-8">
                        <input type="hidden" name="_csrf"
                            value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                            <div>
                                <label for="name" class="block text-sm font-semibold text-gray-700 mb-2">Your
                                    Name</label>
                                <input type="text" id="name" name="name" required
                                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#fe424d] focus:border-transparent outline-none transition-all">
                            </div>
                            <div>
                                <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">Email
                                    Address</label>
                                <input type="email" id="email" name="email" required
                                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#fe424d] focus:border-transparent outline-none transition-all">
                            </div>
                        </div>

                        <div class="mb-6">
                            <label for="subject" class="block text-sm font-semibold text-gray-700 mb-2">Subject</label>
                            <input type="text" id="subject" name="subject" required
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#fe424d] focus:border-transparent outline-none transition-all">
                        </div>

                        <div class="mb-6">
                            <label for="message" class="block text-sm font-semibold text-gray-700 mb-2">Message</label>
                            <textarea id="message" name="message" rows="5" required
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#fe424d] focus:border-transparent outline-none transition-all"></textarea>
                        </div>

                        <button type="submit"
                            class="bg-[#fe424d] hover:bg-[#e63946] text-white font-bold py-3 px-8 rounded-xl transition-all transform hover:-translate-y-1 hover:shadow-lg w-full md:w-auto">
                            Send Message
                        </button>
                    </form>
                </div>

                <div id="direct-contact" class="mt-12">
                    <h2><i class="fas fa-phone-alt"></i> Direct Contact</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
                        <div class="bg-gray-50 p-6 rounded-2xl border border-gray-200 flex items-start gap-4">
                            <div
                                class="w-12 h-12 bg-red-100 text-[#fe424d] rounded-full flex items-center justify-center text-xl shrink-0">
                                <i class="fas fa-phone"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-900">Call Us</h4>
                                <p class="text-sm text-gray-500 mb-2">Available 24/7 for urgent matters.</p>
                                <p class="font-semibold text-gray-900">1-800-STAYZIO-HELP</p>
                            </div>
                        </div>

                        <div class="bg-gray-50 p-6 rounded-2xl border border-gray-200 flex items-start gap-4">
                            <div
                                class="w-12 h-12 bg-red-100 text-[#fe424d] rounded-full flex items-center justify-center text-xl shrink-0">
                                <i class="fas fa-envelope"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-900">Email Us</h4>
                                <p class="text-sm text-gray-500 mb-2">We aim to respond within 24 hours.</p>
                                <a href="mailto:support@stayzio.com"
                                    class="font-semibold text-[#fe424d] hover:underline">support@stayzio.com</a>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>