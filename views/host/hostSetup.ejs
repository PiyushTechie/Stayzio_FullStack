<% layout('layouts/boilerplate') -%>

  <div class="min-h-screen bg-gray-50 pt-28 pb-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-12">
        <h1 class="text-4xl font-black text-gray-900 mb-4">Become a Stayzio Host</h1>
        <p class="text-lg text-gray-600">Join thousands of hosts earning extra income by sharing their space securely.
        </p>
      </div>

      <div class="mb-12">
        <div class="flex items-center justify-between relative max-w-3xl mx-auto">
          <div class="absolute left-0 top-1/2 transform -translate-y-1/2 w-full h-1 bg-gray-200 -z-10"></div>
          <div id="progress-bar"
            class="absolute left-0 top-1/2 transform -translate-y-1/2 h-1 bg-gray-900 transition-all duration-300 -z-10"
            style="width: 0%;"></div>

          <div class="step-indicator flex flex-col items-center gap-2 relative z-10" data-target="1">
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-white bg-gray-900 border-4 border-white transition-colors duration-300 shadow-sm">
              1</div>
            <span class="text-xs font-bold uppercase tracking-wider text-gray-900 hidden sm:block">Basic Info</span>
          </div>

          <div class="step-indicator flex flex-col items-center gap-2 relative z-10" data-target="2">
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-gray-400 bg-gray-100 border-4 border-white transition-colors duration-300">
              2</div>
            <span class="text-xs font-bold uppercase tracking-wider text-gray-400 hidden sm:block">Verification</span>
          </div>

          <div class="step-indicator flex flex-col items-center gap-2 relative z-10" data-target="3">
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-gray-400 bg-gray-100 border-4 border-white transition-colors duration-300">
              3</div>
            <span class="text-xs font-bold uppercase tracking-wider text-gray-400 hidden sm:block">Preferences</span>
          </div>

          <div class="step-indicator flex flex-col items-center gap-2 relative z-10" data-target="4">
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-gray-400 bg-gray-100 border-4 border-white transition-colors duration-300">
              4</div>
            <span class="text-xs font-bold uppercase tracking-wider text-gray-400 hidden sm:block">Review</span>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
        <form id="hostSetupForm" action="/host/setup" method="POST" enctype="multipart/form-data" class="p-8 sm:p-12">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="step-content block" data-step="1">
            <div class="mb-8">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Tell us about yourself</h2>
              <p class="text-gray-500">Let's start with the basics to set up your host profile securely.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="md:col-span-2">
                <label class="block text-sm font-bold text-gray-700 mb-2">Full Name *</label>
                <input type="text" name="name"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-gray-900 focus:border-gray-900 transition-colors"
                  placeholder="John Doe" required>
              </div>

              <div class="md:col-span-2">
                <label class="block text-sm font-bold text-gray-700 mb-2">Phone Number *</label>
                <div class="flex">
                  <span
                    class="inline-flex items-center px-4 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 font-bold">+91</span>
                  <input type="tel" name="phone"
                    class="flex-1 px-4 py-3 rounded-r-lg border border-gray-300 focus:ring-2 focus:ring-gray-900 focus:border-gray-900 transition-colors"
                    placeholder="98765 43210" required>
                </div>
              </div>

              <div class="md:col-span-2">
                <label class="block text-sm font-bold text-gray-700 mb-2">Profile Photo *</label>
                <div
                  class="border-2 border-dashed border-gray-300 rounded-xl p-8 text-center hover:bg-gray-50 hover:border-gray-400 transition-colors cursor-pointer relative"
                  id="photoDropzone">
                  <input type="file" name="profilePhoto" id="profilePhotoInput"
                    class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" accept="image/*" required>
                  <div id="photoPreviewContainer" class="hidden flex-col items-center gap-4">
                    <img id="photoPreview" class="w-32 h-32 rounded-full object-cover border-4 border-white shadow-md"
                      src="" alt="Preview">
                    <p
                      class="text-sm font-bold text-gray-900 bg-white border border-gray-200 px-4 py-2 rounded-lg shadow-sm">
                      Click to change photo</p>
                  </div>
                  <div id="photoPlaceholder" class="flex flex-col items-center gap-3">
                    <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center text-gray-400">
                      <i class="fa-solid fa-camera text-2xl"></i>
                    </div>
                    <p class="text-gray-900 font-bold">Click or drag photo here</p>
                    <p class="text-sm text-gray-500">JPG, PNG up to 5MB</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="step-content hidden" data-step="2">
            <div class="mb-8">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Verify your identity</h2>
              <p class="text-gray-500">This helps us keep Stayzio secure. Your data is encrypted.</p>
            </div>

            <div class="grid grid-cols-1 gap-6">
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">ID Document Type *</label>
                <select name="idType"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-gray-900 focus:border-gray-900 transition-colors"
                  required>
                  <option value="">Select document type...</option>
                  <option value="passport">Passport</option>
                  <option value="drivers_license">Driver's License</option>
                  <option value="national_id">National ID Card</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">Upload ID Document *</label>
                <div
                  class="border-2 border-dashed border-gray-300 rounded-xl p-8 text-center hover:bg-gray-50 hover:border-gray-400 transition-colors cursor-pointer relative"
                  id="idDropzone">
                  <input type="file" name="idProof" id="idProofInput"
                    class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" accept="image/*,.pdf" required>
                  <div id="idPreviewContainer" class="hidden flex-col items-center gap-4">
                    <div class="w-full max-w-sm h-48 bg-gray-100 rounded-lg overflow-hidden border border-gray-200">
                      <img id="idPreview" class="w-full h-full object-contain" src="" alt="ID Preview">
                    </div>
                    <p
                      class="text-sm font-bold text-gray-900 bg-white border border-gray-200 px-4 py-2 rounded-lg shadow-sm">
                      Click to change document</p>
                  </div>
                  <div id="idPlaceholder" class="flex flex-col items-center gap-3">
                    <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center text-gray-400">
                      <i class="fa-solid fa-id-card text-2xl"></i>
                    </div>
                    <p class="text-gray-900 font-bold">Upload a clear photo of your ID</p>
                    <p class="text-sm text-gray-500">JPG, PNG or PDF up to 10MB</p>
                  </div>
                </div>
              </div>

              <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 flex gap-4 mt-2">
                <i class="fa-solid fa-shield-halved text-blue-600 text-xl mt-0.5"></i>
                <div>
                  <h4 class="text-sm font-bold text-blue-900">Bank-level Security</h4>
                  <p class="text-sm text-blue-800 mt-1">Your identification documents are encrypted in transit and at
                    rest. They are only used for verification.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="step-content hidden" data-step="3">
            <div class="mb-8">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Your preferences</h2>
              <p class="text-gray-500">Help us personalize your hosting experience.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">Country *</label>
                <select name="country"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-gray-900 focus:border-gray-900 transition-colors"
                  required>
                  <option value="">Select country...</option>
                  <option value="US">United States</option>
                  <option value="IN">India</option>
                  <option value="UK">United Kingdom</option>
                  <option value="CA">Canada</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">City *</label>
                <input type="text" name="city"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-gray-900 focus:border-gray-900 transition-colors"
                  required>
              </div>

              <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">Postal Code *</label>
                <input type="text" name="postalCode"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-gray-900 focus:border-gray-900 transition-colors"
                  required>
              </div>

              <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">Preferred Language *</label>
                <select name="language"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-gray-900 focus:border-gray-900 transition-colors"
                  required>
                  <option value="en">English</option>
                  <option value="es">Spanish</option>
                  <option value="hi">Hindi</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">Currency *</label>
                <select name="currency"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-gray-900 focus:border-gray-900 transition-colors"
                  required>
                  <option value="USD">USD</option>
                  <option value="EUR">EUR</option>
                  <option value="INR">INR</option>
                  <option value="GBP">GBP</option>
                </select>
              </div>

              <div class="md:col-span-2">
                <label class="block text-sm font-bold text-gray-700 mb-2">About You *</label>
                <textarea name="bio" rows="4"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-gray-900 focus:border-gray-900 transition-colors"
                  placeholder="Tell guests about yourself..." required></textarea>
              </div>
            </div>
          </div>

          <div class="step-content hidden" data-step="4">
            <div class="mb-8">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Review your application</h2>
              <p class="text-gray-500">Please review your details before submitting securely.</p>
            </div>

            <div class="bg-gray-50 rounded-xl p-6 border border-gray-200 mb-6">
              <h3 class="text-lg font-bold text-gray-900 mb-4">Terms & Conditions</h3>
              <p class="text-sm text-gray-600 mb-4">By submitting this application, you agree to Stayzio's Host Terms of
                Service, Privacy Policy, and Nondiscrimination Policy. Your data is protected by industry-standard
                encryption.</p>

              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" id="termsCheck"
                  class="w-5 h-5 mt-0.5 text-gray-900 border-gray-300 rounded focus:ring-gray-900" required>
                <span class="text-sm font-bold text-gray-900">I agree to the Terms and Conditions</span>
              </label>
            </div>
          </div>

          <div class="flex items-center justify-between pt-8 mt-8 border-t border-gray-100">
            <button type="button" id="prevBtn"
              class="px-6 py-3 rounded-lg font-bold text-gray-700 bg-gray-100 hover:bg-gray-200 transition-colors hidden">
              <i class="fa-solid fa-arrow-left mr-2"></i> Previous
            </button>

            <div class="flex-1"></div>

            <button type="button" id="nextBtn"
              class="px-8 py-3 rounded-lg font-bold text-white bg-gray-900 hover:bg-black transition-colors shadow-md">
              Next <i class="fa-solid fa-arrow-right ml-2"></i>
            </button>

            <button type="submit" id="submitBtn"
              class="px-8 py-3 rounded-lg font-bold text-white bg-gray-900 hover:bg-black transition-colors shadow-md hidden">
              <i class="fa-solid fa-shield-halved mr-2"></i> Submit Securely
            </button>
          </div>

        </form>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      let currentStep = 1;
      const totalSteps = 4;

      const form = document.getElementById('hostSetupForm');
      const stepContents = document.querySelectorAll('.step-content');
      const stepIndicators = document.querySelectorAll('.step-indicator');
      const progressBar = document.getElementById('progress-bar');

      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');
      const submitBtn = document.getElementById('submitBtn');

      const setupImagePreview = (inputId, containerId, placeholderId, imgId) => {
        const input = document.getElementById(inputId);
        const container = document.getElementById(containerId);
        const placeholder = document.getElementById(placeholderId);
        const img = document.getElementById(imgId);

        input.addEventListener('change', (e) => {
          const file = e.target.files[0];
          if (file) {
            const url = URL.createObjectURL(file);
            img.src = url;
            container.classList.remove('hidden');
            container.classList.add('flex');
            placeholder.classList.add('hidden');
          }
        });
      };

      setupImagePreview('profilePhotoInput', 'photoPreviewContainer', 'photoPlaceholder', 'photoPreview');
      setupImagePreview('idProofInput', 'idPreviewContainer', 'idPlaceholder', 'idPreview');

      const validateStep = (step) => {
        const content = document.querySelector(`.step-content[data-step="${step}"]`);
        const inputs = content.querySelectorAll('input:required, select:required, textarea:required');
        let isValid = true;

        inputs.forEach(input => {
          if (!input.value.trim() && input.type !== 'checkbox') {
            isValid = false;
            input.classList.add('border-red-500', 'bg-red-50');
          } else if (input.type === 'checkbox' && !input.checked) {
            isValid = false;
            input.classList.add('ring-2', 'ring-red-500');
          } else {
            input.classList.remove('border-red-500', 'bg-red-50', 'ring-2', 'ring-red-500');
          }
        });
        return isValid;
      };

      const updateUI = () => {
        stepContents.forEach(c => {
          if (parseInt(c.dataset.step) === currentStep) {
            c.classList.remove('hidden');
            c.classList.add('block');
          } else {
            c.classList.remove('block');
            c.classList.add('hidden');
          }
        });

        stepIndicators.forEach(ind => {
          const step = parseInt(ind.dataset.target);
          const circle = ind.querySelector('div');
          const text = ind.querySelector('span');

          if (step === currentStep) {
            circle.className = 'w-10 h-10 rounded-full flex items-center justify-center font-bold text-white bg-gray-900 border-4 border-white transition-colors duration-300 shadow-sm z-10 relative';
            text.className = 'text-xs font-bold uppercase tracking-wider text-gray-900 hidden sm:block';
          } else if (step < currentStep) {
            circle.className = 'w-10 h-10 rounded-full flex items-center justify-center font-bold text-white bg-gray-900 border-4 border-white transition-colors duration-300 z-10 relative';
            circle.innerHTML = '<i class="fa-solid fa-check"></i>';
            text.className = 'text-xs font-bold uppercase tracking-wider text-gray-900 hidden sm:block';
          } else {
            circle.className = 'w-10 h-10 rounded-full flex items-center justify-center font-bold text-gray-400 bg-gray-100 border-4 border-white transition-colors duration-300 z-10 relative';
            circle.innerHTML = step;
            text.className = 'text-xs font-bold uppercase tracking-wider text-gray-400 hidden sm:block';
          }
        });

        const progress = ((currentStep - 1) / (totalSteps - 1)) * 100;
        progressBar.style.width = `${progress}%`;

        if (currentStep === 1) {
          prevBtn.classList.add('hidden');
        } else {
          prevBtn.classList.remove('hidden');
        }

        if (currentStep === totalSteps) {
          nextBtn.classList.add('hidden');
          submitBtn.classList.remove('hidden');
        } else {
          nextBtn.classList.remove('hidden');
          submitBtn.classList.add('hidden');
        }
      };

      nextBtn.addEventListener('click', () => {
        if (validateStep(currentStep)) {
          if (currentStep < totalSteps) {
            currentStep++;
            updateUI();
          }
        }
      });

      prevBtn.addEventListener('click', () => {
        if (currentStep > 1) {
          currentStep--;
          updateUI();
        }
      });

      form.addEventListener('input', (e) => {
        if (e.target.required) {
          if (e.target.type === 'checkbox' && e.target.checked) {
            e.target.classList.remove('ring-2', 'ring-red-500');
          } else if (e.target.value.trim() !== '') {
            e.target.classList.remove('border-red-500', 'bg-red-50');
          }
        }
      });
    });
  </script>