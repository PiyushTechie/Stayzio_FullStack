<% layout('layouts/hostBoilerplate') -%>
<script>
  window.currentPath = '/host/listings';
</script>

<div class="mb-4 flex items-center gap-2 text-sm text-gray-500 font-medium">
  <a href="/host/listings" class="hover:text-gray-900 transition-colors">My Listings</a>
  <i class="fa-solid fa-chevron-right text-[10px]"></i>
  <span class="text-gray-900 truncate max-w-[200px] sm:max-w-none"><%= listing.title %></span>
</div>

<div class="flex flex-col sm:flex-row sm:items-start justify-between mb-8 gap-4">
  <div class="flex-1">
    <h1 class="text-3xl font-bold text-gray-900 tracking-tight mb-2"><%= listing.title %></h1>
    <p class="text-gray-500 flex items-center gap-1.5">
      <i class="fa-solid fa-location-dot"></i>
      <%= listing.location %>
    </p>
  </div>
  <div class="flex flex-wrap gap-3">
    <a href="/host/listings/<%= listing._id %>/pricing" class="inline-flex items-center justify-center gap-2 bg-gradient-to-br from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white px-5 py-2.5 rounded-xl font-medium transition-all shadow-sm">
      <i class="fa-solid fa-tags"></i>
      <span>Dynamic Pricing</span>
    </a>
    <a href="/listings/<%= listing._id %>/edit" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 text-gray-700 border border-gray-200 px-5 py-2.5 rounded-xl font-medium transition-colors shadow-sm">
      <i class="fa-solid fa-pen-to-square"></i>
      <span>Edit</span>
    </a>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden h-[300px] md:h-[400px]">
      <% if(listing.image && listing.image.url) { %>
        <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="w-full h-full object-cover">
      <% } else { %>
        <div class="w-full h-full bg-gray-100 flex items-center justify-center text-gray-400">
          <i class="fa-solid fa-image text-5xl"></i>
        </div>
      <% } %>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 sm:p-8">
      <h3 class="text-xl font-bold text-gray-900 mb-4">Property Details</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
        <div>
          <p class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-1">Base Price</p>
          <p class="text-2xl font-bold text-gray-900">₹<%= listing.price.toLocaleString("en-IN") %> <span class="text-sm font-medium text-gray-500 normal-case">/ night</span></p>
        </div>
        <div>
          <p class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-1">Category</p>
          <p class="text-lg font-medium text-gray-900 capitalize"><%= listing.category || 'Standard' %></p>
        </div>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-2">Description</p>
        <p class="text-gray-600 leading-relaxed"><%= listing.description %></p>
      </div>
    </div>
  </div>

  <div class="space-y-6">
    
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
      <h3 class="text-lg font-bold text-gray-900 mb-4">Performance</h3>
      
      <div class="space-y-4">
        <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl border border-gray-100">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center">
              <i class="fa-solid fa-calendar-check"></i>
            </div>
            <span class="font-medium text-gray-700">Total Bookings</span>
          </div>
          <span class="font-bold text-gray-900 text-lg"><%= typeof listing.bookingCount !== 'undefined' ? listing.bookingCount : '0' %></span>
        </div>
        
      </div>
    </div>

    <div class="bg-gradient-to-br from-gray-900 to-gray-800 rounded-2xl shadow-sm p-6 text-white relative overflow-hidden">
      <div class="absolute -right-4 -top-4 w-24 h-24 bg-white/10 rounded-full blur-xl"></div>
      <h3 class="text-lg font-bold mb-4 relative z-10">Guest View</h3>
      <p class="text-gray-400 text-sm mb-6 relative z-10">See how this listing appears to guests browsing the platform.</p>
      <a href="/listings/<%= listing._id %>" class="block w-full bg-white text-gray-900 text-center px-4 py-2.5 rounded-xl font-bold hover:bg-gray-100 transition-colors shadow-sm relative z-10">
        Preview Public Page
      </a>
    </div>

  </div>
</div>