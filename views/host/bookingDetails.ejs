<% layout('layouts/hostBoilerplate') -%>
<script>
  window.currentPath = '/host/bookings';
</script>

<div class="mb-4 flex items-center gap-2 text-sm text-gray-500 font-medium">
  <a href="/host/bookings" class="hover:text-gray-900 transition-colors">Bookings</a>
  <i class="fa-solid fa-chevron-right text-[10px]"></i>
  <span class="text-gray-900">#<%= booking._id.toString().substring(0, 8) %></span>
</div>

<div class="flex flex-col sm:flex-row sm:items-end justify-between mb-8 gap-4">
  <div>
    <h1 class="text-3xl font-bold text-gray-900 tracking-tight mb-2">Booking Details</h1>
    <p class="text-gray-500">View complete reservation details.</p>
  </div>
  <a href="/host/bookings" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 text-gray-700 border border-gray-200 px-5 py-2.5 rounded-xl font-medium transition-colors shadow-sm">
    <i class="fa-solid fa-arrow-left"></i>
    <span>Back to Bookings</span>
  </a>
</div>

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden max-w-4xl mx-auto">
  
  <div class="p-6 md:p-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      
      <div class="space-y-6">
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Booking ID</p>
          <p class="font-medium text-gray-900 font-mono bg-gray-50 px-3 py-1.5 rounded-lg inline-block border border-gray-200"><%= booking._id %></p>
        </div>
        
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Property</p>
          <p class="font-bold text-gray-900 flex items-center gap-2">
            <i class="fa-solid fa-house-chimney text-gray-400"></i>
            <%= booking.listing.title %>
          </p>
        </div>

        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Guest</p>
          <div class="flex items-center gap-3 mt-2">
            <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center text-gray-500 shrink-0">
              <i class="fa-solid fa-user"></i>
            </div>
            <div>
              <p class="font-bold text-gray-900"><%= booking.user.username %></p>
              <p class="text-sm text-gray-500"><%= booking.user.email %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-6">
        <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
          <div class="flex items-center justify-between mb-4">
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Check-in</p>
              <p class="font-bold text-gray-900"><%= booking.checkIn.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' }) %></p>
            </div>
            <div class="text-gray-300">
              <i class="fa-solid fa-arrow-right-long"></i>
            </div>
            <div class="text-right">
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Check-out</p>
              <p class="font-bold text-gray-900"><%= booking.checkOut.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' }) %></p>
            </div>
          </div>
          
          <div class="border-t border-gray-200 pt-4 flex items-center justify-between">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Status</p>
            <% if (booking.status === 'confirmed' || booking.paymentStatus === 'paid') { %>
              <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-green-100 text-green-700">
                <i class="fa-solid fa-circle-check"></i> Confirmed
              </span>
            <% } else if (booking.status === 'cancelled') { %>
              <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-red-100 text-red-700">
                <i class="fa-solid fa-circle-xmark"></i> Cancelled
              </span>
            <% } else { %>
              <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-yellow-100 text-yellow-700">
                <i class="fa-solid fa-clock"></i> <%= booking.status %>
              </span>
            <% } %>
          </div>
        </div>

        <div class="bg-gradient-to-br from-gray-900 to-gray-800 rounded-xl p-5 border border-gray-700 text-white relative overflow-hidden">
          <div class="absolute -right-4 -top-4 w-24 h-24 bg-white/10 rounded-full blur-xl"></div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 relative z-10">Total Amount</p>
          <p class="text-3xl font-bold relative z-10">₹<%= booking.finalTotal.toLocaleString("en-IN") %></p>
        </div>

      </div>
    </div>
  </div>
</div>