<% layout('layouts/hostBoilerplate') -%>
  <script>
    window.currentPath = '/host/bookings';
  </script>

  <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-8 gap-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 tracking-tight mb-2">Bookings</h1>
      <p class="text-gray-500">Track and manage reservations across all your properties.</p>
    </div>
  </div>

  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <% if (!bookings || bookings.length===0) { %>
      <div class="p-12 text-center flex flex-col items-center">
        <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center text-gray-300 text-3xl mb-4">
          <i class="fa-solid fa-calendar-xmark"></i>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">No bookings yet</h3>
        <p class="text-gray-500 mb-6 max-w-sm mx-auto">You don't have any reservations right now. Keep your listings
          updated to attract more guests.</p>
        <a href="/host/listings"
          class="bg-gray-900 text-white px-6 py-2.5 rounded-xl font-medium hover:bg-gray-800 transition-colors shadow-sm">
          View My Listings
        </a>
      </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-left whitespace-nowrap">
            <thead>
              <tr
                class="bg-gray-50 border-b border-gray-100 text-gray-500 text-xs uppercase tracking-wider font-semibold">
                <th class="px-6 py-4 rounded-tl-2xl">Guest & Property</th>
                <th class="px-6 py-4">Dates</th>
                <th class="px-6 py-4">Amount</th>
                <th class="px-6 py-4">Status</th>
                <th class="px-6 py-4 text-right rounded-tr-2xl">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% bookings.forEach(b=> { %>
                <tr class="hover:bg-gray-50/50 transition-colors group">

                  <td class="px-6 py-4">
                    <div class="flex flex-col">
                      <span class="font-bold text-gray-900 flex items-center gap-2">
                        <i class="fa-solid fa-user text-gray-400 text-xs"></i>
                        <%= b.user.username %>
                      </span>
                      <span class="text-xs text-gray-500 truncate max-w-[200px] flex items-center gap-1 mt-1">
                        <i class="fa-solid fa-house-chimney text-[10px]"></i>
                        <%= b.listing.title %>
                      </span>
                    </div>
                  </td>

                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3 text-sm">
                      <div class="flex flex-col">
                        <span class="font-medium text-gray-900">
                          <%= new Date(b.checkIn).toLocaleDateString('en-US', { month: 'short' , day: 'numeric' }) %>
                        </span>
                        <span class="text-xs text-gray-500">
                          <%= new Date(b.checkIn).getFullYear() %>
                        </span>
                      </div>
                      <i class="fa-solid fa-arrow-right text-gray-300 text-xs"></i>
                      <div class="flex flex-col">
                        <span class="font-medium text-gray-900">
                          <%= new Date(b.checkOut).toLocaleDateString('en-US', { month: 'short' , day: 'numeric' }) %>
                        </span>
                        <span class="text-xs text-gray-500">
                          <%= new Date(b.checkOut).getFullYear() %>
                        </span>
                      </div>
                    </div>
                  </td>

                  <td class="px-6 py-4">
                    <span class="font-bold text-gray-900">₹<%= b.finalTotal.toLocaleString("en-IN") %></span>
                  </td>

                  <td class="px-6 py-4">
                    <% if (b.status==='confirmed' || b.paymentStatus==='paid' ) { %>
                      <span
                        class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-100">
                        <i class="fa-solid fa-circle-check text-[10px]"></i> Confirmed
                      </span>
                      <% } else if (b.status==='cancelled' ) { %>
                        <span
                          class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-50 text-red-700 border border-red-100">
                          <i class="fa-solid fa-circle-xmark text-[10px]"></i> Cancelled
                        </span>
                        <% } else { %>
                          <span
                            class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-yellow-50 text-yellow-700 border border-yellow-100">
                            <i class="fa-solid fa-clock text-[10px]"></i>
                            <%= b.status %>
                          </span>
                          <% } %>
                  </td>

                  <td class="px-6 py-4 text-right">
                    <div class="flex items-center justify-end gap-2">
                      <a href="/host/bookings/<%= b._id %>"
                        class="p-2 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors"
                        title="View Details">
                        <i class="fa-solid fa-eye"></i>
                      </a>
                      <button type="button"
                        class="p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors"
                        title="Hide Booking" onclick="hideFromHost('<%= b._id %>')">
                        <i class="fa-solid fa-trash-can"></i>
                      </button>
                    </div>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
  </div>

  <script>
    function hideFromHost(bookingId) {
      if (confirm("Hide this booking? It will be removed from your view but not deleted.")) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/host/bookings/${bookingId}/hide?_method=PATCH`;

        const csrfInput = document.createElement('input');
        csrfInput.type = 'hidden';
        csrfInput.name = '_csrf';
        csrfInput.value = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';
        form.appendChild(csrfInput);

        document.body.appendChild(form);
        form.submit();
      }
    }
  </script>