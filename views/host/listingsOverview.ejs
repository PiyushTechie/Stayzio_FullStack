<% layout('layouts/hostBoilerplate') -%>
<script>
  window.currentPath = '/host/listings';
</script>

<div class="flex flex-col sm:flex-row sm:items-center justify-between mb-8 gap-4">
  <div>
    <h1 class="text-3xl font-bold text-gray-900 tracking-tight mb-2">My Listings</h1>
    <p class="text-gray-500">Manage your properties and check their performance.</p>
  </div>
  <a href="/listings/new" class="inline-flex items-center justify-center gap-2 bg-[#fe424d] hover:bg-[#e63946] text-white px-5 py-2.5 rounded-xl font-medium transition-colors shadow-sm w-full sm:w-auto">
    <i class="fa-solid fa-plus"></i>
    <span>Create Listing</span>
  </a>
</div>

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
  <% if (listings.length === 0) { %>
    <div class="p-12 text-center flex flex-col items-center">
      <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center text-gray-300 text-3xl mb-4">
        <i class="fa-solid fa-house-crack"></i>
      </div>
      <h3 class="text-xl font-bold text-gray-900 mb-2">No listings yet</h3>
      <p class="text-gray-500 mb-6 max-w-sm mx-auto">You haven't added any properties to host. Create your first listing to start earning!</p>
      <a href="/listings/new" class="bg-gray-900 text-white px-6 py-2.5 rounded-xl font-medium hover:bg-gray-800 transition-colors shadow-sm">
        Add a Property
      </a>
    </div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-left whitespace-nowrap">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-100 text-gray-500 text-xs uppercase tracking-wider font-semibold">
            <th class="px-6 py-4 rounded-tl-2xl">Property</th>
            <th class="px-6 py-4">Location</th>
            <th class="px-6 py-4">Price / Night</th>
            <th class="px-6 py-4">Bookings</th>
            <th class="px-6 py-4 text-right rounded-tr-2xl">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% listings.forEach(listing => { %>
            <tr class="hover:bg-gray-50/50 transition-colors group">
              <td class="px-6 py-4">
                <div class="flex items-center gap-4">
                  <div class="w-12 h-12 rounded-lg bg-gray-100 overflow-hidden shrink-0">
                    <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="w-full h-full object-cover">
                  </div>
                  <div>
                    <p class="font-bold text-gray-900 truncate max-w-[200px] lg:max-w-[300px]"><%= listing.title %></p>
                    <p class="text-xs text-gray-500 truncate max-w-[200px]"><%= listing.category %></p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 text-sm text-gray-600">
                <div class="flex items-center gap-1.5">
                  <i class="fa-solid fa-location-dot text-gray-400"></i>
                  <%= listing.location %>
                </div>
              </td>
              <td class="px-6 py-4">
                <span class="font-medium text-gray-900">₹<%= listing.price.toLocaleString("en-IN") %></span>
              </td>
              <td class="px-6 py-4">
                <div class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
                  <%= listing.bookingCount %> bookings
                </div>
              </td>
              <td class="px-6 py-4 text-right">
                <div class="flex items-center justify-end gap-2">
                  <a href="/host/listings/<%= listing._id %>" class="p-2 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="View Details">
                    <i class="fa-solid fa-eye"></i>
                  </a>
                  <a href="/listings/<%= listing._id %>/edit" class="p-2 text-gray-400 hover:text-orange-500 hover:bg-orange-50 rounded-lg transition-colors" title="Edit Listing">
                    <i class="fa-solid fa-pen-to-square"></i>
                  </a>
                  <a href="/host/listings/<%= listing._id %>/pricing" class="p-2 text-gray-400 hover:text-green-600 hover:bg-green-50 rounded-lg transition-colors" title="Dynamic Pricing">
                    <i class="fa-solid fa-tags"></i>
                  </a>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>