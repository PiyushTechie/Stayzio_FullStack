<% layout('layouts/hostBoilerplate') -%>
<script>
  window.currentPath = '/host/listings';
</script>

<div class="mb-4 flex items-center gap-2 text-sm text-gray-500 font-medium">
  <a href="/host/listings" class="hover:text-gray-900 transition-colors">My Listings</a>
  <i class="fa-solid fa-chevron-right text-[10px]"></i>
  <a href="/host/listings/<%= listing._id %>" class="hover:text-gray-900 transition-colors truncate max-w-[150px]"><%= listing.title %></a>
  <i class="fa-solid fa-chevron-right text-[10px]"></i>
  <span class="text-gray-900">Dynamic Pricing</span>
</div>

<div class="flex flex-col sm:flex-row sm:items-end justify-between mb-8 gap-4">
  <div>
    <h1 class="text-3xl font-bold text-gray-900 tracking-tight mb-2">Dynamic Pricing</h1>
    <p class="text-gray-500">Automated price adjustments based on demand for <strong class="text-gray-700"><%= listing?.title ?? "Listing" %></strong>.</p>
  </div>
  <a href="/host/listings/<%= listing._id %>" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 text-gray-700 border border-gray-200 px-5 py-2.5 rounded-xl font-medium transition-colors shadow-sm">
    <i class="fa-solid fa-arrow-left"></i>
    <span>Back to Listing</span>
  </a>
</div>

<% if (!dynamicPrices || dynamicPrices.length === 0) { %>
  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-12 text-center flex flex-col items-center">
    <div class="w-20 h-20 bg-blue-50 rounded-full flex items-center justify-center text-blue-300 text-3xl mb-4">
      <i class="fa-solid fa-chart-line"></i>
    </div>
    <h3 class="text-xl font-bold text-gray-900 mb-2">No Pricing Data Yet</h3>
    <p class="text-gray-500 mb-6 max-w-sm mx-auto">Dynamic pricing algorithms haven't generated predictions for this property yet. Please check back later.</p>
  </div>
<% } else { %>
  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-100 bg-gray-50/50 flex justify-between items-center">
      <h3 class="font-semibold text-gray-900 flex items-center gap-2">
        <i class="fa-solid fa-calendar-day text-blue-500"></i>
        Upcoming Price Forecast
      </h3>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-left whitespace-nowrap">
        <thead>
          <tr class="bg-white border-b border-gray-100 text-gray-400 text-xs uppercase tracking-wider font-semibold">
            <th class="px-6 py-4">Date</th>
            <th class="px-6 py-4 text-right">Optimized Price (₹)</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% dynamicPrices.forEach(day => { %>
            <tr class="hover:bg-blue-50/30 transition-colors group">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-gray-50 border border-gray-100 flex flex-col items-center justify-center shrink-0">
                    <span class="text-[10px] font-bold text-[#fe424d] uppercase leading-none mb-0.5"><%= new Date(day.date).toLocaleString('default', { month: 'short' }) %></span>
                    <span class="text-sm font-bold text-gray-700 leading-none"><%= new Date(day.date).getDate() %></span>
                  </div>
                  <div>
                    <p class="font-medium text-gray-900"><%= new Date(day.date).toLocaleDateString('en-US', { weekday: 'long' }) %></p>
                    <p class="text-xs text-gray-400"><%= new Date(day.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 text-right">
                <span class="text-lg font-bold text-green-600 bg-green-50 px-3 py-1 rounded-lg border border-green-100">
                  ₹<%= day.price.toLocaleString("en-IN") %>
                </span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>