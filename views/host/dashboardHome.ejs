<% layout('layouts/hostBoilerplate') -%>
<script>
  // Setup the currentPath variable for the sidebar active state
  window.currentPath = '/host';
</script>

<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900 tracking-tight mb-2">Host Dashboard</h1>
  <p class="text-gray-500">Welcome back, <strong class="text-gray-800"><%= currentUser.username %></strong>. Here’s a quick look at your hosting performance.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
  
  <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden group">
    <div class="absolute top-0 right-0 w-24 h-24 bg-blue-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
    <div class="relative z-10 flex items-start justify-between">
      <div>
        <p class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-1">Total Listings</p>
        <h3 class="text-4xl font-bold text-gray-900"><%= listings.length %></h3>
      </div>
      <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center text-xl shadow-inner">
        <i class="fa-solid fa-house-chimney"></i>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden group">
    <div class="absolute top-0 right-0 w-24 h-24 bg-green-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
    <div class="relative z-10 flex items-start justify-between">
      <div>
        <p class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-1">Total Bookings</p>
        <h3 class="text-4xl font-bold text-gray-900"><%= totalBookings %></h3>
      </div>
      <div class="w-12 h-12 bg-green-100 text-green-600 rounded-xl flex items-center justify-center text-xl shadow-inner">
        <i class="fa-solid fa-calendar-check"></i>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden group">
    <div class="absolute top-0 right-0 w-24 h-24 bg-purple-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
    <div class="relative z-10 flex items-start justify-between">
      <div>
        <p class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-1">Total Earnings</p>
        <h3 class="text-3xl font-bold text-gray-900 mt-1">₹<%= earnings.toLocaleString("en-IN") %></h3>
      </div>
      <div class="w-12 h-12 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center text-xl shadow-inner">
        <i class="fa-solid fa-wallet"></i>
      </div>
    </div>
  </div>

  <a href="/listings/new" class="bg-gradient-to-br from-[#fe424d] to-pink-500 rounded-2xl p-6 shadow-md hover:shadow-lg hover:-translate-y-1 transition-all relative overflow-hidden group flex flex-col justify-center text-white no-underline">
    <div class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
    <div class="relative z-10 flex items-center justify-between">
      <div>
        <h3 class="text-xl font-bold mb-1">Create Listing</h3>
        <p class="text-white/80 text-sm font-medium">Add a new property</p>
      </div>
      <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center text-xl backdrop-blur-sm shadow-inner group-hover:scale-110 transition-transform">
        <i class="fa-solid fa-plus"></i>
      </div>
    </div>
  </a>
</div>

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 mb-8">
  <h2 class="text-lg font-bold text-gray-900 mb-4">Quick Actions</h2>
  <div class="flex flex-wrap gap-4">
    <a href="/host/listings" class="flex items-center gap-2 bg-gray-50 hover:bg-gray-100 text-gray-700 px-5 py-3 rounded-xl font-medium transition-colors border border-gray-200 shadow-sm">
      <i class="fa-solid fa-list-check text-[#fe424d]"></i>
      Manage Listings
    </a>
    <a href="/host/bookings" class="flex items-center gap-2 bg-gray-50 hover:bg-gray-100 text-gray-700 px-5 py-3 rounded-xl font-medium transition-colors border border-gray-200 shadow-sm">
      <i class="fa-solid fa-book-open text-blue-500"></i>
      Manage Bookings
    </a>
    <a href="/host/analytics" class="flex items-center gap-2 bg-gray-50 hover:bg-gray-100 text-gray-700 px-5 py-3 rounded-xl font-medium transition-colors border border-gray-200 shadow-sm">
      <i class="fa-solid fa-chart-pie text-green-500"></i>
      View Performance
    </a>
  </div>
</div>
