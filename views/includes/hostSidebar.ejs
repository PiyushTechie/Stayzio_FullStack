<div class="fixed inset-y-0 left-0 w-64 bg-white border-r border-gray-100 shadow-sm z-50 transform transition-transform duration-300 lg:translate-x-0 -translate-x-full" id="hostSidebar">
  
  <div class="h-16 flex items-center justify-between px-6 border-b border-gray-100">
    <a href="/host" class="flex items-center w-full max-w-[200px]">
      <img src="/images/logonobg.png" alt="Stayzio" class="h-12 w-auto object-contain">
    </a>
    <button class="lg:hidden text-gray-500 hover:text-gray-800" onclick="document.getElementById('hostSidebar').classList.toggle('-translate-x-full')">
      <i class="fa-solid fa-xmark text-xl"></i>
    </button>
  </div>

  <div class="p-4 space-y-1">
    <p class="px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 mt-2">Main Menu</p>
    
    <a href="/host" class="flex items-center gap-3 px-3 py-2.5 rounded-lg font-medium <%= (typeof currentPath !== 'undefined' && currentPath === '/host') ? 'bg-[#fe424d]/10 text-[#fe424d]' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900' %> transition-colors">
      <i class="fa-solid fa-gauge-high w-5 text-center"></i>
      <span>Dashboard</span>
    </a>

    <a href="/host/listings" class="flex items-center gap-3 px-3 py-2.5 rounded-lg font-medium <%= (typeof currentPath !== 'undefined' && currentPath.startsWith('/host/listings')) ? 'bg-[#fe424d]/10 text-[#fe424d]' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900' %> transition-colors">
      <i class="fa-solid fa-house-chimney w-5 text-center"></i>
      <span>My Listings</span>
    </a>

    <a href="/host/bookings" class="flex items-center gap-3 px-3 py-2.5 rounded-lg font-medium <%= (typeof currentPath !== 'undefined' && currentPath.startsWith('/host/bookings')) ? 'bg-[#fe424d]/10 text-[#fe424d]' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900' %> transition-colors">
      <i class="fa-solid fa-calendar-check w-5 text-center"></i>
      <span>Bookings</span>
    </a>

    <a href="/host/analytics" class="flex items-center gap-3 px-3 py-2.5 rounded-lg font-medium <%= (typeof currentPath !== 'undefined' && currentPath === '/host/analytics') ? 'bg-[#fe424d]/10 text-[#fe424d]' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900' %> transition-colors">
      <i class="fa-solid fa-chart-line w-5 text-center"></i>
      <span>Analytics</span>
    </a>
  </div>



</div>

<button class="lg:hidden fixed bottom-6 right-6 z-40 bg-[#fe424d] text-white p-3 rounded-full shadow-lg" onclick="document.getElementById('hostSidebar').classList.toggle('-translate-x-full')">
  <i class="fa-solid fa-bars text-xl"></i>
</button>
