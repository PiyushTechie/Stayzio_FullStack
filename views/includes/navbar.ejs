<% const isHomepage=typeof isHome !=='undefined' && isHome; const compactMode=typeof isCompact !=='undefined' &&
    isCompact; %>

    <nav id="universal-navbar"
        class="fixed top-0 w-full z-50 transition-all duration-500 <%= isHomepage ? 'glass-nav-transparent py-3' : (compactMode ? 'glass-nav-solid py-1' : 'glass-nav-solid py-1.5') %>">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center transition-all duration-300">

                <div class="flex-shrink-0 flex items-center">
                    <a href="/" class="flex items-center gap-2 group outline-none">
                        <img src="/images/logonobg.png" alt="Stayzio"
                            class="<%= isHomepage ? 'h-12 md:h-16' : (compactMode ? 'h-8 md:h-10' : 'h-10 md:h-12') %> w-auto drop-shadow-md transition-all duration-500 group-hover:scale-105 group-hover:-rotate-2 group-hover:drop-shadow-xl"
                            id="navLogo">
                    </a>
                </div>

                <div class="hidden md:flex items-center justify-center flex-1 px-8">
                    <div class="flex space-x-2 border border-transparent rounded-full px-3 py-1.5 transition-all duration-500 hover:border-gray-200/40 hover:bg-white/10 backdrop-blur-md shadow-sm"
                        id="navLinksContainer">
                        <a href="/listings"
                            class="nav-magic-link px-5 py-2.5 font-sans font-bold text-sm tracking-widest transition-colors duration-300 <%= isHomepage ? 'text-white' : 'text-gray-700' %>">
                            <span class="relative z-10">STAYS</span>
                        </a>
                        <a href="/experiences"
                            class="nav-magic-link px-5 py-2.5 font-sans font-bold text-sm tracking-widest transition-colors duration-300 <%= isHomepage ? 'text-white' : 'text-gray-700' %>">
                            <span class="relative z-10">EXPERIENCES</span>
                        </a>
                        <a href="/about"
                            class="nav-magic-link px-5 py-2.5 font-sans font-bold text-sm tracking-widest transition-colors duration-300 <%= isHomepage ? 'text-white' : 'text-gray-700' %>">
                            <span class="relative z-10">ABOUT</span>
                        </a>
                    </div>
                </div>

                <div class="flex items-center gap-3">

                    <div class="relative ml-2" id="userMenuContainer">
                        <% if (currentUser) { %>
                            <button id="userProfileBtn"
                                class="flex items-center gap-2 bg-white/90 border border-gray-200 shadow-sm rounded-full py-1.5 px-2 hover:shadow-lg hover:border-gray-300 hover:-translate-y-0.5 transition-all duration-300 group">
                                <i
                                    class="fa-solid fa-bars text-gray-500 ml-2 group-hover:text-gray-900 transition-colors"></i>
                                <img src="<%= currentUser.profile?.photo?.url || 'https://images.unsplash.com/photo-1633332755192-727a05c4013d?q=80&w=100&auto=format&fit=crop' %>"
                                    alt="Profile" style="width: 40px; height: 40px; min-width: 40px; min-height: 40px;"
                                    class="w-10 h-10 flex-shrink-0 rounded-full object-cover border-2 border-transparent group-hover:border-[#fe424d] transition-all duration-300 m-0 p-0 shadow-sm">
                            </button>

                            <div id="userDropdownMenu"
                                class="absolute right-0 mt-3 w-64 bg-white rounded-2xl shadow-2xl py-2 border border-gray-100 opacity-0 invisible transform scale-95 origin-top-right transition-all duration-300 ease-out z-[100]">
                                <div class="px-5 py-4 border-b border-gray-50 bg-gray-50/50 rounded-t-2xl">
                                    <p class="text-base font-sans font-black text-gray-900 truncate">
                                        <%= currentUser.username %>
                                    </p>
                                    <p class="text-sm font-sans text-gray-500 truncate">
                                        <%= currentUser.email %>
                                    </p>
                                </div>
                                <div class="py-2">
                                    <a href="/listings/new"
                                        class="block px-5 py-2.5 font-sans text-sm text-gray-700 hover:bg-red-50 hover:text-[#fe424d] font-bold transition-colors">Add
                                        new listing</a>
                                    <a href="/profile"
                                        class="block px-5 py-2.5 font-sans text-sm text-gray-700 hover:bg-red-50 hover:text-[#fe424d] font-bold transition-colors">Profile</a>
                                </div>
                                <div class="border-t border-gray-100"></div>
                                <form action="/logout" method="POST" class="w-full m-0 p-0 py-1">
                                    <input type="hidden" name="_csrf"
                                        value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                    <button type="submit"
                                        class="w-full text-left px-5 py-2.5 font-sans text-sm text-red-600 hover:bg-red-50 font-black transition-colors">Sign
                                        out</button>
                                </form>
                            </div>
                            <% } else { %>
                                <div class="flex items-center gap-2 md:gap-4">
                                    <a href="/login"
                                        class="btn-login-minimal font-sans hidden md:inline-flex items-center justify-center py-2 text-sm font-bold <%= isHomepage ? 'text-white' : 'text-gray-700' %>">
                                        <span>Log in</span>
                                    </a>

                                    <a href="/signup" class="custom-signup-btn font-sans" style="--clr: #fe424d">
                                        <span class="custom-signup-btn__icon-wrapper">
                                            <svg viewBox="0 0 14 15" fill="none" xmlns="http://www.w3.org/2000/svg"
                                                class="custom-signup-btn__icon-svg" width="10">
                                                <path
                                                    d="M13.376 11.552l-.264-10.44-10.44-.24.024 2.28 6.96-.048L.2 12.56l1.488 1.488 9.432-9.432-.048 6.912 2.304.024z"
                                                    fill="currentColor"></path>
                                            </svg>
                                            <svg viewBox="0 0 14 15" fill="none" width="10"
                                                xmlns="http://www.w3.org/2000/svg"
                                                class="custom-signup-btn__icon-svg custom-signup-btn__icon-svg--copy">
                                                <path
                                                    d="M13.376 11.552l-.264-10.44-10.44-.24.024 2.28 6.96-.048L.2 12.56l1.488 1.488 9.432-9.432-.048 6.912 2.304.024z"
                                                    fill="currentColor"></path>
                                            </svg>
                                        </span>
                                        Sign up
                                    </a>
                                </div>
                                <% } %>
                    </div>

                    <button id="mobileMenuToggle"
                        class="md:hidden flex items-center justify-center w-12 h-12 rounded-full transition-all duration-300 hover:bg-gray-200/30 <%= isHomepage ? 'text-white' : 'text-gray-900' %>">
                        <i class="fa-solid fa-bars text-2xl"></i>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <div id="mobileMenuOverlay"
        class="fixed inset-0 bg-gray-900/60 backdrop-blur-md z-[90] opacity-0 invisible transition-all duration-400 ease-in-out">
    </div>
    <div id="mobileMenuPanel"
        class="fixed top-0 right-0 h-full w-[85%] max-w-sm bg-white z-[100] transform translate-x-full transition-transform duration-500 cubic-bezier(0.16, 1, 0.3, 1) shadow-2xl flex flex-col rounded-l-3xl">
        <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/50 rounded-tl-3xl">
            <span class="font-black font-sans text-2xl text-gray-900 tracking-tight">Stayzio</span>
            <button id="closeMobileMenu"
                class="w-10 h-10 flex items-center justify-center rounded-full bg-white border-2 border-gray-200 text-gray-500 hover:text-white hover:bg-[#fe424d] hover:border-[#fe424d] transition-all duration-300 rotate-0 hover:rotate-90">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>

        <div class="flex-1 overflow-y-auto p-6 flex flex-col gap-6">
            <% if (currentUser) { %>
                <div class="flex items-center gap-4 bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
                    <img src="<%= currentUser.profile?.photo?.url || 'https://images.unsplash.com/photo-1633332755192-727a05c4013d?q=80&w=100&auto=format&fit=crop' %>"
                        alt="Profile" style="width: 56px; height: 56px; min-width: 56px; min-height: 56px;"
                        class="w-14 h-14 flex-shrink-0 rounded-full object-cover shadow-sm border-2 border-gray-50">
                    <div class="overflow-hidden">
                        <p class="font-black font-sans text-lg text-gray-900 truncate">
                            <%= currentUser.username %>
                        </p>
                        <a href="/profile" class="text-sm font-sans text-[#fe424d] font-bold hover:underline">View
                            Profile</a>
                    </div>
                </div>
                <% } else { %>
                    <div class="flex flex-col gap-3">
                        <a href="/signup"
                            class="w-full py-3.5 font-sans bg-[#fe424d] text-white text-center rounded-xl font-black text-lg shadow-md hover:shadow-lg hover:-translate-y-0.5 transition-all">Sign
                            up</a>
                        <a href="/login"
                            class="w-full py-3.5 font-sans bg-white border-2 border-gray-200 text-gray-900 text-center rounded-xl font-bold text-lg hover:border-gray-900 transition-colors">Log
                            in</a>
                    </div>
                    <% } %>

                        <div class="border-t-2 border-gray-50"></div>

                        <div class="flex flex-col gap-5 mobile-nav-links">
                            <a href="/listings"
                                class="text-2xl font-black font-sans text-gray-800 hover:text-[#fe424d] transition-colors flex items-center justify-between group">STAYS
                                <i
                                    class="fa-solid fa-arrow-right text-base text-gray-300 group-hover:text-[#fe424d] group-hover:translate-x-1 transition-all"></i></a>
                            <a href="/experiences"
                                class="text-2xl font-black font-sans text-gray-800 hover:text-[#fe424d] transition-colors flex items-center justify-between group">EXPERIENCES
                                <i
                                    class="fa-solid fa-arrow-right text-base text-gray-300 group-hover:text-[#fe424d] group-hover:translate-x-1 transition-all"></i></a>
                            <a href="/about"
                                class="text-2xl font-black font-sans text-gray-800 hover:text-[#fe424d] transition-colors flex items-center justify-between group">ABOUT
                                <i
                                    class="fa-solid fa-arrow-right text-base text-gray-300 group-hover:text-[#fe424d] group-hover:translate-x-1 transition-all"></i></a>
                        </div>

                        <div class="border-t-2 border-gray-50"></div>

                        <div class="flex flex-col gap-4">
                            <a href="/listings/new"
                                class="font-bold font-sans text-gray-500 hover:text-gray-900 transition-colors text-lg">Add
                                new listing</a>
                        </div>

                        <% if (currentUser) { %>
                            <div class="mt-auto pt-6">
                                <form action="/logout" method="POST" class="w-full m-0 p-0">
                                    <input type="hidden" name="_csrf"
                                        value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                    <button type="submit"
                                        class="w-full py-4 font-sans bg-red-50 text-red-600 rounded-xl font-black text-lg hover:bg-red-100 hover:shadow-sm transition-all flex justify-center items-center gap-2">
                                        <i class="fa-solid fa-arrow-right-from-bracket"></i> Sign out
                                    </button>
                                </form>
                            </div>
                            <% } %>
        </div>
    </div>

    <style>
        .glass-nav-transparent {
            background: transparent;
            border-bottom: 1px solid transparent;
        }

        .glass-nav-solid {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.08);
        }

        #universal-navbar.scrolled {
            background: rgba(255, 255, 255, 0.95) !important;
            backdrop-filter: blur(25px) !important;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05) !important;
            box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.08) !important;
            padding-top: 0.75rem !important;
            padding-bottom: 0.75rem !important;
        }

        #universal-navbar.scrolled .nav-magic-link {
            color: #374151 !important;
        }

        #universal-navbar.scrolled .nav-magic-link:hover,
        .nav-magic-link:hover {
            color: white !important;
        }

        #universal-navbar.scrolled .btn-login-minimal {
            color: #374151 !important;
        }

        .nav-magic-link {
            position: relative;
            overflow: hidden;
            border-radius: 9999px;
            z-index: 1;
        }

        .nav-magic-link::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 0%;
            height: 3px;
            background: #fe424d;
            border-radius: 9999px;
            z-index: -1;
            transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            opacity: 0;
        }

        .nav-magic-link:hover::before {
            width: 100%;
            height: 100%;
            opacity: 1;
        }

        .nav-magic-link:hover {
            color: white !important;
        }

        .nav-magic-link span {
            transition: transform 0.3s ease;
            display: inline-block;
        }

        .nav-magic-link:hover span {
            transform: translateY(-1px);
        }

        .btn-login-minimal {
            position: relative;
            transition: color 0.3s ease;
            padding: 0.25rem 0.5rem;
        }

        .btn-login-minimal::after {
            content: '';
            position: absolute;
            width: 100%;
            height: 2px;
            bottom: 0;
            left: 0;
            background-color: #fe424d;
            transform: scaleX(0);
            transform-origin: bottom right;
            transition: transform 0.4s cubic-bezier(0.86, 0, 0.07, 1);
        }

        .btn-login-minimal:hover::after {
            transform: scaleX(1);
            transform-origin: bottom left;
        }

        #universal-navbar.scrolled .btn-login-minimal:hover {
            color: #fe424d !important;
        }

        .custom-signup-btn {
            line-height: 1;
            text-decoration: none;
            display: inline-flex;
            border: none;
            cursor: pointer;
            align-items: center;
            gap: 0.5rem;
            background-color: var(--clr);
            color: #fff;
            border-radius: 9999px;
            font-weight: 800;
            padding: 0.5rem 1.25rem 0.5rem 0.6rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            transition: background-color 0.3s ease, transform 0.2s ease;
        }

        .custom-signup-btn__icon-wrapper {
            flex-shrink: 0;
            width: 25px;
            height: 25px;
            position: relative;
            color: var(--clr);
            background-color: #fff;
            border-radius: 50%;
            display: grid;
            place-items: center;
            overflow: hidden;
        }

        .custom-signup-btn:hover {
            background-color: #111827;
            transform: translateY(-1px);
        }

        .custom-signup-btn:hover .custom-signup-btn__icon-wrapper {
            color: #111827;
        }

        .custom-signup-btn__icon-svg--copy {
            position: absolute;
            transform: translate(-150%, 150%);
        }

        .custom-signup-btn:hover .custom-signup-btn__icon-svg:first-child {
            transition: transform 0.3s ease-in-out;
            transform: translate(150%, -150%);
        }

        .custom-signup-btn:hover .custom-signup-btn__icon-svg--copy {
            transition: transform 0.3s ease-in-out 0.1s;
            transform: translate(0);
        }

        .cubic-bezier {
            transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const profileBtn = document.getElementById('userProfileBtn');
            const dropdownMenu = document.getElementById('userDropdownMenu');

            if (profileBtn && dropdownMenu) {
                profileBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const isOpen = !dropdownMenu.classList.contains('opacity-0');
                    if (isOpen) {
                        dropdownMenu.classList.add('opacity-0', 'invisible', 'scale-95');
                        dropdownMenu.classList.remove('opacity-100', 'visible', 'scale-100');
                    } else {
                        dropdownMenu.classList.remove('opacity-0', 'invisible', 'scale-95');
                        dropdownMenu.classList.add('opacity-100', 'visible', 'scale-100');
                    }
                });

                document.addEventListener('click', (e) => {
                    if (!profileBtn.contains(e.target) && !dropdownMenu.contains(e.target)) {
                        dropdownMenu.classList.add('opacity-0', 'invisible', 'scale-95');
                        dropdownMenu.classList.remove('opacity-100', 'visible', 'scale-100');
                    }
                });
            }

            const mobileToggle = document.getElementById('mobileMenuToggle');
            const mobilePanel = document.getElementById('mobileMenuPanel');
            const mobileOverlay = document.getElementById('mobileMenuOverlay');
            const closeMobile = document.getElementById('closeMobileMenu');

            function openMobileMenu() {
                mobileOverlay.classList.remove('opacity-0', 'invisible');
                mobilePanel.classList.remove('translate-x-full');
                document.body.style.overflow = 'hidden';
            }

            function closeMobileMenuFunc() {
                mobileOverlay.classList.add('opacity-0', 'invisible');
                mobilePanel.classList.add('translate-x-full');
                document.body.style.overflow = '';
            }

            if (mobileToggle) mobileToggle.addEventListener('click', openMobileMenu);
            if (closeMobile) closeMobile.addEventListener('click', closeMobileMenuFunc);
            if (mobileOverlay) mobileOverlay.addEventListener('click', closeMobileMenuFunc);

            const navbar = document.getElementById('universal-navbar');
            const isHomepage = <%= isHomepage %>;

            if (navbar) {
                window.addEventListener('scroll', () => {
                    if (window.scrollY > 40) {
                        navbar.classList.add('scrolled');
                        document.getElementById('navLogo').classList.remove('h-12', 'md:h-16');
                        document.getElementById('navLogo').classList.add('h-10', 'md:h-12');
                    } else {
                        navbar.classList.remove('scrolled');
                        if (isHomepage) {
                            document.getElementById('navLogo').classList.remove('h-10', 'md:h-12');
                            document.getElementById('navLogo').classList.add('h-12', 'md:h-16');
                        }
                    }
                });

                if (window.scrollY > 40) {
                    navbar.classList.add('scrolled');
                    document.getElementById('navLogo').classList.remove('h-12', 'md:h-16');
                    document.getElementById('navLogo').classList.add('h-10', 'md:h-12');
                }
            }
        });
    </script>